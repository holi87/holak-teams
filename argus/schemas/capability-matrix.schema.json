{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/holi87/holak-teams/argus/schemas/capability-matrix.schema.json",
  "title": "Argus capability matrix",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "supportedBuiltinTools", "legacyToolReplacements", "orchestration", "capabilities", "agents"],
  "properties": {
    "$schema": { "type": "string" },
    "schemaVersion": { "const": 1 },
    "supportedBuiltinTools": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "pattern": "^[A-Za-z][A-Za-z0-9]*$" }
    },
    "legacyToolReplacements": {
      "type": "object",
      "additionalProperties": { "type": "string", "minLength": 1 },
      "required": ["LS", "MultiEdit", "Task", "TodoWrite"]
    },
    "orchestration": {
      "type": "object",
      "additionalProperties": false,
      "required": ["requiredTools", "requiredAssets", "artifactPaths"],
      "properties": {
        "requiredTools": { "$ref": "#/$defs/stringList" },
        "requiredAssets": { "$ref": "#/$defs/stringList" },
        "artifactPaths": { "$ref": "#/$defs/stringList" }
      }
    },
    "capabilities": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": ["kind", "missingDisposition", "fallback"],
        "properties": {
          "kind": { "enum": ["browser", "mcp", "target"] },
          "serverPatterns": { "$ref": "#/$defs/stringList" },
          "missingDisposition": { "enum": ["degraded", "deferred", "skipped"] },
          "fallback": { "type": "string", "minLength": 1 }
        }
      }
    },
    "agents": {
      "type": "array",
      "minItems": 27,
      "maxItems": 27,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["slug", "lane", "modes", "requiredTools", "artifactPaths"],
        "properties": {
          "slug": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
          "lane": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
          "modes": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": { "enum": ["A", "B", "C", "D"] }
          },
          "requiredTools": { "$ref": "#/$defs/stringList" },
          "requiredCapabilities": { "$ref": "#/$defs/stringList" },
          "optionalCapabilities": { "$ref": "#/$defs/stringList" },
          "artifactPaths": { "$ref": "#/$defs/stringList" }
        }
      }
    }
  },
  "$defs": {
    "stringList": {
      "type": "array",
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 }
    }
  }
}
