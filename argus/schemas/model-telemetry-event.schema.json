{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://holak-teams.local/argus/model-telemetry-event.schema.json",
  "title": "Sanitized telemetry bound to one immutable model decision",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema", "timestamp", "eventId", "decisionId", "decisionIntegritySha256",
    "adapterId", "adapterSnapshotSha256", "engagementId", "dispatchId", "attempt", "agent", "runtime", "tier",
    "model", "effort", "maxTurns", "signal", "reasonCode", "fallbackUsed", "success",
    "inputTokens", "outputTokens", "totalTokens", "durationMs"
  ],
  "properties": {
    "schema": { "const": "argus/model-telemetry-event@2" },
    "timestamp": { "type": "string", "format": "date-time" },
    "eventId": { "type": "string", "pattern": "^MDL-[a-f0-9]{24}$" },
    "decisionId": { "type": "string", "pattern": "^MDR-[a-f0-9]{24}$" },
    "decisionIntegritySha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "adapterId": { "enum": ["claude-plugin-agent@1", "codex-custom-agent@1"] },
    "adapterSnapshotSha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "engagementId": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$" },
    "dispatchId": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$" },
    "attempt": { "type": "integer", "minimum": 1 },
    "agent": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
    "runtime": { "enum": ["claude", "codex"] },
    "tier": { "enum": ["frontier", "standard", "mechanical"] },
    "model": { "type": "string", "minLength": 1 },
    "effort": { "type": "string", "minLength": 1 },
    "maxTurns": { "type": "integer", "minimum": 1 },
    "signal": { "type": "string", "minLength": 1 },
    "reasonCode": {
      "enum": [
        "BASELINE_SELECTED",
        "ESCALATION_SELECTED",
        "SIGNAL_NOT_ALLOWED",
        "MECHANICAL_FULL_ROLE_FORBIDDEN",
        "FRONTIER_UNAVAILABLE",
        "CAPABILITY_DRIFT"
      ]
    },
    "fallbackUsed": { "type": "boolean" },
    "success": { "type": "boolean" },
    "inputTokens": { "type": "number", "minimum": 0 },
    "outputTokens": { "type": "number", "minimum": 0 },
    "totalTokens": { "type": "number", "minimum": 0 },
    "durationMs": { "type": "number", "minimum": 0 },
    "reportedCostUsd": { "type": "number", "minimum": 0 }
  }
}
