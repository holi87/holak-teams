{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://holak-teams.local/argus/native-launch-receipt.schema.json",
  "title": "Verified Argus native launch receipt",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema", "schemaVersion", "launchId", "engagementId", "launcherPid", "launchCapabilitySha256",
    "authorizationPath", "authorizationSha256", "trustStorePath", "trustStoreSha256",
    "runtimeKeyId", "runtimeKeyFingerprintSha256", "targetKind", "target", "workspace",
    "artifactRoot", "mode", "runtime", "model", "effort", "maxTurns", "launcherExecutable", "launcherSha256",
    "claudeExecutable", "claudeExecutableSha256", "claudeVersion", "sandboxPolicy", "sandboxProbePath",
    "sandboxProbeDevice", "sandboxProbeInode", "sandboxProbeUid", "sandboxProbeMode",
    "environmentPolicy", "verifiedAt", "expiresAt"
  ],
  "properties": {
    "schema": { "const": "argus/native-launch-receipt@1" },
    "schemaVersion": { "const": 1 },
    "launchId": { "type": "string", "pattern": "^LCH-[a-f0-9]{24}$" },
    "engagementId": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$" },
    "launcherPid": { "type": "integer", "minimum": 1 },
    "launchCapabilitySha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "authorizationPath": { "type": "string", "pattern": "^/" },
    "authorizationSha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "trustStorePath": { "type": "string", "pattern": "^/" },
    "trustStoreSha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "runtimeKeyId": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$" },
    "runtimeKeyFingerprintSha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "targetKind": { "enum": ["path", "url"] },
    "target": { "type": "string", "minLength": 1 },
    "workspace": { "type": "string", "pattern": "^/" },
    "artifactRoot": { "type": "string", "pattern": "^/" },
    "mode": { "enum": ["A", "B", "C", "D"] },
    "runtime": { "const": "claude" },
    "model": { "const": "opus" },
    "effort": { "const": "max" },
    "maxTurns": { "const": 96 },
    "launcherExecutable": { "type": "string", "pattern": "^/" },
    "launcherSha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "claudeExecutable": { "type": "string", "pattern": "^/" },
    "claudeExecutableSha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "claudeVersion": { "type": "string", "minLength": 1 },
    "sandboxPolicy": { "const": "os-native-target-readonly@2" },
    "sandboxProbePath": { "type": "string", "pattern": "^/" },
    "sandboxProbeDevice": { "type": "integer", "minimum": 0 },
    "sandboxProbeInode": { "type": "integer", "minimum": 1 },
    "sandboxProbeUid": { "type": "integer", "minimum": 0 },
    "sandboxProbeMode": { "const": 448 },
    "environmentPolicy": { "const": "argus-launch-allowlist@1" },
    "verifiedAt": { "type": "string", "format": "date-time" },
    "expiresAt": { "type": "string", "format": "date-time" }
  }
}
