{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/holi87/holak-teams/argus/schemas/evidence-reference-v1.schema.json",
  "title": "Argus redacted evidence reference legacy v1",
  "type": "object", "additionalProperties": false,
  "required": ["$schema", "schemaVersion", "engagementId", "id", "kind", "source", "collectedBy", "capturedAt", "redaction", "sha256", "relatedBugIds"],
  "properties": {
    "$schema": { "const": "argus/evidence-reference@1" }, "schemaVersion": { "const": 1 }, "engagementId": { "type": "string", "minLength": 1 },
    "id": { "type": "string", "pattern": "^EVD-[0-9]{4}$" }, "kind": { "enum": ["text", "http", "trace", "metric", "log"] }, "source": { "type": "string", "minLength": 1 },
    "collectedBy": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" }, "capturedAt": { "type": "string", "format": "date-time" }, "redaction": { "enum": ["redacted", "synthetic", "public"] },
    "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }, "relatedBugIds": { "type": "array", "uniqueItems": true, "items": { "type": "string", "pattern": "^BUG-[0-9]{4}$" } }
  }
}
