{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/holi87/holak-teams/argus/schemas/preflight-report.schema.json",
  "title": "Argus runtime preflight report",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "generatedAt", "mode", "status", "target", "artifactRoot", "authorization", "checks", "capabilities", "agents", "summary"],
  "properties": {
    "$schema": { "type": "string" },
    "schemaVersion": { "const": 1 },
    "generatedAt": { "type": "string", "format": "date-time" },
    "mode": { "enum": ["A", "B", "C", "D"] },
    "status": { "enum": ["ready", "degraded", "blocked"] },
    "target": {
      "type": "object",
      "additionalProperties": false,
      "required": ["value", "kind", "reachable", "evidence"],
      "properties": {
        "value": { "type": "string", "minLength": 1 },
        "kind": { "enum": ["path", "url"] },
        "reachable": { "type": "boolean" },
        "evidence": { "type": "string", "minLength": 1 }
      }
    },
    "artifactRoot": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "writable", "safePaths"],
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "writable": { "type": "boolean" },
        "safePaths": { "type": "boolean" }
      }
    },
    "authorization": {
      "type": "object",
      "additionalProperties": false,
      "required": ["manifestPath", "auditPath", "sha256", "created", "environment", "productionLike", "productionSignals", "defaultReadOnly"],
      "properties": {
        "manifestPath": { "type": "string", "minLength": 1 },
        "auditPath": { "type": "string", "minLength": 1 },
        "sha256": { "type": ["string", "null"], "pattern": "^[a-f0-9]{64}$" },
        "created": { "type": "boolean" },
        "environment": { "enum": ["unknown", "development", "test", "staging", "production"] },
        "productionLike": { "type": "boolean" },
        "productionSignals": { "$ref": "#/$defs/stringList" },
        "defaultReadOnly": { "type": "boolean" }
      }
    },
    "checks": {
      "type": "array",
      "items": { "$ref": "#/$defs/check" }
    },
    "capabilities": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "available", "evidence"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "available": { "type": "boolean" },
          "evidence": { "type": "string", "minLength": 1 }
        }
      }
    },
    "agents": {
      "type": "array",
      "minItems": 27,
      "maxItems": 27,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["slug", "lane", "selected", "status", "dispatchAllowed", "missingTools", "missingCapabilities", "actions", "artifactPaths", "authorization"],
        "properties": {
          "slug": { "type": "string", "minLength": 1 },
          "lane": { "type": "string", "minLength": 1 },
          "selected": { "type": "boolean" },
          "status": { "enum": ["not-selected", "ready", "degraded", "deferred", "skipped", "blocked"] },
          "dispatchAllowed": { "type": "boolean" },
          "missingTools": { "$ref": "#/$defs/stringList" },
          "missingCapabilities": { "$ref": "#/$defs/stringList" },
          "actions": { "$ref": "#/$defs/stringList" },
          "artifactPaths": { "$ref": "#/$defs/stringList" },
          "authorization": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["action", "decision", "ruleId", "reason"],
              "properties": {
                "action": { "type": "string", "minLength": 1 },
                "decision": { "enum": ["allow", "deny"] },
                "ruleId": { "type": "string", "pattern": "^AUTH-[A-Z0-9-]+$" },
                "reason": { "type": "string", "minLength": 1 }
              }
            }
          }
        }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["selected", "ready", "degraded", "deferred", "skipped", "blocked", "dispatchable"],
      "properties": {
        "selected": { "type": "integer", "minimum": 0 },
        "ready": { "type": "integer", "minimum": 0 },
        "degraded": { "type": "integer", "minimum": 0 },
        "deferred": { "type": "integer", "minimum": 0 },
        "skipped": { "type": "integer", "minimum": 0 },
        "blocked": { "type": "integer", "minimum": 0 },
        "dispatchable": { "type": "integer", "minimum": 0 }
      }
    }
  },
  "$defs": {
    "stringList": {
      "type": "array",
      "items": { "type": "string" }
    },
    "check": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "mandatory", "status", "evidence"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "mandatory": { "type": "boolean" },
        "status": { "enum": ["pass", "fail", "degraded"] },
        "evidence": { "type": "string", "minLength": 1 }
      }
    }
  }
}
