{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/holi87/holak-teams/argus/schemas/preflight-report.schema.json",
  "title": "Argus runtime preflight report v2",
  "type": "object",
  "additionalProperties": false,
  "required": ["$schema", "schemaVersion", "generatedAt", "mode", "modelRuntime", "status", "target", "artifactRoot", "authorization", "engagement", "orchestration", "checks", "capabilities", "agents", "summary"],
  "properties": {
    "$schema": { "const": "https://raw.githubusercontent.com/holi87/holak-teams/master/argus/schemas/preflight-report.schema.json" },
    "schemaVersion": { "const": 2 },
    "generatedAt": { "type": "string", "format": "date-time" },
    "mode": { "enum": ["A", "B", "C", "D"] },
    "modelRuntime": { "enum": ["claude", "codex"] },
    "status": { "enum": ["ready", "degraded", "blocked"] },
    "target": {
      "type": "object",
      "additionalProperties": false,
      "required": ["value", "kind", "reachable", "evidence"],
      "properties": {
        "value": { "type": "string", "minLength": 1 },
        "kind": { "enum": ["path", "url"] },
        "reachable": { "type": "boolean" },
        "evidence": { "type": "string", "minLength": 1 }
      }
    },
    "artifactRoot": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "writable", "safePaths"],
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "writable": { "type": "boolean" },
        "safePaths": { "type": "boolean" }
      }
    },
    "authorization": {
      "type": "object",
      "additionalProperties": false,
      "required": ["manifestPath", "auditPath", "sha256", "created", "environment", "productionLike", "productionSignals", "defaultReadOnly"],
      "properties": {
        "manifestPath": { "type": "string", "minLength": 1 },
        "auditPath": { "type": "string", "minLength": 1 },
        "sha256": { "type": ["string", "null"], "pattern": "^[a-f0-9]{64}$" },
        "created": { "type": "boolean" },
        "environment": { "enum": ["unknown", "development", "test", "staging", "production"] },
        "productionLike": { "type": "boolean" },
        "productionSignals": { "$ref": "#/$defs/stringList" },
        "defaultReadOnly": { "type": "boolean" }
      }
    },
    "engagement": {
      "type": "object",
      "additionalProperties": false,
      "required": ["manifestPath", "statePath", "immutabilityAuditPath", "sha256", "created", "stateCreated", "phase", "selectedAgents", "accessibilityTarget", "browserCoverageEntries", "browserCoverageSource", "hookPath", "hookPackaged"],
      "properties": {
        "manifestPath": { "type": "string", "minLength": 1 },
        "statePath": { "type": "string", "minLength": 1 },
        "immutabilityAuditPath": { "type": "string", "minLength": 1 },
        "sha256": { "type": ["string", "null"], "pattern": "^[a-f0-9]{64}$" },
        "created": { "type": "boolean" },
        "stateCreated": { "type": "boolean" },
        "phase": { "type": ["string", "null"] },
        "selectedAgents": { "type": "integer", "minimum": 0 },
        "accessibilityTarget": { "type": ["string", "null"] },
        "browserCoverageEntries": { "type": "integer", "minimum": 0 },
        "browserCoverageSource": { "type": ["string", "null"] },
        "hookPath": { "type": "string", "minLength": 1 },
        "hookPackaged": { "type": "boolean" }
      }
    },
    "orchestration": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "sha256", "specialists"],
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "sha256": { "type": ["string", "null"], "pattern": "^[a-f0-9]{64}$" },
        "specialists": { "type": "integer", "minimum": 0, "maximum": 26 }
      }
    },
    "checks": {
      "type": "array",
      "items": { "$ref": "#/$defs/check" }
    },
    "capabilities": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "available", "evidence"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "available": { "type": "boolean" },
          "evidence": { "type": "string", "minLength": 1 }
        }
      }
    },
    "agents": {
      "type": "array",
      "minItems": 27,
      "maxItems": 27,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["slug", "lane", "selected", "status", "dispatchAllowed", "model", "missingTools", "missingCapabilities", "actions", "artifactPaths", "authorization"],
        "properties": {
          "slug": { "type": "string", "minLength": 1 },
          "lane": { "type": "string", "minLength": 1 },
          "selected": { "type": "boolean" },
          "status": { "enum": ["not-selected", "ready", "degraded", "deferred", "skipped", "blocked"] },
          "dispatchAllowed": { "type": "boolean" },
          "model": {
            "type": "object",
            "additionalProperties": false,
            "required": ["schema", "policyId", "agent", "runtime", "status", "baselineConfig", "requiredOverrides", "requiredEnforcements", "adapterId", "adapterSnapshotSha256", "missingCapabilities", "reason"],
            "properties": {
              "schema": { "const": "argus/model-routing-preview@1" },
              "policyId": { "const": "argus/model-policy@1" },
              "agent": { "type": "string" },
              "runtime": { "enum": ["claude", "codex"] },
              "status": { "enum": ["ready", "blocked", "attestation-required"] },
              "baselineConfig": {
                "type": "object",
                "additionalProperties": false,
                "required": ["tier", "model", "effort", "maxTurns"],
                "properties": {
                  "tier": { "enum": ["frontier", "standard"] },
                  "model": { "enum": ["opus", "sonnet", "sol", "terra"] },
                  "effort": { "enum": ["medium", "max", "xhigh"] },
                  "maxTurns": { "type": "integer", "minimum": 1 }
                }
              },
              "requiredOverrides": { "type": "array", "items": { "enum": ["model", "effort"] }, "uniqueItems": true },
              "requiredEnforcements": { "type": "array", "minItems": 3, "items": { "enum": ["model", "effort", "maxTurns"] }, "uniqueItems": true },
              "adapterId": { "enum": ["claude-plugin-agent@1", "codex-custom-agent@1"] },
              "adapterSnapshotSha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
              "missingCapabilities": { "type": "array", "items": { "enum": ["model", "effort", "maxTurns"] }, "uniqueItems": true },
              "reason": { "type": "string" }
            }
          },
          "missingTools": { "$ref": "#/$defs/stringList" },
          "missingCapabilities": { "$ref": "#/$defs/stringList" },
          "actions": { "$ref": "#/$defs/stringList" },
          "artifactPaths": { "$ref": "#/$defs/stringList" },
          "authorization": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["action", "decision", "ruleId", "reason"],
              "properties": {
                "action": { "type": "string", "minLength": 1 },
                "decision": { "enum": ["allow", "deny"] },
                "ruleId": { "type": "string", "pattern": "^AUTH-[A-Z0-9-]+$" },
                "reason": { "type": "string", "minLength": 1 }
              }
            }
          }
        }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["selected", "ready", "degraded", "deferred", "skipped", "blocked", "dispatchable"],
      "properties": {
        "selected": { "type": "integer", "minimum": 0 },
        "ready": { "type": "integer", "minimum": 0 },
        "degraded": { "type": "integer", "minimum": 0 },
        "deferred": { "type": "integer", "minimum": 0 },
        "skipped": { "type": "integer", "minimum": 0 },
        "blocked": { "type": "integer", "minimum": 0 },
        "dispatchable": { "type": "integer", "minimum": 0 }
      }
    }
  },
  "$defs": {
    "stringList": {
      "type": "array",
      "items": { "type": "string" }
    },
    "check": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "mandatory", "status", "evidence"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "mandatory": { "type": "boolean" },
        "status": { "enum": ["pass", "fail", "degraded"] },
        "evidence": { "type": "string", "minLength": 1 }
      }
    }
  }
}
