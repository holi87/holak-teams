{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/holi87/holak-teams/argus/schemas/raci.schema.json",
  "title": "Argus RACI contract",
  "type": "object",
  "additionalProperties": false,
  "required": ["$schema", "schemaVersion", "defectLifecycle", "surfaceRoutes", "stateTransitions", "artifacts", "dualHome", "agents"],
  "properties": {
    "$schema": { "type": "string" },
    "schemaVersion": { "const": 1 },
    "defectLifecycle": { "type": "array", "minItems": 7, "items": { "$ref": "#/$defs/activity" } },
    "surfaceRoutes": { "type": "array", "minItems": 4, "items": { "$ref": "#/$defs/route" } },
    "stateTransitions": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/transition" } },
    "artifacts": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/artifact" } },
    "dualHome": { "type": "array", "items": { "type": "object", "additionalProperties": false, "required": ["slug", "workUnits", "rule"], "properties": { "slug": { "$ref": "#/$defs/slug" }, "workUnits": { "$ref": "#/$defs/strings" }, "rule": { "type": "string", "minLength": 1 } } } },
    "agents": { "type": "array", "minItems": 27, "maxItems": 27, "items": { "$ref": "#/$defs/agent" } }
  },
  "$defs": {
    "slug": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
    "strings": { "type": "array", "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
    "activity": { "type": "object", "additionalProperties": false, "required": ["activity", "accountable", "responsible"], "properties": { "activity": { "enum": ["discover", "validate", "deduplicate", "persist", "automate", "judge", "report"] }, "accountable": { "type": "string", "minLength": 1 }, "responsible": { "$ref": "#/$defs/strings" }, "consulted": { "$ref": "#/$defs/strings" }, "handoff": { "type": "string", "minLength": 1 } } },
    "route": { "type": "object", "additionalProperties": false, "required": ["surface", "discover", "baseline", "automate", "validate", "report"], "properties": { "surface": { "type": "string", "minLength": 1 }, "discover": { "type": "string", "minLength": 1 }, "baseline": { "type": "string", "minLength": 1 }, "automate": { "type": "string", "minLength": 1 }, "validate": { "$ref": "#/$defs/slug" }, "report": { "$ref": "#/$defs/slug" }, "gate": { "type": "string", "minLength": 1 } } },
    "transition": { "type": "object", "additionalProperties": false, "required": ["stateMachine", "from", "to", "accountable"], "properties": { "stateMachine": { "type": "string", "minLength": 1 }, "from": { "type": "string", "minLength": 1 }, "to": { "type": "string", "minLength": 1 }, "accountable": { "$ref": "#/$defs/slug" } } },
    "artifact": { "type": "object", "additionalProperties": false, "required": ["path", "accountable"], "properties": { "path": { "type": "string", "minLength": 1 }, "accountable": { "$ref": "#/$defs/slug" } } },
    "agent": { "type": "object", "additionalProperties": false, "required": ["slug", "role", "lane", "responsible", "accountableArtifacts", "persistence", "description"], "properties": { "slug": { "$ref": "#/$defs/slug" }, "role": { "type": "string", "minLength": 1 }, "lane": { "$ref": "#/$defs/slug" }, "responsible": { "$ref": "#/$defs/strings" }, "accountableArtifacts": { "$ref": "#/$defs/strings" }, "persistence": { "enum": ["candidate-file", "fragment-only", "owned-artifact", "owned-path-spec", "result-envelope", "tests-only"] }, "description": { "type": "string", "minLength": 1 } } }
  }
}
