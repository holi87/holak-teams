{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/holi87/holak-teams/argus/schemas/lane-plan-v1.schema.json",
  "title": "Argus lane plan legacy v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["$schema", "schemaVersion", "engagementId", "lane", "owner", "phase", "status", "dependsOn", "outputContracts", "transitions"],
  "properties": {
    "$schema": { "const": "argus/lane-plan@1" }, "schemaVersion": { "const": 1 }, "engagementId": { "type": "string", "minLength": 1 },
    "lane": { "$ref": "#/$defs/slug" }, "owner": { "$ref": "#/$defs/slug" },
    "phase": { "enum": ["discovery", "hunting", "automation", "verification", "reporting"] },
    "status": { "enum": ["planned", "running", "blocked", "completed"] },
    "dependsOn": { "type": "array", "uniqueItems": true, "items": { "$ref": "#/$defs/slug" } },
    "outputContracts": { "type": "array", "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
    "transitions": { "type": "array", "minItems": 1, "items": { "type": "object", "additionalProperties": false, "required": ["to", "at", "by"], "properties": { "to": { "enum": ["planned", "running", "blocked", "completed"] }, "at": { "type": "string", "format": "date-time" }, "by": { "$ref": "#/$defs/slug" } } } }
  },
  "$defs": { "slug": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" } }
}
