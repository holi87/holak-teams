{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://holak-teams.local/argus/role-manifest.schema.json",
  "title": "Argus canonical role source manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["$schema", "schemaVersion", "contracts", "roles"],
  "properties": {
    "$schema": { "type": "string" },
    "schemaVersion": { "const": 2 },
    "contracts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["modelPolicy", "ownership", "capabilities", "adapters"],
      "properties": {
        "modelPolicy": { "const": "argus/model-policy.json" },
        "ownership": { "const": "argus/raci.json" },
        "capabilities": { "const": "argus/capabilities/capability-matrix.json" },
        "adapters": { "const": "argus/runtime-adapters.json" }
      }
    },
    "roles": {
      "type": "array",
      "minItems": 27,
      "maxItems": 27,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["slug", "source", "color"],
        "properties": {
          "slug": { "type": "string", "pattern": "^[a-z]+(?:-[a-z]+)*$" },
          "source": { "type": "string", "pattern": "^[a-z]+(?:-[a-z]+)*\\.md$" },
          "color": { "enum": ["cyan", "red", "green", "yellow", "purple"] }
        }
      }
    }
  }
}
