{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/holi87/holak-teams/argus/schemas/redaction-patterns.schema.json",
  "title": "Argus redaction patterns",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "sensitiveKeys", "patterns"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "sensitiveKeys": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 }
    },
    "patterns": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "expression", "flags", "replacement"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
          "expression": { "type": "string", "minLength": 1 },
          "flags": { "type": "string", "pattern": "^[dgimsuvy]*$" },
          "replacement": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
