{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://holak-teams.local/argus/prompt-budgets.schema.json",
  "type": "object",
  "required": ["schemaVersion", "baseline", "budgets", "requiredPreloadedSkill", "optionalProfiles"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "baseline": {
      "type": "object",
      "required": ["claudeAgentWords", "capturedAt", "sourceCommit"],
      "properties": {
        "claudeAgentWords": { "type": "integer", "minimum": 1 },
        "capturedAt": { "type": "string", "format": "date" },
        "sourceCommit": { "type": "string", "pattern": "^[0-9a-f]{7,40}$" }
      },
      "additionalProperties": false
    },
    "budgets": {
      "type": "object",
      "required": ["maxClaudeAgentWords", "maxAgentWords", "maxDescriptionWords", "duplicateParagraphMinWords", "maxDuplicatedDoctrineInstances"],
      "properties": {
        "maxClaudeAgentWords": { "type": "integer", "minimum": 1 },
        "maxAgentWords": { "type": "integer", "minimum": 1 },
        "maxDescriptionWords": { "type": "integer", "minimum": 1 },
        "duplicateParagraphMinWords": { "type": "integer", "minimum": 1 },
        "maxDuplicatedDoctrineInstances": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "requiredPreloadedSkill": { "const": "qa-doctrine" },
    "optionalProfiles": {
      "type": "array",
      "contains": { "const": "competition-profile" }
    }
  },
  "additionalProperties": false
}
