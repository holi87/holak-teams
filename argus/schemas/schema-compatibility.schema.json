{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/holi87/holak-teams/argus/schemas/schema-compatibility.schema.json",
  "title": "Argus per-contract schema compatibility policy",
  "type": "object", "additionalProperties": false,
  "required": ["$schema", "schemaVersion", "current", "readCompatible", "migration", "contracts"],
  "properties": {
    "$schema": { "type": "string" }, "schemaVersion": { "const": 3 }, "current": { "const": 1 }, "readCompatible": { "const": [1] }, "migration": { "type": "string", "minLength": 1 },
    "contracts": {
      "type": "object", "additionalProperties": false,
      "required": ["lane-plan", "evidence-reference", "automation-status", "preflight-report"],
      "properties": {
        "lane-plan": { "$ref": "#/$defs/override" },
        "evidence-reference": { "$ref": "#/$defs/override" },
        "automation-status": { "$ref": "#/$defs/override" },
        "preflight-report": { "$ref": "#/$defs/override" }
      }
    }
  },
  "$defs": {
    "override": {
      "type": "object", "additionalProperties": false, "required": ["current", "readCompatible"],
      "properties": { "current": { "const": 2 }, "readCompatible": { "const": [2] } }
    }
  }
}
