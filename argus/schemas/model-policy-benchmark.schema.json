{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://holak-teams.local/argus/model-policy-benchmark.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "policyId", "decision", "recordedAt", "claudeCodeVersion", "syntheticOnly", "scenarios"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "policyId": { "const": "argus/model-policy@1" },
    "decision": { "const": "adopt-10-frontier-17-standard" },
    "recordedAt": { "type": "string", "format": "date-time" },
    "claudeCodeVersion": { "type": "string" },
    "syntheticOnly": { "const": true },
    "scenarios": {
      "type": "array",
      "minItems": 3,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "agent", "expectedTier", "classification", "qualityMarkers", "runs"],
        "properties": {
          "id": { "type": "string" },
          "agent": { "type": "string" },
          "expectedTier": { "enum": ["frontier", "standard"] },
          "classification": { "type": "string" },
          "qualityMarkers": { "type": "integer", "minimum": 1 },
          "runs": {
            "type": "array",
            "minItems": 2,
            "maxItems": 2,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["requestedModel", "runtimeModel", "qualityPassed", "qualityTotal", "latencyMs", "inputTokens", "outputTokens", "totalTokens", "reportedCostUsd", "outputSha256"],
              "properties": {
                "requestedModel": { "enum": ["opus", "sonnet"] },
                "runtimeModel": { "type": "string" },
                "qualityPassed": { "type": "integer", "minimum": 0 },
                "qualityTotal": { "type": "integer", "minimum": 1 },
                "latencyMs": { "type": "number", "minimum": 0 },
                "inputTokens": { "type": "number", "minimum": 1 },
                "outputTokens": { "type": "number", "minimum": 1 },
                "totalTokens": { "type": "number", "minimum": 1 },
                "reportedCostUsd": { "type": "number", "minimum": 0 },
                "outputSha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
              }
            }
          }
        }
      }
    }
  }
}
