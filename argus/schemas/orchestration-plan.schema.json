{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/holi87/holak-teams/argus/schemas/orchestration-plan.schema.json",
  "title": "Argus orchestration plan",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "schemaVersion",
    "capabilityMatrix",
    "raci",
    "dependencyPolicy",
    "modeCounts",
    "waves",
    "roles"
  ],
  "properties": {
    "$schema": { "const": "argus/orchestration-plan@1" },
    "schemaVersion": { "const": 1 },
    "capabilityMatrix": { "const": "capabilities/capability-matrix.json" },
    "raci": { "const": "references/raci.json" },
    "dependencyPolicy": { "const": "selected-dispatchable-predecessors" },
    "modeCounts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["A", "B", "C", "D"],
      "properties": {
        "A": { "type": "integer", "minimum": 0, "maximum": 27 },
        "B": { "type": "integer", "minimum": 0, "maximum": 27 },
        "C": { "type": "integer", "minimum": 0, "maximum": 27 },
        "D": { "type": "integer", "minimum": 0, "maximum": 27 }
      }
    },
    "waves": {
      "type": "array",
      "minItems": 5,
      "uniqueItems": true,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "barrierAfter"],
        "properties": {
          "id": { "enum": ["W0", "W1", "W2", "W3", "W4"] },
          "barrierAfter": { "type": "boolean" }
        }
      }
    },
    "roles": {
      "type": "array",
      "minItems": 27,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/role" }
    }
  },
  "$defs": {
    "role": {
      "type": "object",
      "additionalProperties": false,
      "required": ["slug", "kind", "dispatch", "wave", "modes", "gates", "dependsOn"],
      "properties": {
        "slug": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
        "kind": { "enum": ["controller", "specialist"] },
        "dispatch": { "type": "boolean" },
        "wave": { "enum": ["controller", "W0", "W1", "W2", "W3", "W4"] },
        "modes": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "enum": ["A", "B", "C", "D"] }
        },
        "gates": { "$ref": "#/$defs/stringList" },
        "dependsOn": { "$ref": "#/$defs/stringList" }
      }
    },
    "stringList": {
      "type": "array",
      "uniqueItems": true,
      "items": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" }
    }
  }
}
