{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/holi87/holak-teams/argus/schemas/bug-ledger.schema.json",
  "title": "Argus confirmed defect ledger v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["$schema", "schemaVersion", "engagementId", "bugs"],
  "properties": {
    "$schema": { "const": "argus/bug-ledger@1" },
    "schemaVersion": { "const": 1 },
    "engagementId": { "type": "string", "minLength": 1 },
    "bugs": { "type": "array", "items": { "$ref": "#/$defs/bug" } }
  },
  "$defs": {
    "bug": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "origin", "title", "severity", "priority", "lane", "oracleId", "status", "wired", "testId", "evidenceIds"],
      "properties": {
        "id": { "type": "string", "pattern": "^BUG-[0-9]{4}$" },
        "origin": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "pattern": "^[A-Z]{3}-[0-9]{3,4}$" } },
        "title": { "type": "string", "minLength": 1 },
        "severity": { "enum": ["Blocker", "Critical", "Major", "Minor", "Trivial"] },
        "priority": { "enum": ["P1", "P2", "P3", "P4"] },
        "lane": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
        "oracleId": { "type": "string", "minLength": 1 },
        "status": { "enum": ["confirmed", "suspected", "needs-oracle"] },
        "wired": { "type": "boolean" },
        "testId": { "type": ["string", "null"], "pattern": "^(?:TST|REG)-[0-9]{4}$" },
        "evidenceIds": { "type": "array", "uniqueItems": true, "items": { "type": "string", "pattern": "^EVD-[0-9]{4}$" } }
      },
      "allOf": [
        { "if": { "properties": { "wired": { "const": true } }, "required": ["wired"] }, "then": { "properties": { "testId": { "type": "string", "pattern": "^(?:TST|REG)-[0-9]{4}$" } } } }
      ]
    }
  }
}
