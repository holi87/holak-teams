{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://holak-teams.local/argus/model-escalation-request.schema.json",
  "title": "Argus worker model escalation request",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "kind", "engagementId", "dispatchId", "attempt", "agent", "signal", "checkpointRef", "resumable"],
  "properties": {
    "schema": { "const": "argus/model-escalation-request@1" },
    "kind": { "const": "MODEL_ESCALATION_REQUEST" },
    "engagementId": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$" },
    "dispatchId": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$" },
    "attempt": { "type": "integer", "minimum": 2 },
    "agent": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
    "signal": {
      "enum": ["ambiguity", "safety", "cross-lane", "conflicting-evidence", "oracle-ambiguity", "schema-validation-failure", "repeated-failure", "turn-limit"]
    },
    "checkpointRef": { "type": "string", "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))[A-Za-z0-9._/-]+\\.json$" },
    "resumable": { "const": true }
  }
}
