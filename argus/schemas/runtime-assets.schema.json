{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/holi87/holak-teams/argus/schemas/runtime-assets.schema.json",
  "title": "Argus runtime asset source manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "budgets", "templateCompositions", "assets", "buildOnly", "maintainerOnly", "forbiddenPromptReferences"],
  "properties": {
    "$schema": { "type": "string" },
    "schemaVersion": { "const": 1 },
    "generated": { "type": "boolean" },
    "generatedFrom": { "type": "string" },
    "budgets": {
      "type": "object",
      "additionalProperties": false,
      "required": ["generatedAssetsBytes", "installedPluginBytes"],
      "properties": {
        "generatedAssetsBytes": { "type": "integer", "minimum": 1 },
        "installedPluginBytes": { "type": "integer", "minimum": 1 }
      }
    },
    "templateCompositions": {
      "type": "object",
      "additionalProperties": false,
      "required": ["typescript", "java", "python"],
      "properties": {
        "typescript": { "$ref": "#/$defs/templateComposition" },
        "java": { "$ref": "#/$defs/templateComposition" },
        "python": { "$ref": "#/$defs/templateComposition" }
      }
    },
    "assets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "kind", "source", "destination"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
          "kind": { "enum": ["capabilities", "policies", "reference", "runtime", "schemas", "skill", "template"] },
          "source": { "type": "string", "pattern": "^argus/" },
          "destination": { "type": "string", "pattern": "^(capabilities|lib|policies|references|schemas|skills|templates)(/|$)" },
          "files": { "type": "integer", "minimum": 1 },
          "bytes": { "type": "integer", "minimum": 1 },
          "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
        }
      }
    },
    "buildOnly": { "$ref": "#/$defs/excludedSources" },
    "maintainerOnly": {
      "$ref": "#/$defs/excludedSources"
    },
    "forbiddenPromptReferences": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    }
  },
  "$defs": {
    "excludedSources": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["source", "reason"],
        "properties": {
          "source": { "type": "string", "pattern": "^argus/" },
          "reason": { "type": "string", "minLength": 1 }
        }
      }
    },
    "templateComposition": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source", "commonAsset", "runtimeAsset"],
      "properties": {
        "source": { "type": "string", "pattern": "^argus/framework-template(?:-(?:java|python))?$" },
        "commonAsset": { "const": "common-template" },
        "runtimeAsset": { "type": "string", "pattern": "^(?:typescript|java|python)-template$" }
      }
    }
  }
}
