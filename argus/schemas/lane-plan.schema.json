{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/holi87/holak-teams/argus/schemas/lane-plan.schema.json",
  "title": "Argus lane plan collection v2",
  "type": "object", "additionalProperties": false,
  "required": ["$schema", "schemaVersion", "engagementId", "lanes"],
  "properties": {
    "$schema": { "const": "argus/lane-plan@2" }, "schemaVersion": { "const": 2 }, "engagementId": { "type": "string", "minLength": 1 },
    "lanes": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "$ref": "#/$defs/lane" } }
  },
  "$defs": {
    "slug": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
    "lane": {
      "type": "object", "additionalProperties": false,
      "required": ["lane", "owner", "phase", "status", "dependsOn", "outputContracts", "transitions"],
      "properties": {
        "lane": { "$ref": "#/$defs/slug" }, "owner": { "$ref": "#/$defs/slug" },
        "phase": { "enum": ["discovery", "hunting", "automation", "verification", "reporting"] },
        "status": { "enum": ["planned", "running", "blocked", "completed"] },
        "dependsOn": { "type": "array", "uniqueItems": true, "items": { "$ref": "#/$defs/slug" } },
        "outputContracts": { "type": "array", "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
        "transitions": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/transition" } }
      }
    },
    "transition": {
      "type": "object", "additionalProperties": false, "required": ["to", "at", "by"],
      "properties": { "to": { "enum": ["planned", "running", "blocked", "completed"] }, "at": { "type": "string", "format": "date-time" }, "by": { "$ref": "#/$defs/slug" } }
    }
  }
}
