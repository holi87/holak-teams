{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/holi87/holak-teams/argus/schemas/surface-inventory.schema.json",
  "title": "Argus target surface inventory v1",
  "type": "object", "additionalProperties": false,
  "required": ["$schema", "schemaVersion", "engagementId", "owner", "discovery", "items"],
  "properties": {
    "$schema": { "const": "argus/surface-inventory@1" }, "schemaVersion": { "const": 1 }, "engagementId": { "type": "string", "minLength": 1 }, "owner": { "const": "kalchas" },
    "discovery": { "type": "object", "additionalProperties": false, "required": ["candidates", "characterized"], "properties": { "candidates": { "type": "integer", "minimum": 1 }, "characterized": { "type": "integer", "minimum": 0 } } },
    "items": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/item" } }
  },
  "$defs": { "item": {
    "type": "object", "additionalProperties": false,
    "required": ["id", "surfaceType", "lane", "risk", "riskWeight", "riskBasis", "accessibility", "denominators", "discoveryEvidenceIds"],
    "properties": {
      "id": { "type": "string", "pattern": "^SRF-[A-Z0-9][A-Z0-9-]*$" }, "surfaceType": { "enum": ["ui", "api", "event", "data"] }, "lane": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
      "risk": { "enum": ["critical", "high", "medium", "low"] }, "riskWeight": { "type": "integer", "minimum": 1, "maximum": 5 }, "riskBasis": { "type": "string", "minLength": 1 },
      "accessibility": { "enum": ["testable", "inaccessible", "untestable"] }, "scopeReason": { "type": "string", "minLength": 1 },
      "techniqueScopes": { "type": "array", "uniqueItems": true, "items": { "type": "string", "pattern": "^(atalanta|proteus|metis):[a-z0-9]+(?:-[a-z0-9]+)*$" } },
      "denominators": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "enum": ["route", "operation", "schema", "role", "state", "device", "browser", "risk-category"] } },
      "discoveryEvidenceIds": { "type": "array", "uniqueItems": true, "items": { "type": "string", "pattern": "^EVD-[0-9]{4}$" } }
    },
    "allOf": [{ "if": { "properties": { "accessibility": { "enum": ["inaccessible", "untestable"] } } }, "then": { "required": ["scopeReason"] } }]
  } }
}
