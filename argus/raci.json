{
  "$schema": "./schemas/raci.schema.json",
  "schemaVersion": 1,
  "defectLifecycle": [
    { "activity": "discover", "accountable": "odysseus", "responsible": ["surface-owner"], "handoff": "Resolve the responsible specialist from surfaceRoutes, then submit an immutable candidate with evidence to Minos through Odysseus." },
    { "activity": "validate", "accountable": "minos", "responsible": ["minos"], "consulted": ["originating-specialist"] },
    { "activity": "deduplicate", "accountable": "minos", "responsible": ["minos"] },
    { "activity": "persist", "accountable": "minos", "responsible": ["minos"], "consulted": ["originating-specialist"] },
    { "activity": "automate", "accountable": "atlas", "responsible": ["surface-automation-owner"], "consulted": ["minos"] },
    { "activity": "judge", "accountable": "aristarchus", "responsible": ["aristarchus"], "consulted": ["asklepios"] },
    { "activity": "report", "accountable": "kleio", "responsible": ["kleio"], "consulted": ["minos", "atlas", "metis"] }
  ],
  "surfaceRoutes": [
    { "surface": "ui-functional", "discover": "orion", "baseline": "penelope", "automate": "daidalos", "validate": "minos", "report": "kleio" },
    { "surface": "ui-presentation", "discover": "lynceus", "baseline": "penelope", "automate": "daidalos", "validate": "minos", "report": "kleio" },
    { "surface": "accessibility", "discover": "antigone", "baseline": "penelope", "automate": "daidalos", "validate": "minos", "report": "kleio" },
    { "surface": "api-rest", "discover": "atalanta", "baseline": "theseus", "automate": "talos", "validate": "minos", "report": "kleio" },
    { "surface": "event-protocol", "discover": "proteus", "baseline": "pistis", "automate": "talos", "validate": "minos", "report": "kleio" },
    { "surface": "journey-ui", "discover": "ariadne", "baseline": "penelope", "automate": "daidalos", "validate": "minos", "report": "kleio" },
    { "surface": "journey-api", "discover": "ariadne", "baseline": "theseus", "automate": "talos", "validate": "minos", "report": "kleio" },
    { "surface": "performance", "discover": "hermes", "baseline": "metis", "automate": "nike", "validate": "minos", "report": "kleio" },
    { "surface": "resilience", "discover": "tyche", "baseline": "metis", "automate": "nike", "validate": "minos", "report": "kleio" },
    { "surface": "security", "discover": "perseus", "baseline": "metis", "automate": "aegis", "validate": "minos", "report": "kleio" },
    { "surface": "data-direct", "discover": "charon", "baseline": "kalchas", "automate": "mnemosyne", "validate": "minos", "report": "kleio", "gate": "db-access" },
    { "surface": "data-public-api", "discover": "atalanta", "baseline": "theseus", "automate": "talos", "validate": "minos", "report": "kleio" },
    { "surface": "source", "discover": "tiresias", "baseline": "kalchas", "automate": "atlas", "validate": "minos", "report": "kleio", "gate": "source-access" },
    { "surface": "existing-suite", "discover": "asklepios", "baseline": "asklepios", "automate": "asklepios", "validate": "aristarchus", "report": "kleio", "gate": "existing-suite" }
  ],
  "stateTransitions": [
    { "stateMachine": "engagement", "from": "preflight", "to": "discovery", "accountable": "odysseus" },
    { "stateMachine": "engagement", "from": "discovery", "to": "hunting", "accountable": "odysseus" },
    { "stateMachine": "engagement", "from": "hunting", "to": "automation", "accountable": "odysseus" },
    { "stateMachine": "engagement", "from": "automation", "to": "verification", "accountable": "odysseus" },
    { "stateMachine": "engagement", "from": "verification", "to": "reporting", "accountable": "odysseus" },
    { "stateMachine": "engagement", "from": "reporting", "to": "complete", "accountable": "odysseus" },
    { "stateMachine": "lane-plan", "from": "planned", "to": "running", "accountable": "odysseus" },
    { "stateMachine": "lane-plan", "from": "planned", "to": "blocked", "accountable": "odysseus" },
    { "stateMachine": "lane-plan", "from": "running", "to": "blocked", "accountable": "odysseus" },
    { "stateMachine": "lane-plan", "from": "running", "to": "completed", "accountable": "odysseus" },
    { "stateMachine": "defect", "from": "candidate", "to": "needs-oracle", "accountable": "minos" },
    { "stateMachine": "defect", "from": "needs-oracle", "to": "suspected", "accountable": "minos" },
    { "stateMachine": "defect", "from": "suspected", "to": "confirmed", "accountable": "minos" },
    { "stateMachine": "defect", "from": "confirmed", "to": "automated", "accountable": "atlas" },
    { "stateMachine": "defect", "from": "automated", "to": "fixed", "accountable": "minos" },
    { "stateMachine": "defect", "from": "fixed", "to": "closed", "accountable": "minos" },
    { "stateMachine": "runner-lifecycle", "from": "discovered", "to": "reproduced", "accountable": "minos" },
    { "stateMachine": "runner-lifecycle", "from": "reproduced", "to": "automated", "accountable": "atlas" },
    { "stateMachine": "runner-lifecycle", "from": "automated", "to": "fixed", "accountable": "minos" },
    { "stateMachine": "runner-lifecycle", "from": "fixed", "to": "closed", "accountable": "minos" },
    { "stateMachine": "evidence", "from": "collected", "to": "immutable", "accountable": "kleio" },
    { "stateMachine": "coverage-observations", "from": "collected", "to": "merged", "accountable": "atlas" },
    { "stateMachine": "coverage-result", "from": "inputs-ready", "to": "calculated", "accountable": "kleio" },
    { "stateMachine": "automation", "from": "planned", "to": "implemented", "accountable": "atlas" },
    { "stateMachine": "automation", "from": "implemented", "to": "passed", "accountable": "atlas" },
    { "stateMachine": "automation", "from": "implemented", "to": "failed", "accountable": "atlas" },
    { "stateMachine": "automation", "from": "implemented", "to": "skipped", "accountable": "atlas" },
    { "stateMachine": "final-summary", "from": "reporting", "to": "completed", "accountable": "kleio" },
    { "stateMachine": "final-summary", "from": "reporting", "to": "degraded", "accountable": "kleio" },
    { "stateMachine": "final-summary", "from": "reporting", "to": "blocked", "accountable": "kleio" }
  ],
  "artifacts": [
    { "path": "README.md", "accountable": "kleio" },
    { "path": "run-tests.sh", "accountable": "atlas" },
    { "path": "solution/ARCHITECTURE.md", "accountable": "atlas" },
    { "path": "solution/BUG-LEDGER.md", "accountable": "minos" },
    { "path": "solution/bug-ledger.json", "accountable": "minos" },
    { "path": "solution/lane-plan.json", "accountable": "odysseus" },
    { "path": "solution/evidence-reference.json", "accountable": "kleio" },
    { "path": "solution/automation-status.json", "accountable": "atlas" },
    { "path": "solution/surface-inventory.json", "accountable": "kalchas" },
    { "path": "solution/coverage-observations.json", "accountable": "atlas" },
    { "path": "solution/coverage-result.json", "accountable": "kleio" },
    { "path": "solution/final-summary.json", "accountable": "kleio" },
    { "path": "solution/FINDINGS.md", "accountable": "kleio" },
    { "path": "solution/IMPLEMENTATION-REPORT.md", "accountable": "kleio" },
    { "path": "solution/ORACLES.md", "accountable": "metis" },
    { "path": "solution/PERF-REPORT.md", "accountable": "hermes" },
    { "path": "solution/RESILIENCE-REPORT.md", "accountable": "tyche" },
    { "path": "solution/STATE_MODEL.md", "accountable": "ariadne" },
    { "path": "solution/TEST-HEALTH.md", "accountable": "asklepios" },
    { "path": "solution/TEST-STRATEGY.md", "accountable": "metis" },
    { "path": "solution/TRACEABILITY.md", "accountable": "kleio" },
    { "path": "solution/WHITEBOX-LEADS.md", "accountable": "minos" }
  ],
  "dualHome": [
    { "slug": "nike", "workUnits": ["performance", "resilience"], "rule": "Dispatch separate work units; resilience automation requires the exclusive fault window and cannot overlap performance load." },
    { "slug": "ariadne", "workUnits": ["ui-journey", "api-journey"], "rule": "Own the cross-feature business invariant; route pure presentation to Orion/Lynceus and pure endpoint contract behavior to Atalanta." },
    { "slug": "tiresias", "workUnits": ["source-lead", "source-candidate"], "rule": "Return immutable TIR candidates and leads; Minos persists canonical bug files and WHITEBOX-LEADS." }
  ],
  "agents": [
    { "slug": "aegis", "role": "Security automation engineer", "lane": "security-automation", "responsible": ["automate confirmed security defects", "maintain tests/security"], "accountableArtifacts": [], "persistence": "tests-only", "description": "Security automation engineer. Owns tests/security/ and automates Minos-confirmed security defects; does not discover, validate, deduplicate, or persist canonical defects." },
    { "slug": "antigone", "role": "Accessibility hunter", "lane": "accessibility-hunt", "responsible": ["discover accessibility candidates", "submit ANG evidence"], "accountableArtifacts": [], "persistence": "candidate-file", "description": "Accessibility hunter. Discovers WCAG candidates and persists ANG candidate reports; Minos validates, deduplicates, and promotes canonical defects, while Daidalos owns automation." },
    { "slug": "ariadne", "role": "Journey and lifecycle hunter", "lane": "journey-hunt", "responsible": ["discover cross-feature journey candidates", "maintain state model fragments"], "accountableArtifacts": ["solution/STATE_MODEL.md"], "persistence": "candidate-file", "description": "Journey hunter. Owns cross-feature business invariants and STATE_MODEL; persists ARI candidates, while Minos validates and Talos or Daidalos automates by the failing surface." },
    { "slug": "aristarchus", "role": "Automation quality judge", "lane": "automation-review", "responsible": ["judge automation quality", "issue blocker or warning verdict"], "accountableArtifacts": [], "persistence": "result-envelope", "description": "Read-only automation judge. Runs after implementation, evaluates determinism and oracle honesty, and returns BLOCKER/WARNING; does not validate product defects or edit tests." },
    { "slug": "asklepios", "role": "Test-suite sanitation specialist", "lane": "suite-sanitation", "responsible": ["sanitize existing suite", "document test health", "submit product candidates"], "accountableArtifacts": ["solution/TEST-HEALTH.md"], "persistence": "candidate-file", "description": "Existing-suite sanitation specialist. Owns TEST-HEALTH and approved test repairs, persists ASK product candidates for Minos, and leaves final automation judgment to Aristarchus." },
    { "slug": "atalanta", "role": "REST API and public-data hunter", "lane": "api-hunt", "responsible": ["discover REST API candidates", "cover public-data integrity when DB access is absent"], "accountableArtifacts": [], "persistence": "candidate-file", "description": "REST API hunter. Persists ATA candidates for API and public-data behavior; non-REST events belong to Proteus, canonical validation to Minos, and automation to Talos." },
    { "slug": "atlas", "role": "Automation architect", "lane": "automation-architecture", "responsible": ["own shared harness", "own runner", "merge automation status and coverage observations"], "accountableArtifacts": ["run-tests.sh", "solution/ARCHITECTURE.md", "solution/automation-status.json", "solution/coverage-observations.json"], "persistence": "owned-artifact", "description": "Automation architect. Owns the shared harness, ten oracle helpers, run-tests.sh, automation status, and coverage observations; delegates lane tests and never validates product defects." },
    { "slug": "charon", "role": "Direct-database hunter", "lane": "database-hunt", "responsible": ["discover direct-database candidates"], "accountableArtifacts": [], "persistence": "candidate-file", "description": "Gated direct-database hunter. Persists CHA candidates from read-only DB analysis when db-access is ready; public-data behavior belongs to Atalanta and canonical validation to Minos." },
    { "slug": "daidalos", "role": "UI and accessibility automation engineer", "lane": "ui-automation", "responsible": ["automate UI baseline", "automate confirmed UI and accessibility defects"], "accountableArtifacts": [], "persistence": "tests-only", "description": "UI automation engineer. Owns tests/ui/, implements Penelope baselines, and automates Minos-confirmed ORI, LYN, and ANG defects; does not hunt or validate them." },
    { "slug": "hermes", "role": "Performance hunter", "lane": "performance-hunt", "responsible": ["discover performance candidates", "characterize performance surface"], "accountableArtifacts": ["solution/PERF-REPORT.md"], "persistence": "candidate-file", "description": "Performance hunter. Owns PERF-REPORT and persists HER candidates from structural and characterized latency evidence; Minos validates and Nike automates." },
    { "slug": "kalchas", "role": "System reconnaissance analyst", "lane": "recon", "responsible": ["map target surfaces", "gate capabilities", "own surface inventory"], "accountableArtifacts": ["solution/surface-inventory.json"], "persistence": "owned-artifact", "description": "Recon analyst. Maps target surfaces, roles, states, and access gates and owns surface-inventory; does not hunt, validate, or persist defects." },
    { "slug": "kleio", "role": "Final reporter", "lane": "reporting", "responsible": ["merge evidence references", "calculate coverage result", "publish final report"], "accountableArtifacts": ["README.md", "solution/evidence-reference.json", "solution/coverage-result.json", "solution/final-summary.json", "solution/FINDINGS.md", "solution/IMPLEMENTATION-REPORT.md", "solution/TRACEABILITY.md"], "persistence": "owned-artifact", "description": "Final reporter. Owns evidence, coverage result, final summary, README, findings, implementation report, and traceability; reports Minos and Atlas outcomes without re-validating them." },
    { "slug": "lynceus", "role": "UI presentation hunter", "lane": "presentation-hunt", "responsible": ["discover presentation and locale candidates"], "accountableArtifacts": [], "persistence": "candidate-file", "description": "UI presentation hunter. Persists LYN candidates for layout, format, locale, and rendering; functional behavior belongs to Orion, accessibility to Antigone, and validation to Minos." },
    { "slug": "metis", "role": "Test strategist", "lane": "strategy", "responsible": ["own risk strategy", "own behavioral oracles"], "accountableArtifacts": ["solution/TEST-STRATEGY.md", "solution/ORACLES.md"], "persistence": "owned-artifact", "description": "Test strategist. Owns TEST-STRATEGY and ORACLES from Kalchas inventory; plans risk-weighted coverage but does not execute tests, validate defects, or report final outcomes." },
    { "slug": "minos", "role": "Defect authority and triage lead", "lane": "triage", "responsible": ["validate candidates", "deduplicate defects", "persist canonical defects", "close defect lifecycle"], "accountableArtifacts": ["solution/BUG-LEDGER.md", "solution/bug-ledger.json", "solution/WHITEBOX-LEADS.md"], "persistence": "owned-artifact", "description": "Defect authority. Independently validates, deduplicates, ranks, and persists canonical bugs, BUG-LEDGER, and WHITEBOX-LEADS; does not discover candidates or implement regression tests." },
    { "slug": "mnemosyne", "role": "Database automation engineer", "lane": "database-automation", "responsible": ["automate confirmed database defects", "maintain tests/db"], "accountableArtifacts": [], "persistence": "tests-only", "description": "Gated database automation engineer. Owns tests/db/ for confirmed DB invariants when db-access is ready; Charon discovers and Minos validates defects." },
    { "slug": "nike", "role": "Performance and resilience automation engineer", "lane": "performance-resilience-automation", "responsible": ["automate confirmed performance defects", "automate confirmed resilience defects"], "accountableArtifacts": [], "persistence": "tests-only", "description": "Performance and resilience automation engineer. Owns tests/perf/ and tests/resilience/ as separate scheduled work units; fault automation requires the exclusive fault window." },
    { "slug": "odysseus", "role": "Main-thread orchestration policy", "lane": "orchestration", "responsible": ["select mode", "route from RACI", "advance barriers", "own lane plan"], "accountableArtifacts": ["solution/lane-plan.json"], "persistence": "owned-artifact", "description": "Main-thread orchestration policy. Selects mode, routes work from the RACI contract, advances barriers, and owns lane-plan when Agent is available; otherwise returns an explicit preflight error." },
    { "slug": "orion", "role": "Functional UI hunter", "lane": "ui-hunt", "responsible": ["discover functional UI candidates"], "accountableArtifacts": [], "persistence": "candidate-file", "description": "Functional UI hunter. Persists ORI candidates for behavior, forms, and client state; presentation belongs to Lynceus, accessibility to Antigone, and validation to Minos." },
    { "slug": "penelope", "role": "UI baseline path analyst", "lane": "ui-path-analysis", "responsible": ["define UI baseline paths", "submit incidental leads"], "accountableArtifacts": [], "persistence": "owned-path-spec", "description": "UI baseline analyst. Owns solution/paths/ui-* specifications and submits incidental PEN leads; Orion confirms functional defects and Daidalos automates the baseline." },
    { "slug": "perseus", "role": "Security hunter", "lane": "security-hunt", "responsible": ["discover security candidates"], "accountableArtifacts": [], "persistence": "candidate-file", "description": "Security hunter. Persists PER candidates from authorized STRIDE and OWASP probes; Minos validates and Aegis automates canonical security defects." },
    { "slug": "pistis", "role": "Consumer contract baseline analyst", "lane": "contract-analysis", "responsible": ["define cross-service contract baseline"], "accountableArtifacts": [], "persistence": "owned-path-spec", "description": "Gated consumer-contract analyst. Owns contract path specifications for confirmed multi-service targets; Proteus or Atalanta discovers defects, Minos validates, and Talos automates." },
    { "slug": "proteus", "role": "Event and non-REST protocol hunter", "lane": "multi-protocol-hunt", "responsible": ["discover event and non-REST candidates"], "accountableArtifacts": [], "persistence": "candidate-file", "description": "Event and non-REST hunter. Persists PRO candidates for GraphQL, gRPC, WebSocket, SSE, messaging, and webhooks; REST belongs to Atalanta and validation to Minos." },
    { "slug": "talos", "role": "API and event automation engineer", "lane": "api-automation", "responsible": ["automate API baseline", "automate confirmed API and event defects"], "accountableArtifacts": [], "persistence": "tests-only", "description": "API automation engineer. Owns tests/api/, implements Theseus and Pistis baselines, and automates Minos-confirmed ATA and PRO defects using Atlas's shared harness." },
    { "slug": "theseus", "role": "REST API baseline path analyst", "lane": "api-path-analysis", "responsible": ["define REST API baseline paths"], "accountableArtifacts": [], "persistence": "owned-path-spec", "description": "REST API baseline analyst. Owns solution/paths/api-* specifications from the discovered contract; Atalanta discovers defects, Minos validates, and Talos automates." },
    { "slug": "tiresias", "role": "White-box source analyst", "lane": "source-analysis", "responsible": ["discover source-derived candidates", "submit source leads"], "accountableArtifacts": [], "persistence": "fragment-only", "description": "Gated read-only source analyst. Returns TIR candidates and source leads as immutable fragments; Minos validates and persists canonical bug files and WHITEBOX-LEADS." },
    { "slug": "tyche", "role": "Resilience hunter", "lane": "resilience-hunt", "responsible": ["discover resilience candidates", "own resilience report"], "accountableArtifacts": ["solution/RESILIENCE-REPORT.md"], "persistence": "candidate-file", "description": "Authorized resilience hunter. Owns RESILIENCE-REPORT and persists TYC candidates from reversible fault evidence; Minos validates and Nike automates under the exclusive fault window." }
  ]
}
