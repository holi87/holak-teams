  requireOptions(options, ['manifest', 'lane', 'canonical', 'id', 'input'], 'engagement fragment');
  const { manifest: engagement } = loadEngagement(options);
  const content = readTextInput(options.input);
  console.log(JSON.stringify(writeFragment(engagement, options.lane, leaseToken(options), options.canonical, options.id, content)));
  return 0;
}

