function guardCommand(args) {
  if (args.length > 0) fail('usage: argus-assets guard');
  const raw = readFileSync(0, 'utf8');
  let payload;
  try { payload = JSON.parse(raw); }
  catch { return denyHook('GUARD-MANIFEST-INVALID', 'PreToolUse payload is not valid JSON'); }
  const cwd = resolve(payload.cwd ?? process.cwd());
  const manifestPath = locateEngagementManifest(cwd, process.env.ARGUS_ENGAGEMENT_MANIFEST);
  if (!manifestPath) return 0;
  let engagement;
  try { engagement = JSON.parse(readFileSync(manifestPath, 'utf8')); }
  catch { return denyHook('GUARD-MANIFEST-INVALID', 'engagement manifest is not valid JSON'); }
  const errors = validateEngagementManifest(engagement);
  if (errors.length > 0) return denyHook('GUARD-MANIFEST-INVALID', errors.join('; '));
  const decision = evaluateWriteGuard({
    manifest: engagement,
    manifestPath,
    payload,
    cwd,
    bypassToken: process.env.ARGUS_IMMUTABILITY_BYPASS_TOKEN,
  });
  if (decision.decision === 'deny' || decision.ruleId === 'GUARD-EXPLICIT-BYPASS') {
    const patterns = readJson(REDACTION_PATTERNS_PATH);
    const event = redactValue(buildGuardAudit({ manifest: engagement, payload, decision, timestamp: new Date().toISOString() }), patterns).value;
    const auditPath = resolve(engagement.artifactRoot, engagement.writePolicy.auditPath);
    if (!safePhysicalPath(engagement.artifactRoot, auditPath)) return denyHook('GUARD-MANIFEST-INVALID', 'guard audit path escapes its physical artifact root or crosses a symbolic link');
    mkdirSync(dirname(auditPath), { recursive: true });
    atomicPrivateAppend(auditPath, `${JSON.stringify(event)}\n`);
  }
  if (decision.decision === 'deny') return denyHook(decision.ruleId, `${decision.reason}; audit=${engagement.writePolicy.auditPath}`);
  return 0;
}

function denyHook(ruleId, reason) {
  console.log(JSON.stringify({
    hookSpecificOutput: {
      hookEventName: 'PreToolUse',
      permissionDecision: 'deny',
      permissionDecisionReason: `${ruleId}: ${String(reason).replace(/[\r\n]+/g, ' ')}`,
    },
  }));
  return 0;
}

function initializeAuthorization(args) {
  const options = parseNamedOptions(args, new Set(['--target', '--environment', '--output', '--engagement-id']));
  if (!options.target) fail('authorization init requires --target');
  const environment = options.environment ?? 'unknown';
  if (!['unknown', 'development', 'test', 'staging', 'production'].includes(environment)) {
    fail('authorization init --environment must be unknown, development, test, staging, or production');
  }
  const output = resolve(options.output ?? 'ai_agents_internal/authorization.json');
  if (!safePhysicalPath(process.cwd(), output)) fail('authorization manifest path escapes the physical working root or crosses a symbolic link');
  if (existsSync(output)) fail(`refusing to overwrite existing authorization manifest: ${output}`);
  const template = readJson(AUTHORIZATION_TEMPLATE_PATH);
  const targetPath = statSafe(resolve(options.target)) ? resolve(options.target) : null;
  const targetIdentifier = targetPath ?? (/^https?:\/\//i.test(options.target) ? new URL(options.target).toString() : options.target);
  const authorization = createDefaultAuthorization({
    template,
    target: targetIdentifier,
    environment,
    engagementId: options.engagementId,
  });
  const errors = validateAuthorizationManifest(authorization);
  if (errors.length > 0) fail(`generated authorization manifest is invalid: ${errors.join('; ')}`);
  mkdirSync(dirname(output), { recursive: true });
  writeFileSync(output, `${JSON.stringify(authorization, null, 2)}\n`, { mode: 0o600 });
  chmodSync(output, 0o600);
  console.log(`AUTHORIZATION  initialized default-deny manifest=${output} sha256=${manifestSha256(authorization)}`);
  return 0;
}

function checkAuthorization(args) {
  const options = parseNamedOptions(args, new Set([
    '--manifest', '--lane', '--action', '--target', '--source-trust', '--account',
    '--namespace', '--mutation', '--classification', '--rate', '--concurrency',
    '--total-requests', '--duration', '--resource', '--at', '--binary-reviewed',
  ]));
  for (const required of ['manifest', 'lane', 'action', 'target', 'sourceTrust']) {
    if (!options[required]) fail(`authorization check requires --${camelToKebab(required)}`);
  }
  const manifestPath = resolve(options.manifest);
  if (!statSafe(manifestPath)?.isFile() || lstatSync(manifestPath).isSymbolicLink()) fail('authorization manifest must be a real file');
  const authorization = readSecureJson(manifestPath, 'authorization manifest');
  const patterns = readJson(REDACTION_PATTERNS_PATH);
  const patternErrors = validateRedactionPatterns(patterns);
  if (patternErrors.length > 0) fail(`packaged redaction patterns are invalid: ${patternErrors.join('; ')}`);
  const request = {
    lane: options.lane,
    action: options.action,
    target: options.target,
    sourceTrust: options.sourceTrust,
    account: options.account,
    namespace: options.namespace,
    mutation: options.mutation,
    classification: options.classification,
    binaryReviewed: parseBooleanOption(options.binaryReviewed, '--binary-reviewed'),
    rate: parsePositiveOption(options.rate, '--rate'),
    concurrency: parsePositiveOption(options.concurrency, '--concurrency'),
    totalRequests: parsePositiveOption(options.totalRequests, '--total-requests'),
    duration: parsePositiveOption(options.duration, '--duration'),
    resource: options.resource,
  };
  const timestamp = options.at ?? new Date().toISOString();
  const decision = evaluateAuthorization({ manifest: authorization, request, now: timestamp });
  const auditName = nonEmptyString(authorization.audit?.path) && !authorization.audit.path.includes('/')
    ? authorization.audit.path
    : 'authorization-audit.jsonl';
  const auditPath = resolve(dirname(manifestPath), auditName);
  if (!safePhysicalPath(dirname(manifestPath), auditPath)) fail('authorization audit path crosses a symbolic link');
  const auditManifest = { ...authorization, engagementId: authorization.engagementId ?? 'INVALID-MANIFEST' };
  const event = buildAuditEvent({ manifest: auditManifest, request, decision, timestamp, patterns });
  atomicPrivateAppend(auditPath, `${JSON.stringify(event)}\n`);
  const safeReason = redactText(decision.reason, patterns).text.replace(/[\r\n]+/g, ' ');
  console.log(`AUTHORIZATION  ${decision.decision.toUpperCase()} rule=${decision.ruleId} reason=${safeReason} audit=${auditPath}`);
  return decision.decision === 'allow' ? 0 : 3;
}

function redactCommand(args) {
  const options = parseNamedOptions(args, new Set(['--input', '--output']));
  const input = options.input ?? '-';
  const output = options.output ?? '-';
  const buffer = input === '-' ? readFileSync(0) : readFileSync(resolve(input));
  if (isBinaryBuffer(buffer)) {
    console.error('REDACTION  DENY rule=AUTH-REDACTION-REQUIRED reason=binary evidence requires approved masking and independent review');
    return 4;
  }
  const patterns = readJson(REDACTION_PATTERNS_PATH);
  const errors = validateRedactionPatterns(patterns);
  if (errors.length > 0) fail(`packaged redaction patterns are invalid: ${errors.join('; ')}`);
  const source = buffer.toString('utf8');
  let redacted;
  let findings;
  try {
    const parsed = JSON.parse(source);
    const result = redactValue(parsed, patterns);
    redacted = `${JSON.stringify(result.value, null, 2)}\n`;
    findings = result.findings;
  } catch {
    const result = redactText(source, patterns);
    redacted = result.text;
    findings = result.findings;
  }
  if (output === '-') {
    process.stdout.write(redacted);
  } else {
    const outputPath = resolve(output);
    assertActiveEngagementWrites([outputPath], 'redaction output');
    mkdirSync(dirname(outputPath), { recursive: true });
    atomicPrivateWrite(outputPath, redacted);
    console.log(`REDACTION  wrote=${outputPath} findings=${findings.length}`);
  }
  return 0;
}

function printPath(id) {
  const asset = requireAsset(id);
  console.log(assetPath(asset));
}

function verify() {
  try {
    const stats = verifyRuntimeAssets();
    console.log(`PASS  ${stats.assets} assets verified (${stats.assetBytes} bytes); plugin ${stats.pluginBytes} bytes`);
  } catch (error) {
    fail(error.message);
  }
}

function verifyRuntimeAssets() {
  let assetBytes = 0;
  for (const asset of manifest.assets) {
    const path = assetPath(asset);
    if (!existsSync(path)) throw new Error(`missing packaged asset: ${asset.id} (${asset.destination})`);
    const stats = treeStats(path);
    if (stats.files !== asset.files || stats.bytes !== asset.bytes || stats.sha256 !== asset.sha256) {
      throw new Error(`packaged asset hash mismatch: ${asset.id}`);
    }
    assetBytes += stats.bytes;
  }
  if (assetBytes > manifest.budgets.generatedAssetsBytes) {
    throw new Error(`generated asset budget exceeded: ${assetBytes} > ${manifest.budgets.generatedAssetsBytes}`);
  }
  const pluginBytes = treeStats(ROOT).bytes;
  if (pluginBytes > manifest.budgets.installedPluginBytes) {
    throw new Error(`installed plugin budget exceeded: ${pluginBytes} > ${manifest.budgets.installedPluginBytes}`);
  }
  loadVerifiedRuntimeInventory();
  return { assets: manifest.assets.length, assetBytes, pluginBytes };
}

function loadVerifiedRuntimeInventory() {
  if (!existsSync(INVENTORY_PATH)) throw new Error('missing runtime-reference-inventory.json');
  const buffer = readFileSync(INVENTORY_PATH);
  const metadata = manifest.inventory;
  if (!metadata || metadata.path !== 'runtime-reference-inventory.json' || metadata.schemaVersion !== 2) {
    throw new Error('runtime inventory metadata is missing or invalid');
  }
  const digest = createHash('sha256').update(buffer).digest('hex');
  if (metadata.bytes !== buffer.length || metadata.sha256 !== digest) {
    throw new Error('runtime inventory differs from the packaged manifest');
  }
  let inventory;
  try {
    inventory = JSON.parse(buffer.toString('utf8'));
  } catch (error) {
    throw new Error(`cannot parse runtime inventory: ${error.message}`);
  }
  const counts = [
    ['agentsScanned', 27],
    ['skillsScanned', 7],
    ['entrypointsScanned', 1],
  ];
  for (const [field, expected] of counts) {
    if (inventory[field] !== expected) throw new Error(`runtime inventory ${field} is ${inventory[field]}; expected ${expected}`);
  }
  if (inventory.schemaVersion !== 2 || inventory.generatedFrom !== 'all packaged Argus agents, skills, entrypoints, capability declarations, runtime imports, hooks, CLI commands, and template compositions') {
    throw new Error('runtime inventory v2 identity is invalid');
  }
  for (const field of ['runtimeFilesScanned', 'runtimeImportsScanned', 'hooksScanned']) {
    if (!Number.isInteger(inventory[field]) || inventory[field] < 1) {
      throw new Error(`runtime inventory ${field} must be a positive integer`);
    }
  }
  for (const field of [
    'unconsumedAssets',
    'unknownAssetReferences',
    'unknownProfileReferences',
    'unownedPluginReferences',
    'unownedRuntimeReferences',
    'unownedSkills',
  ]) {
    if (!Array.isArray(inventory[field]) || inventory[field].length !== 0) {
      throw new Error(`runtime inventory ${field} must be an empty array`);
    }
  }
  for (const field of ['pluginAssetReferences', 'targetFileReferences', 'commandReferences']) {
    if (!Array.isArray(inventory[field]) || inventory[field].some((record) =>
      !nonEmptyString(record?.value) || !Array.isArray(record.consumers) || record.consumers.length === 0 ||
      record.consumers.some((consumer) => !nonEmptyString(consumer)))) {
      throw new Error(`runtime inventory ${field} is malformed`);
    }
  }
  if (!Array.isArray(inventory.assetConsumers) || inventory.assetConsumers.length !== manifest.assets.length) {
    throw new Error('runtime inventory asset consumer count differs from the manifest');
  }
  const expectedAssets = new Map(manifest.assets.map((asset) => [asset.id, asset.destination]));
  const seenAssets = new Set();
  for (const record of inventory.assetConsumers) {
    if (!expectedAssets.has(record?.assetId) || expectedAssets.get(record.assetId) !== record.destination ||
        seenAssets.has(record.assetId) || !Array.isArray(record.consumers) || record.consumers.length === 0) {
      throw new Error(`runtime inventory has an invalid asset consumer record: ${record?.assetId ?? '(missing)'}`);
    }
    seenAssets.add(record.assetId);
  }
  const coreReference = inventory.pluginAssetReferences.find((record) =>
    record.value === 'skills/orchestration-core/SKILL.md');
  if (!coreReference?.consumers.includes('/argus:run')) {
    throw new Error('runtime inventory does not bind /argus:run to orchestration-core');
  }
  return inventory;
}

function inspectNativeLaunchForPreflight({ options, modelRuntime, mode, targetKind, targetIdentity, artifactRootPath, engagementId }) {
  if (modelRuntime !== 'claude') return { ready: false, evidence: 'native launch authorization is available only for Claude runtime' };
  try {
    if (!options.launchAuthorization || !options.launchReceipt || !options.trustStore) {
      throw new Error('signed launch authorization, verified receipt, and public trust store are required');
    }
    const authorizationPath = strictPhysicalInput(options.launchAuthorization, 'native launch authorization');
    const receiptPath = strictPhysicalInput(options.launchReceipt, 'native launch receipt');
    const trustStorePath = strictPhysicalInput(options.trustStore, 'native launch trust store');
    const expectedReceipt = join(artifactRootPath, 'ai_agents_internal', 'native-launch-receipt.json');
    if (receiptPath !== expectedReceipt || !safePhysicalPath(artifactRootPath, receiptPath)) {
      throw new Error('native launch receipt is outside the exact engagement control path');
    }
    const authorization = JSON.parse(readFileSync(authorizationPath, 'utf8'));
    const receipt = JSON.parse(readFileSync(receiptPath, 'utf8'));
    const trustStoreRaw = readFileSync(trustStorePath);
    const trustStore = JSON.parse(trustStoreRaw.toString('utf8'));
    const authorizationErrors = validateNativeLaunchAuthorizationSchema(authorization);
    if (authorizationErrors.length) throw new Error(`authorization schema: ${formatSchemaErrors(authorizationErrors)}`);
    const receiptErrors = validateNativeLaunchReceiptSchema(receipt);
    if (receiptErrors.length) throw new Error(`receipt schema: ${formatSchemaErrors(receiptErrors)}`);
    const trustErrors = validateModelTrustStoreSchema(trustStore);
    if (trustErrors.length) throw new Error(`trust-store schema: ${formatSchemaErrors(trustErrors)}`);
    const artifactStats = lstatSync(artifactRootPath);
    const artifactUid = typeof process.getuid === 'function' ? process.getuid() : artifactStats.uid;
    if (!artifactStats.isDirectory() || artifactStats.isSymbolicLink() || realpathSync(artifactRootPath) !== artifactRootPath ||
        artifactStats.uid !== artifactUid || (artifactStats.mode & 0o022) !== 0) {
      throw new Error('artifact root is not a physical current-user-owned directory with safe permissions');
    }
    const trustStats = lstatSync(trustStorePath);
    const trustDirectoryStats = lstatSync(dirname(trustStorePath));
    const uid = typeof process.getuid === 'function' ? process.getuid() : null;
    if (trustStats.isSymbolicLink() || !trustStats.isFile() || trustStats.nlink !== 1 ||
        trustDirectoryStats.isSymbolicLink() || !trustDirectoryStats.isDirectory() ||
        realpathSync(trustStorePath) !== trustStorePath || realpathSync(dirname(trustStorePath)) !== dirname(trustStorePath) ||
        (uid !== null && (trustStats.uid !== uid || trustDirectoryStats.uid !== uid)) ||
        (trustStats.mode & 0o133) !== 0 || (trustDirectoryStats.mode & 0o022) !== 0) {
      throw new Error('native launch trust store path or permissions are unsafe');
    }
    if (isWithin(artifactRootPath, trustStorePath) || (targetKind === 'path' && isWithin(targetIdentity, trustStorePath))) {
      throw new Error('native launch trust store entered the target or artifact boundary');
    }
    const trustRecord = trustStore.keys.find((record) => record.keyId === authorization.authentication.keyId);
    if (!trustRecord || trustRecord.status !== 'active' || trustRecord.purpose !== 'runtime-attestation') {
      throw new Error('native launch runtime-attestation anchor is missing or revoked');
    }
    const runtimeFingerprint = modelPublicKeyFingerprint(trustRecord.publicKeyPem);
    const pinnedRuntimeKey = {
      keyId: trustRecord.keyId,
      purpose: trustRecord.purpose,
      subjectId: trustRecord.subjectId,
      algorithm: 'Ed25519',
      publicKeyPem: trustRecord.publicKeyPem,
      keyFingerprintSha256: runtimeFingerprint,
    };
    const authentication = verifyNativeLaunchAuthorization(authorization, pinnedRuntimeKey);
    const now = Date.now();
    const issuedAt = Date.parse(authorization.issuedAt);
    const expiresAt = Date.parse(authorization.expiresAt);
    if (!Number.isFinite(issuedAt) || !Number.isFinite(expiresAt) || expiresAt <= issuedAt || expiresAt - issuedAt > 300_000 ||
        issuedAt > now + 30_000 || expiresAt <= now) {
      throw new Error('native launch authorization is stale or has an invalid validity window');
    }
    if (authorization.mode !== mode || authorization.targetKind !== targetKind || authorization.target !== targetIdentity ||
        authorization.artifactRoot !== artifactRootPath || authorization.engagementId !== engagementId) {
      throw new Error('native launch authorization differs from the current engagement coordinates');
    }
    const currentWorkspace = realpathSync(process.cwd());
    if (authorization.workspace !== currentWorkspace) throw new Error('native launch workspace differs from the sandbox working directory');
    const authorizationSha256 = modelAuthenticatedDocumentSha256(authorization);
    const trustStoreSha256 = createHash('sha256').update(trustStoreRaw).digest('hex');
    const receiptBindings = {
      launchId: authorization.launchId,
      engagementId: authorization.engagementId,
      launcherPid: authorization.launcherPid,
      launchCapabilitySha256: authorization.launchCapabilitySha256,
      authorizationPath,
      authorizationSha256,
      trustStorePath,
      trustStoreSha256,
      runtimeKeyId: authentication.keyId,
      runtimeKeyFingerprintSha256: authentication.keyFingerprintSha256,
      targetKind,
      target: targetIdentity,
      workspace: authorization.workspace,
      artifactRoot: artifactRootPath,
      mode,
      runtime: authorization.runtime,
      model: authorization.model,
      effort: authorization.effort,
      maxTurns: authorization.maxTurns,
      launcherExecutable: authorization.launcherExecutable,
      launcherSha256: authorization.launcherSha256,
      claudeExecutable: authorization.claudeExecutable,
      claudeExecutableSha256: authorization.claudeExecutableSha256,
      claudeVersion: authorization.claudeVersion,
      sandboxPolicy: authorization.sandboxPolicy,
      sandboxProbePath: authorization.sandboxProbePath,
      sandboxProbeDevice: authorization.sandboxProbeDevice,
      sandboxProbeInode: authorization.sandboxProbeInode,
      sandboxProbeUid: authorization.sandboxProbeUid,
      sandboxProbeMode: authorization.sandboxProbeMode,
      environmentPolicy: authorization.environmentPolicy,
      expiresAt: authorization.expiresAt,
    };
    for (const [field, expected] of Object.entries(receiptBindings)) {
      if (receipt[field] !== expected) throw new Error(`native launch receipt ${field} binding differs from signed authorization`);
    }
    if (Date.parse(receipt.verifiedAt) < issuedAt || Date.parse(receipt.verifiedAt) > now + 30_000) {
      throw new Error('native launch receipt verification time is invalid');
    }
    if (sha256File(strictPhysicalInput(authorization.launcherExecutable, 'authorized launcher executable')) !== authorization.launcherSha256) {
      throw new Error('authorized launcher executable changed after verification');
    }
    const claudeExecutable = strictPhysicalInput(authorization.claudeExecutable, 'authorized Claude executable');
    if (sha256File(claudeExecutable) !== authorization.claudeExecutableSha256 || claudeExecutableVersion(claudeExecutable) !== authorization.claudeVersion) {
      throw new Error('authorized Claude executable or version changed after verification');
    }
    const sandboxProbePath = strictPhysicalDirectoryInput(authorization.sandboxProbePath, 'authorized sandbox probe');
    if (isWithin(artifactRootPath, sandboxProbePath) || (targetKind === 'path' && isWithin(targetIdentity, sandboxProbePath))) {
      throw new Error('authorized sandbox probe entered the target or artifact boundary');
    }
    const sandboxProbeStats = lstatSync(sandboxProbePath);
    const sandboxProbeBindings = {
      sandboxProbeDevice: sandboxProbeStats.dev,
      sandboxProbeInode: sandboxProbeStats.ino,
      sandboxProbeUid: sandboxProbeStats.uid,
      sandboxProbeMode: sandboxProbeStats.mode & 0o777,
    };
    for (const [field, current] of Object.entries(sandboxProbeBindings)) {
      if (authorization[field] !== current) throw new Error(`authorized sandbox probe ${field} identity changed after verification`);
    }
    if ((sandboxProbeStats.mode & 0o777) !== 0o700 || readdirSync(sandboxProbePath).length !== 0) {
      throw new Error('authorized sandbox probe is not an empty mode-0700 directory');
    }
    if (directoryIsWritable(sandboxProbePath)) {
      throw new Error('OS sandbox is not active: signed host-writable probe remains writable');
    }
    if (!directoryIsWritable(artifactRootPath)) {
      throw new Error('OS sandbox does not permit the contracted artifact root');
    }
    const expectedEnvironment = {
      ARGUS_MODEL_TRUST_STORE: trustStorePath,
      ARGUS_NATIVE_LAUNCH_AUTHORIZATION: authorizationPath,
      ARGUS_NATIVE_LAUNCH_RECEIPT: receiptPath,
    };
    for (const [name, expected] of Object.entries(expectedEnvironment)) {
      if (process.env[name] !== expected) throw new Error(`${name} does not match the signed launcher binding`);
    }
    const capability = process.env.ARGUS_NATIVE_LAUNCH_CAPABILITY;
    if (!/^[a-f0-9]{64}$/.test(capability ?? '')) throw new Error('native launch capability is missing or malformed');
    if (createHash('sha256').update(capability).digest('hex') !== authorization.launchCapabilitySha256) {
      throw new Error('native launch capability does not match the signed authorization');
    }
    expectedEnvironment.ARGUS_NATIVE_LAUNCH_CAPABILITY = capability;
    const unexpectedArgus = Object.keys(process.env).filter((name) => name.startsWith('ARGUS_') && !Object.hasOwn(expectedEnvironment, name));
    if (unexpectedArgus.length) throw new Error(`unapproved inherited Argus environment: ${unexpectedArgus.sort().join(',')}`);
    return {
      ready: true,
      evidence: `authenticated launch ${authorization.launchId}; signer=${authorization.issuedBy}; claude=${authorization.claudeVersion}; model=opus effort=max maxTurns=96; sandbox=${authorization.sandboxPolicy}; environment=${authorization.environmentPolicy}`,
    };
  } catch (error) {
    return { ready: false, evidence: `authenticated native launch unavailable: ${error.message}` };
  }
}

function strictPhysicalInput(value, label) {
  if (typeof value !== 'string' || !value.startsWith('/') || resolve(value) !== value) throw new Error(`${label} path is not absolute and normalized`);
  const stats = lstatSync(value);
  if (!stats.isFile() || stats.isSymbolicLink() || stats.nlink !== 1 || realpathSync(value) !== value) {
    throw new Error(`${label} is not a physical single-link file`);
  }
  return value;
}

function strictPhysicalDirectoryInput(value, label) {
  if (typeof value !== 'string' || !value.startsWith('/') || resolve(value) !== value) throw new Error(`${label} path is not absolute and normalized`);
  const stats = lstatSync(value);
  if (!stats.isDirectory() || stats.isSymbolicLink() || realpathSync(value) !== value) {
    throw new Error(`${label} is not a physical directory`);
  }
  return value;
}

async function preflight(argv) {
  assertTrustedModelRoutingAssets();
  const options = parsePreflightOptions(argv);
  let inventory;
  try {
    inventory = loadVerifiedRuntimeInventory();
  } catch (error) {
    fail(error.message);
  }
  const profile = options.profile ? readJson(resolve(options.profile)) : {};
  const mode = options.mode ?? 'A';
  const modelRuntime = options.modelRuntime ?? 'claude';
  if (!['A', 'B', 'C', 'D'].includes(mode)) fail('preflight --mode must be A, B, C, or D');
  if (!['claude', 'codex'].includes(modelRuntime)) fail('preflight --model-runtime must be claude or codex');
  if (!options.target) fail('preflight requires --target <url-or-path>');
  const selectedSlugs = new Set(matrix.agents.filter((agent) => agent.modes.includes(mode)).map((agent) => agent.slug));
  for (const feature of options.features) {
    if (!Object.hasOwn(matrix.capabilities, feature)) fail(`unknown preflight feature: ${feature}`);
  }

  const targetDescriptor = identifyTarget(options.target);
  const { kind: targetKind, targetPath, targetIdentity } = targetDescriptor;
  let target = {
    value: targetIdentity,
    kind: targetKind,
    reachable: false,
    evidence: 'target probe deferred until authorization and engagement controls are persisted',
  };
  const artifactRootCandidate = resolve(options.artifactRoot ?? targetPath ?? process.cwd());
  const artifactRootPath = statSafe(artifactRootCandidate)?.isDirectory() ? realpathSync(artifactRootCandidate) : artifactRootCandidate;
  const nativeLaunch = inspectNativeLaunchForPreflight({
    options,
    modelRuntime,
    mode,
    targetKind,
    targetIdentity,
    artifactRootPath,
    engagementId: options.engagementId,
  });
  if (modelRuntime === 'claude' && !nativeLaunch.ready) fail(nativeLaunch.evidence);
  const outputRelative = options.output ?? 'ai_agents_internal/preflight.json';
  const requestedOutputPath = resolve(artifactRootPath, outputRelative);
  const fallbackOutputPath = resolve(artifactRootPath, 'ai_agents_internal/preflight.json');
  const requestedOutputSafe = isWithin(artifactRootPath, requestedOutputPath) && safePhysicalPath(artifactRootPath, requestedOutputPath);
  const outputPath = requestedOutputSafe ? requestedOutputPath : fallbackOutputPath;
  const outputPathSafe = isWithin(artifactRootPath, outputPath) && safePhysicalPath(artifactRootPath, outputPath);
  const contractedArtifactPaths = [
    ...matrix.orchestration.artifactPaths,
    ...matrix.agents.flatMap((agent) => agent.artifactPaths),
  ];
  const safePaths = requestedOutputSafe && contractedArtifactPaths.every((path) => {
    const stablePrefix = path.replace(/[*?].*$/, '').replace(/\/$/, '');
    const resolvedPath = resolve(artifactRootPath, stablePrefix);
    return isWithin(artifactRootPath, resolvedPath) && safePhysicalPath(artifactRootPath, resolvedPath);
  });
  const artifactWritable = typeof profile.artifactWritable === 'boolean'
    ? profile.artifactWritable
    : isWritableDirectory(artifactRootPath);

  const authorizationEnvironment = options.environment ?? profile.environment ?? 'unknown';
  if (!['unknown', 'development', 'test', 'staging', 'production'].includes(authorizationEnvironment)) {
    fail('preflight --environment must be unknown, development, test, staging, or production');
  }
  const authorizationCandidate = resolve(artifactRootPath, options.authorization ?? 'ai_agents_internal/authorization.json');
  const requestedAuthorizationPath = existsSync(authorizationCandidate) && !lstatSync(authorizationCandidate).isSymbolicLink()
    ? realpathSync(authorizationCandidate) : authorizationCandidate;
  const authorizationPathSafe = isWithin(artifactRootPath, requestedAuthorizationPath) && safePhysicalPath(artifactRootPath, requestedAuthorizationPath);
  let authorization = null;
  let authorizationCreated = false;
  const authorizationErrors = [];
  if (!authorizationPathSafe) {
    authorizationErrors.push('authorization manifest path escapes the artifact root');
  } else if (existsSync(requestedAuthorizationPath)) {
    try {
      authorization = JSON.parse(readFileSync(requestedAuthorizationPath, 'utf8'));
    } catch (error) {
      authorizationErrors.push(`authorization manifest is not valid JSON: ${error.message}`);
    }
  } else if (options.authorization) {
    authorizationErrors.push(`supplied authorization manifest is missing: ${requestedAuthorizationPath}`);
  } else if (!artifactWritable) {
    authorizationErrors.push('artifact root is not writable; cannot create default authorization manifest');
  } else {
    authorization = createDefaultAuthorization({
      template: readJson(AUTHORIZATION_TEMPLATE_PATH),
      target: targetIdentity,
      environment: authorizationEnvironment,
      engagementId: options.engagementId,
    });
    mkdirSync(dirname(requestedAuthorizationPath), { recursive: true });
    writeFileSync(requestedAuthorizationPath, `${JSON.stringify(authorization, null, 2)}\n`, { mode: 0o600 });
    chmodSync(requestedAuthorizationPath, 0o600);
    authorizationCreated = true;
  }
  if (authorization) {
    authorizationErrors.push(...validateAuthorizationManifest(authorization));
  }
  const authorizationAuditPath = authorization && nonEmptyString(authorization.audit?.path)
    ? resolve(dirname(requestedAuthorizationPath), authorization.audit.path)
    : resolve(dirname(requestedAuthorizationPath), 'authorization-audit.jsonl');
  const authorizationAuditPathSafe = isWithin(artifactRootPath, authorizationAuditPath) && safePhysicalPath(artifactRootPath, authorizationAuditPath);
  if (!authorizationAuditPathSafe) authorizationErrors.push('authorization audit path escapes the artifact root');
  const production = authorization
    ? detectProductionLike(authorization.target, options.target)
    : { productionLike: true, signals: ['invalid-authorization-manifest'] };
  const authorizationSummary = {
    manifestPath: requestedAuthorizationPath,
    auditPath: authorizationAuditPath,
    sha256: authorization ? manifestSha256(authorization) : null,
    created: authorizationCreated,
    environment: authorization?.target?.environment ?? authorizationEnvironment,
    productionLike: production.productionLike,
    productionSignals: production.signals,
    defaultReadOnly: !authorization || Object.values(authorization.actionGrants ?? {}).every((grant) => !grant.enabled),
  };

  const engagementCandidate = resolve(artifactRootPath, options.engagement ?? 'ai_agents_internal/engagement.json');
  const requestedEngagementPath = existsSync(engagementCandidate) && !lstatSync(engagementCandidate).isSymbolicLink()
    ? realpathSync(engagementCandidate) : engagementCandidate;
  const engagementPathSafe = isWithin(artifactRootPath, requestedEngagementPath) && safePhysicalPath(artifactRootPath, requestedEngagementPath);
  let engagement = null;
  let engagementCreated = false;
  let engagementState = null;
  const engagementErrors = [];
  if (!engagementPathSafe) {
    engagementErrors.push('engagement manifest path escapes the artifact root');
  } else if (existsSync(requestedEngagementPath)) {
    try { engagement = JSON.parse(readFileSync(requestedEngagementPath, 'utf8')); }
    catch (error) { engagementErrors.push(`engagement manifest is not valid JSON: ${error.message}`); }
  } else if (options.engagement) {
    engagementErrors.push(`supplied engagement manifest is missing: ${requestedEngagementPath}`);
  } else if (!artifactWritable) {
    engagementErrors.push('artifact root is not writable; cannot create engagement manifest');
  } else if (!authorization || authorizationErrors.length > 0) {
    engagementErrors.push('valid authorization manifest is required before engagement initialization');
  } else {
    engagement = createDefaultEngagement({
      template: readJson(ENGAGEMENT_TEMPLATE_PATH),
      target: targetIdentity,
      targetRoot: targetPath,
      artifactRoot: artifactRootPath,
      mode,
      engagementId: authorization.engagementId,
      selectedAgents: [...selectedSlugs],
      browserSupport: profile.browserSupport,
      accessibilityRequirement: profile.accessibilityRequirement,
    });
    mkdirSync(dirname(requestedEngagementPath), { recursive: true });
    writeFileSync(requestedEngagementPath, `${JSON.stringify(engagement, null, 2)}\n`, { mode: 0o600 });
    chmodSync(requestedEngagementPath, 0o600);
    engagementCreated = true;
  }
  if (engagement) {
    engagementErrors.push(...validateEngagementManifest(engagement));
    if (engagement.mode !== mode) engagementErrors.push(`engagement mode ${engagement.mode} does not match preflight mode ${mode}`);
    if (typeof engagement.artifactRoot !== 'string' || !physicalPathsEquivalent(engagement.artifactRoot, artifactRootPath)) engagementErrors.push('engagement artifactRoot does not match preflight artifact root');
    if (!targetIdentitiesEquivalent(engagement.target?.identifier, targetIdentity) || !nullablePhysicalPathsEquivalent(engagement.target?.root, targetPath)) engagementErrors.push('engagement target does not match the inspected target');
    if (engagement.engagementId !== authorization?.engagementId) engagementErrors.push('engagementId does not match authorization manifest');
    if (!Array.isArray(engagement.selectedAgents) || JSON.stringify([...engagement.selectedAgents].sort()) !== JSON.stringify([...selectedSlugs].sort())) engagementErrors.push('engagement selectedAgents do not match the selected mode');
    if (engagementErrors.length === 0) {
      try { engagementState = initializeEngagementState(engagement); }
      catch (error) { engagementErrors.push(`engagement state initialization failed: ${error.message}`); }
    }
  }
  const engagementUsable = engagement && engagementErrors.length === 0;
  const authorizationTargetIdentity = engagementUsable ? engagement.target.identifier : targetIdentity;
  const engagementSummary = {
    manifestPath: requestedEngagementPath,
    statePath: engagementUsable ? resolve(engagement.artifactRoot, engagement.statePath) : resolve(artifactRootPath, 'ai_agents_internal/engagement-state.json'),
    immutabilityAuditPath: engagementUsable ? resolve(engagement.artifactRoot, engagement.writePolicy.auditPath) : resolve(artifactRootPath, 'ai_agents_internal/immutability-audit.jsonl'),
    sha256: engagementUsable ? manifestSha256(engagement) : null,
    created: engagementCreated,
    stateCreated: engagementState?.created ?? false,
    phase: engagementState?.state.currentPhase ?? null,
    selectedAgents: engagementUsable ? engagement.selectedAgents.length : 0,
    accessibilityTarget: engagementUsable ? `${engagement.accessibilityPolicy.standard} ${engagement.accessibilityPolicy.version} ${engagement.accessibilityPolicy.level}` : null,
    browserCoverageEntries: engagementUsable ? engagement.browserPolicy.coverage.matrix.length : 0,
    browserCoverageSource: engagementUsable ? engagement.browserPolicy.coverage.supportSource : null,
    hookPath: HOOKS_PATH,
    hookPackaged: existsSync(HOOKS_PATH),
  };

  let preflightHeartbeatError = null;
  let preflightHeartbeatEvidence = null;
  if (engagementUsable) {
    try {
      const heartbeat = ensurePreflightHeartbeat(engagement, profile.generatedAt ?? new Date().toISOString());
      preflightHeartbeatEvidence = heartbeat.disposition === 'created'
        ? 'initial controller heartbeat persisted before target probe'
        : heartbeat.disposition === 'existing'
          ? `validated existing controller heartbeat; engagement state revision=${engagementState.state.revision}`
          : heartbeat.disposition === 'legacy-migrated-existing'
            ? `validated migrated v1 controller heartbeat beginning at ${heartbeat.record.phase}; engagement state revision=${engagementState.state.revision}`
            : `resumed migrated v1 engagement without a historical heartbeat; engagement state revision=${engagementState.state.revision}`;
    } catch (error) { preflightHeartbeatError = error.message; }
  } else {
    preflightHeartbeatError = 'engagement controls are unavailable';
  }

  const probeTimestamp = profile.generatedAt ?? new Date().toISOString();
  const probeRequest = { lane: 'odysseus', action: 'read', target: authorizationTargetIdentity, sourceTrust: 'manifest' };
  const boundaryDecision = authorization && authorizationErrors.length === 0
    ? evaluateAuthorization({ manifest: authorization, request: probeRequest, now: probeTimestamp })
    : null;
  let boundaryAuditError = null;
  if (boundaryDecision && authorizationAuditPathSafe) {
    try {
      const patterns = readJson(REDACTION_PATTERNS_PATH);
      const patternErrors = validateRedactionPatterns(patterns);
      if (patternErrors.length > 0) throw new Error(patternErrors.join('; '));
      const event = buildAuditEvent({ manifest: authorization, request: probeRequest, decision: boundaryDecision, timestamp: probeTimestamp, patterns });
      atomicPrivateAppend(authorizationAuditPath, `${JSON.stringify(event)}\n`);
    } catch (error) {
      boundaryAuditError = `authorization probe audit failed: ${error.message}`;
    }
  } else if (boundaryDecision) {
    boundaryAuditError = 'authorization probe audit path is unsafe';
  }
  const probeAllowed = boundaryDecision?.decision === 'allow' && boundaryAuditError === null && engagementErrors.length === 0 && preflightHeartbeatError === null;
  if (probeAllowed) {
    target = await inspectTarget(options.target, profile);
    target.value = targetIdentity;
  } else {
    const reason = boundaryAuditError ?? (boundaryDecision
      ? `${boundaryDecision.ruleId}: ${boundaryDecision.reason}`
      : 'authorization or engagement controls are unavailable');
    target.evidence = `target probe skipped: ${reason}`;
  }

  const availableTools = new Set(profile.availableTools ?? matrix.supportedBuiltinTools);
  const commandAvailability = detectCommands(inventory, profile);
  const mcpServers = profile.mcpServers ?? detectMcpServers();
  const detectedFeatures = new Set([
    ...(Array.isArray(profile.features) ? profile.features : (probeAllowed ? detectTargetFeatures(targetPath) : [])),
    ...options.features,
  ]);

  const capabilityState = {};
  for (const [id, definition] of Object.entries(matrix.capabilities)) {
    let available = detectedFeatures.has(id);
    let evidence = available ? `target/profile feature confirmed: ${id}` : `target/profile feature not detected: ${id}`;
    if (definition.kind === 'mcp') {
      const match = mcpServers.find((server) => definition.serverPatterns.some((pattern) => server.includes(pattern)));
      available = Boolean(match);
      evidence = match ? `connected MCP server: ${match}` : `no connected MCP server matched ${definition.serverPatterns.join(', ')}`;
    }
    if (id === 'browser-runtime' && !available && probeAllowed) {
      available = hasBrowserRuntime(targetPath);
      evidence = available
        ? 'target has an installed Playwright runtime and packaged isolated driver is available'
        : 'no installed Playwright runtime detected at target root';
    }
    capabilityState[id] = { available, evidence };
  }

  const checks = [];
  const nativeLaunchReady = nativeLaunch.ready;
  addCheck(
    checks,
    'native-host-execution',
    true,
    nativeLaunchReady,
    nativeLaunchReady
      ? nativeLaunch.evidence
      : modelRuntime === 'codex'
        ? 'Codex dispatch is disabled because the installed CLI exposes no native hard turn cap'
        : nativeLaunch.evidence,
  );
  addCheck(checks, 'target-reachable', true, target.reachable, target.evidence);
  addCheck(checks, 'artifact-root-writable', true, artifactWritable, artifactWritable ? `writable: ${artifactRootPath}` : `not writable: ${artifactRootPath}`);
  addCheck(checks, 'artifact-paths-safe', true, safePaths, safePaths ? 'all contracted paths remain under the artifact root' : 'a contracted or output path escapes the artifact root');
  addCheck(
    checks,
    'authorization-manifest',
    true,
    authorizationErrors.length === 0,
    authorizationErrors.length === 0
      ? `${authorizationCreated ? 'created default-deny' : 'loaded'} manifest sha256=${authorizationSummary.sha256}`
      : authorizationErrors.join('; '),
  );
  addCheck(
    checks,
    'engagement-manifest',
    true,
    engagementErrors.length === 0,
    engagementErrors.length === 0
      ? `${engagementCreated ? 'created' : 'loaded'} manifest sha256=${engagementSummary.sha256}; phase=${engagementSummary.phase}`
      : engagementErrors.join('; '),
  );
  addCheck(
    checks,
    'path-immutability-hook',
    true,
    engagementSummary.hookPackaged,
    engagementSummary.hookPackaged ? `packaged PreToolUse hook: ${HOOKS_PATH}` : 'plugin hooks/hooks.json is missing',
  );
  addCheck(
    checks,
    'controller-heartbeat',
    true,
    preflightHeartbeatError === null,
    preflightHeartbeatError ?? preflightHeartbeatEvidence,
  );
  if (boundaryDecision) {
    const passed = boundaryDecision.decision === 'allow' && boundaryAuditError === null;
    const evidence = boundaryAuditError ?? `${boundaryDecision.ruleId}: ${boundaryDecision.reason}; audit=${authorizationAuditPath}`;
    addCheck(checks, 'authorization-target-boundary', true, passed, evidence);
  } else {
    addCheck(checks, 'authorization-target-boundary', true, false, 'authorization manifest unavailable or invalid');
  }
  try {
    const assetStats = verifyRuntimeAssets();
    addCheck(checks, 'packaged-assets', true, true, `${assetStats.assets} assets and hashes verified`);
  } catch (error) {
    addCheck(checks, 'packaged-assets', true, false, error.message);
  }
  for (const tool of matrix.orchestration.requiredTools) {
    addCheck(checks, `tool:${tool}`, true, availableTools.has(tool), availableTools.has(tool) ? 'available' : 'unavailable');
  }
  for (const [id, state] of Object.entries(capabilityState)) {
    addCheck(checks, `capability:${id}`, false, state.available, state.evidence);
  }
  for (const [command, state] of Object.entries(commandAvailability)) {
    const consumers = inventory.commandReferences.find((item) => item.value === command)?.consumers ?? [];
    if (consumers.some((consumer) => selectedSlugs.has(consumer))) {
      addCheck(checks, `command:${command}`, false, state.available, state.evidence);
    }
  }

  const commandConsumers = new Map(inventory.commandReferences.map((item) => [item.value, new Set(item.consumers)]));
  const prerequisiteFailure = checks.some((check) => check.mandatory && check.status === 'fail');
  const authorizationByAgent = new Map(matrix.agents.map((contract) => [
    contract.slug,
    evaluateRiskAuthorizations(contract, authorization, authorizationTargetIdentity, profile.generatedAt ?? new Date().toISOString()),
  ]));
  let agents = matrix.agents.map((contract) => evaluateAgent({
    contract,
    mode,
    availableTools,
    capabilityState,
    commandAvailability,
    commandConsumers,
    matrix,
    modelRuntime,
    mandatoryFailure: prerequisiteFailure,
    authorizationDecisions: authorizationByAgent.get(contract.slug),
  }));
  let orchestration = { path: join(artifactRootPath, 'ai_agents_internal', 'orchestration-plan.json'), sha256: null, specialists: 0 };
  let orchestrationError = null;
  try {
    if (prerequisiteFailure) throw new Error('preflight prerequisites failed; projection was not persisted');
    const dispatchable = agents.filter((agent) => agent.slug !== 'odysseus' && agent.selected && agent.dispatchAllowed).map((agent) => agent.slug);
    orchestration = persistPreflightOrchestrationPlan(artifactRootPath, mode, dispatchable);
  } catch (error) {
    orchestrationError = error.message;
  }
  addCheck(
    checks,
    'orchestration-plan',
    true,
    orchestrationError === null,
    orchestrationError ?? `persisted ${orchestration.specialists} dispatchable specialists sha256=${orchestration.sha256}`,
  );
  if (orchestrationError !== null) {
    agents = agents.map((agent) => agent.selected
      ? { ...agent, status: 'blocked', dispatchAllowed: false, actions: [...agent.actions, `Orchestration projection failed: ${orchestrationError}`] }
      : agent);
  }
  const selectedAgents = agents.filter((agent) => agent.selected);
  const summary = {
    selected: selectedAgents.length,
    ready: selectedAgents.filter((agent) => agent.status === 'ready').length,
    degraded: selectedAgents.filter((agent) => agent.status === 'degraded').length,
    deferred: selectedAgents.filter((agent) => agent.status === 'deferred').length,
    skipped: selectedAgents.filter((agent) => agent.status === 'skipped').length,
    blocked: selectedAgents.filter((agent) => agent.status === 'blocked').length,
    dispatchable: selectedAgents.filter((agent) => agent.dispatchAllowed).length,
  };
  const mandatoryFailure = checks.some((check) => check.mandatory && check.status === 'fail');
  const status = mandatoryFailure || summary.blocked > 0
    ? 'blocked'
    : summary.degraded + summary.deferred + summary.skipped > 0
      ? 'degraded'
      : 'ready';

  const report = {
    $schema: 'https://raw.githubusercontent.com/holi87/holak-teams/master/argus/schemas/preflight-report.schema.json',
    schemaVersion: 2,
    generatedAt: profile.generatedAt ?? new Date().toISOString(),
    mode,
    modelRuntime,
    status,
    target,
    artifactRoot: { path: artifactRootPath, writable: artifactWritable, safePaths },
    authorization: authorizationSummary,
    engagement: engagementSummary,
    orchestration,
    checks,
    capabilities: Object.entries(capabilityState).map(([id, state]) => ({ id, ...state })),
    agents,
    summary,
  };

  let persisted = false;
  if (artifactWritable && outputPathSafe) {
    mkdirSync(dirname(outputPath), { recursive: true });
    atomicPrivateWrite(outputPath, `${JSON.stringify(report, null, 2)}\n`);
    persisted = true;
  }
  if (options.json) {
    process.stdout.write(`${JSON.stringify(report, null, 2)}\n`);
  } else {
    console.log(
      `PREFLIGHT  ${status} mode=${mode} selected=${summary.selected} dispatchable=${summary.dispatchable} ` +
      `degraded=${summary.degraded} deferred=${summary.deferred} skipped=${summary.skipped} blocked=${summary.blocked} ` +
      `report=${persisted ? outputPath : 'NOT_PERSISTED'}`,
    );
  }
  return status === 'blocked' ? 2 : 0;
}

function evaluateAgent({ contract, mode, availableTools, capabilityState, commandAvailability, commandConsumers, matrix, modelRuntime, mandatoryFailure, authorizationDecisions }) {
  const selected = contract.modes.includes(mode);
  if (!selected) return agentResult(contract, false, 'not-selected', false, [], [], [], contract.artifactPaths, authorizationDecisions, modelRuntime);
  if (mandatoryFailure) {
    return agentResult(contract, true, 'blocked', false, [], [], ['Orchestration preflight failed; no specialist may be dispatched.'], contract.artifactPaths, authorizationDecisions, modelRuntime);
  }
  const modelPreview = buildModelRoutingPreview(modelPolicy, runtimeAdapters, { slug: contract.slug, runtime: modelRuntime });
  if (modelPreview.status !== 'ready') {
    return agentResult(contract, true, 'blocked', false, [], [`model:${modelPreview.missingCapabilities.join(',')}`], [modelPreview.reason], contract.artifactPaths, authorizationDecisions, modelRuntime);
  }

  const missingTools = contract.requiredTools.filter((tool) => !availableTools.has(tool));
  const missingRequired = (contract.requiredCapabilities ?? []).filter((id) => !capabilityState[id]?.available);
  const missingOptional = (contract.optionalCapabilities ?? []).filter((id) => !capabilityState[id]?.available);
  const missingCommands = Object.entries(commandAvailability)
    .filter(([command, state]) => !state.available && commandConsumers.get(command)?.has(contract.slug))
    .map(([command]) => `command:${command}`);
  const actions = [];

  if (missingTools.length > 0) {
    actions.push(`Mandatory tools unavailable: ${missingTools.join(', ')}. Stop before dispatch.`);
    return agentResult(contract, true, 'blocked', false, missingTools, [...missingRequired, ...missingOptional, ...missingCommands], actions, contract.artifactPaths, authorizationDecisions, modelRuntime);
  }

  let status = 'ready';
  for (const id of missingRequired) {
    const capability = matrix.capabilities[id];
    actions.push(`${id}: ${capability.fallback}`);
    if (capability.missingDisposition === 'skipped') status = 'skipped';
    else if (status !== 'skipped') status = 'deferred';
  }
  for (const id of missingOptional) {
    actions.push(`${id}: ${matrix.capabilities[id].fallback}`);
    if (status === 'ready') status = 'degraded';
  }
  if (missingCommands.length > 0) {
    actions.push(`Optional host commands unavailable: ${missingCommands.map((item) => item.slice(8)).join(', ')}; use an available equivalent or record the probe as skipped.`);
    if (status === 'ready') status = 'degraded';
  }
  const deniedAuthorizations = authorizationDecisions.filter((decision) => decision.decision === 'deny');
  if (deniedAuthorizations.length > 0) {
    actions.push(...deniedAuthorizations.map((decision) => (
      `Authorization denied ${decision.action}: ${decision.ruleId} — ${decision.reason}. Restrict the lane to its allowed read-only actions.`
    )));
    if (status === 'ready') status = 'degraded';
  }
  return agentResult(
    contract,
    true,
    status,
    status === 'ready' || status === 'degraded',
    [],
    [...missingRequired, ...missingOptional, ...missingCommands],
    actions,
    contract.artifactPaths,
    authorizationDecisions,
    modelRuntime,
  );
}

function agentResult(contract, selected, status, dispatchAllowed, missingTools, missingCapabilities, actions, artifactPaths, authorization, modelRuntime) {
  const model = buildModelRoutingPreview(modelPolicy, runtimeAdapters, { slug: contract.slug, runtime: modelRuntime });
  return { slug: contract.slug, lane: contract.lane, selected, status, dispatchAllowed: contract.slug === 'odysseus' ? false : dispatchAllowed, model, missingTools, missingCapabilities, actions, artifactPaths, authorization };
}

function evaluateRiskAuthorizations(contract, authorization, target, now) {
  if (!authorization) {
    return (contract.riskActions ?? []).map((action) => ({
      action,
      decision: 'deny',
      ruleId: 'AUTH-MANIFEST-INVALID',
      reason: 'authorization manifest is unavailable',
    }));
  }
  const account = authorization.accounts?.allowedAliases?.[0];
  const namespace = authorization.dataBoundaries?.allowedNamespaces?.[0];
  const mutation = authorization.allowedMutations?.[0];
  return (contract.riskActions ?? []).map((action) => {
    const decision = evaluateAuthorization({
      manifest: authorization,
      request: {
        lane: contract.slug,
        action,
        target,
        sourceTrust: 'manifest',
        account,
        namespace,
        mutation,
        rate: authorization.rateLimits?.requestsPerSecond,
        concurrency: authorization.rateLimits?.maxConcurrent,
        totalRequests: authorization.rateLimits?.maxTotalRequests,
        duration: authorization.rateLimits?.maxDurationSeconds,
        binaryReviewed: action === 'binary-evidence' ? true : undefined,
      },
      now,
    });
    return { action, decision: decision.decision, ruleId: decision.ruleId, reason: decision.reason };
  });
}

function parsePreflightOptions(args) {
  const options = { features: [], json: false };
  for (let index = 0; index < args.length; index += 1) {
    const name = args[index];
    if (name === '--json') {
      options.json = true;
      continue;
    }
    const value = args[index + 1];
    if (!value || value.startsWith('--')) fail(`preflight ${name} requires a value`);
    index += 1;
    if (name === '--target') options.target = value;
    else if (name === '--mode') options.mode = value.toUpperCase();
    else if (name === '--artifact-root') options.artifactRoot = value;
    else if (name === '--output') options.output = value;
    else if (name === '--authorization') options.authorization = value;
    else if (name === '--engagement') options.engagement = value;
    else if (name === '--environment') options.environment = value;
    else if (name === '--engagement-id') options.engagementId = value;
    else if (name === '--model-runtime') options.modelRuntime = value.toLowerCase();
    else if (name === '--launch-authorization') options.launchAuthorization = value;
    else if (name === '--launch-receipt') options.launchReceipt = value;
    else if (name === '--trust-store') options.trustStore = value;
    else if (name === '--profile') options.profile = value;
    else if (name === '--feature') options.features.push(value);
    else fail(`unknown preflight option: ${name}`);
  }
  return options;
}

async function inspectTarget(value, profile) {
  if (/^https?:\/\//i.test(value)) {
    if (typeof profile.targetReachable === 'boolean') {
      return { value, kind: 'url', reachable: profile.targetReachable, evidence: `profile override: reachable=${profile.targetReachable}` };
    }
    try {
      const response = await fetch(value, { method: 'HEAD', redirect: 'manual', signal: AbortSignal.timeout(5000) });
      return { value, kind: 'url', reachable: true, evidence: `HTTP HEAD responded with ${response.status}` };
    } catch (error) {
      return { value, kind: 'url', reachable: false, evidence: `HTTP HEAD failed: ${error.message}` };
    }
  }
  const path = resolve(value);
  let reachable = typeof profile.targetReachable === 'boolean' ? profile.targetReachable : existsSync(path);
  if (reachable && typeof profile.targetReachable !== 'boolean') {
    try {
      accessSync(path, constants.R_OK);
    } catch {
      reachable = false;
    }
  }
  return {
    value: path,
    kind: 'path',
    reachable,
    evidence: typeof profile.targetReachable === 'boolean'
      ? `profile override: reachable=${profile.targetReachable}`
      : reachable ? `local path exists and is readable: ${path}` : `local path is missing or unreadable: ${path}`,
  };
}

function identifyTarget(value) {
  if (/^https?:\/\//i.test(value)) {
    let url;
    try { url = new URL(value); }
    catch (error) { fail(`preflight target URL is invalid: ${error.message}`); }
    if (!['http:', 'https:'].includes(url.protocol)) fail('preflight target URL must use HTTP or HTTPS');
    return { kind: 'url', targetPath: null, targetIdentity: url.toString() };
  }
  const candidate = resolve(value);
  const targetPath = statSafe(candidate) ? realpathSync(candidate) : candidate;
  return { kind: 'path', targetPath, targetIdentity: targetPath };
}

function targetIdentitiesEquivalent(stored, inspected) {
  if (stored === inspected) return true;
  if (!nonEmptyString(stored) || !nonEmptyString(inspected)) return false;
  if (!/^https?:\/\//i.test(stored) && !/^https?:\/\//i.test(inspected)) return physicalPathsEquivalent(stored, inspected);
  if (!/^https?:\/\//i.test(stored) || !/^https?:\/\//i.test(inspected)) return false;
  try {
    const storedUrl = new URL(stored);
    const inspectedUrl = new URL(inspected);
    if (!['http:', 'https:'].includes(storedUrl.protocol) || !['http:', 'https:'].includes(inspectedUrl.protocol)) return false;
    return storedUrl.toString() === inspectedUrl.toString();
  } catch {
    return false;
  }
}

function detectCommands(inventory, profile) {
  const override = Array.isArray(profile.commands) ? new Set(profile.commands) : null;
  const result = {};
  for (const { value } of inventory.commandReferences) {
    const available = override ? override.has(value) : commandExists(value);
    result[value] = { available, evidence: override ? `profile command ${available ? 'available' : 'missing'}` : `PATH command ${available ? 'found' : 'missing'}` };
  }
  return result;
}

function commandExists(command) {
  try {
    execFileSync('sh', ['-c', 'command -v "$1" >/dev/null 2>&1', 'argus-preflight', command]);
    return true;
  } catch {
    return false;
  }
}

function detectMcpServers() {
  try {
    return execFileSync('claude', ['mcp', 'list'], { encoding: 'utf8', timeout: 15000 })
      .split('\n')
      .filter((line) => /Connected/.test(line))
      .map((line) => line.split(': ').at(0).trim());
  } catch {
    return [];
  }
}

function detectTargetFeatures(targetPath) {
  if (!targetPath || !existsSync(targetPath)) return [];
  const features = [];
  const has = (...paths) => paths.some((path) => existsSync(join(targetPath, path)));
  if (has('src', 'app', 'lib', 'package.json', 'pyproject.toml', 'pom.xml', 'build.gradle')) features.push('source-access');
  if (has('tests', 'test', 'spec', 'playwright.config.ts', 'pytest.ini', 'vitest.config.ts', 'jest.config.js')) features.push('existing-suite');
  if (has('docker-compose.yml', 'docker-compose.yaml', 'compose.yml', 'compose.yaml')) features.push('multi-service');
  const manifests = ['package.json', 'pyproject.toml', 'pom.xml'].filter((path) => existsSync(join(targetPath, path)));
  if (manifests.some((path) => /graphql|grpc|websocket|socket\.io|kafka|rabbitmq|nats/i.test(readFileSync(join(targetPath, path), 'utf8')))) {
    features.push('non-rest-surface');
  }
  if (process.env.DATABASE_URL || process.env.PGHOST || process.env.MYSQL_HOST) features.push('db-access');
  return features;
}

function hasBrowserRuntime(targetPath) {
  if (!targetPath || !existsSync(targetPath)) return false;
  return existsSync(join(targetPath, 'node_modules', 'playwright')) || existsSync(join(targetPath, 'node_modules', '@playwright', 'test'));
}

function isWritableDirectory(path) {
  try {
    if (!statSync(path).isDirectory()) return false;
    accessSync(path, constants.W_OK);
    return true;
  } catch {
    return false;
  }
}

function statSafe(path) {
  try {
    return statSync(path);
  } catch {
    return null;
  }
}

function isWithin(root, path) {
  return path === root || path.startsWith(`${root}${sep}`);
}

function addCheck(checks, id, mandatory, passed, evidence) {
  checks.push({ id, mandatory, status: passed ? 'pass' : mandatory ? 'fail' : 'degraded', evidence });
}

function parseNamedOptions(args, allowed) {
  const options = {};
  for (let index = 0; index < args.length; index += 1) {
    const name = args[index];
    if (!allowed.has(name)) fail(`unknown option: ${name}`);
    const value = args[index + 1];
    if (value == null || value.startsWith('--')) fail(`${name} requires a value`);
    index += 1;
    const key = kebabToCamel(name.slice(2));
    if (Object.hasOwn(options, key)) fail(`duplicate option: ${name}`);
    options[key] = value;
  }
  return options;
}

function loadEngagement(options) {
  const candidate = resolve(options.manifest ?? process.env.ARGUS_ENGAGEMENT_MANIFEST ?? 'ai_agents_internal/engagement.json');
  if (!statSafe(candidate)?.isFile() || lstatSync(candidate).isSymbolicLink()) throw new Error(`engagement manifest must be a real file: ${candidate}`);
  const path = realpathSync(candidate);
  const engagement = readSecureJson(path, 'engagement manifest');
  const errors = validateEngagementManifest(engagement);
  if (errors.length > 0) throw new Error(`invalid manifest ${path}: ${errors.join('; ')}`);
  if (!statSafe(engagement.artifactRoot)?.isDirectory()) throw new Error(`engagement artifactRoot must be an existing directory: ${engagement.artifactRoot}`);
  const physicalArtifactRoot = realpathSync(engagement.artifactRoot);
  if (!safePhysicalPath(physicalArtifactRoot, path)) throw new Error(`engagement manifest escapes its physical artifact root: ${path}`);
  return { manifest: engagement, path };
}

function physicalPathsEquivalent(left, right) {
  try { return realpathSync(resolve(left)) === realpathSync(resolve(right)); }
  catch { return resolve(left) === resolve(right); }
}

function nullablePhysicalPathsEquivalent(left, right) {
  if (left === null || left === undefined || right === null || right === undefined) return left == null && right == null;
  return physicalPathsEquivalent(left, right);
}

function requireOptions(options, required, command) {
  for (const key of required) if (!options[key]) fail(`${command} requires --${camelToKebab(key)}`);
}

function leaseToken(options) {
  const token = options.token ?? process.env.ARGUS_ENGAGEMENT_LEASE_TOKEN;
  if (!token) fail('engagement operation requires --token or ARGUS_ENGAGEMENT_LEASE_TOKEN');
  return token;
}

function readTextInput(input) {
  return input === '-' ? readFileSync(0, 'utf8') : readFileSync(resolve(input), 'utf8');
}

function parsePositiveOption(value, label) {
  if (value == null) return undefined;
  const number = Number(value);
  if (!Number.isFinite(number) || number <= 0) fail(`${label} must be a positive number`);
  return number;
}

function parseBooleanOption(value, label) {
  if (value == null) return undefined;
  if (value === 'true') return true;
  if (value === 'false') return false;
  fail(`${label} must be true or false`);
}

function kebabToCamel(value) {
  return value.replace(/-([a-z])/g, (_, letter) => letter.toUpperCase());
}

function camelToKebab(value) {
  return value.replace(/[A-Z]/g, (letter) => `-${letter.toLowerCase()}`);
}

function nonEmptyString(value) {
  return typeof value === 'string' && value.trim().length > 0;
}

function plainObject(value) {
  return value !== null && typeof value === 'object' && !Array.isArray(value);
}

function validDateTime(value) {
  return typeof value === 'string' && Number.isFinite(Date.parse(value));
}

function stableCanonicalJson(value) {
  if (Array.isArray(value)) return `[${value.map(stableCanonicalJson).join(',')}]`;
  if (value && typeof value === 'object') {
    return `{${Object.keys(value).sort().map((key) => `${JSON.stringify(key)}:${stableCanonicalJson(value[key])}`).join(',')}}`;
  }
  return JSON.stringify(value);
}

function copyTemplate(runtime, destination) {
  const entries = prepareTemplateComposition(runtime);
  if (!destination) fail('copy-template requires an empty destination path');
  const target = resolve(destination);
  try {
    assertActiveEngagementWrites([target], 'copy-template');
    inspectEmptyDestination(target);
    writeTemplateEntries(entries, target);
  } catch (error) {
    fail(error.message);
  }
  console.log(`COPIED  ${runtime} template -> ${target}`);
}

function prepareTemplateComposition(runtime) {
  const composition = manifest.templateCompositions?.[runtime];
  if (!composition) fail('copy-template runtime must be typescript, java, or python');
  const layers = [requireAsset(composition.commonAsset), requireAsset(composition.runtimeAsset)];
  const entries = validateTemplateLayers(runtime, layers);
  for (const asset of layers) assertPackagedAsset(asset, `template layer ${asset.id}`);
  return entries;
}

function writeTemplateEntries(entries, target) {
  mkdirSync(target, { recursive: true });
  if (lstatSync(target).isSymbolicLink() || !lstatSync(target).isDirectory()) {
    throw new Error(`template destination must be a real directory: ${target}`);
  }
  for (const entry of entries.filter((item) => item.type === 'directory')) {
    const output = resolve(target, entry.relativePath);
    if (!isWithin(target, output)) throw new Error(`template output escapes destination: ${entry.relativePath}`);
    if (!existsSync(output)) mkdirSync(output);
    if (lstatSync(output).isSymbolicLink() || !lstatSync(output).isDirectory()) {
      throw new Error(`template output directory is unsafe: ${entry.relativePath}`);
    }
    chmodSync(output, entry.mode);
  }
  for (const entry of entries.filter((item) => item.type === 'file')) {
    const output = resolve(target, entry.relativePath);
    if (!isWithin(target, output)) throw new Error(`template output escapes destination: ${entry.relativePath}`);
    if (existsSync(output)) throw new Error(`refusing to overwrite composed template file: ${entry.relativePath}`);
    const parent = dirname(output);
    if (lstatSync(parent).isSymbolicLink() || !lstatSync(parent).isDirectory()) {
      throw new Error(`template output parent is unsafe: ${entry.relativePath}`);
    }
    copyFileSync(entry.source, output, constants.COPYFILE_EXCL);
    chmodSync(output, entry.mode);
  }
}

function scaffoldTemplateAtomically(selection, destination, entries) {
  const target = resolve(destination);
  const initial = inspectEmptyDestination(target);
  const parent = dirname(target);
  mkdirSync(parent, { recursive: true });
  const temporary = mkdtempSync(join(parent, `.${basename(target)}.argus-scaffold-`));
  let published = false;
  try {
    chmodSync(temporary, 0o700);
    writeTemplateEntries(entries, temporary);
    materializeTemplateLayout(temporary, selection);
    const record = resolve(temporary, 'ai_agents_internal', 'template-selection.json');
    mkdirSync(dirname(record), { recursive: true });
    writeFileSync(record, stableTemplateJson(selection), { mode: 0o600, flag: 'wx' });
    chmodSync(record, 0o600);
    publishScaffold(temporary, target, initial);
    published = true;
  } finally {
    if (!published) rmSync(temporary, { recursive: true, force: true });
  }
}

function publishScaffold(temporary, target, initial) {
  const current = inspectEmptyDestination(target);
  if (current.existed !== initial.existed) throw new Error('template destination changed while scaffold was prepared');
  if (initial.existed && current.mode !== initial.mode) throw new Error('template destination mode changed while scaffold was prepared');
  const finalMode = initial.existed ? initial.mode : (0o777 & ~process.umask());
  chmodSync(temporary, finalMode);
  if (!initial.existed) {
    renameSync(temporary, target);
    return;
  }
  rmdirSync(target);
  try {
    renameSync(temporary, target);
  } catch (error) {
    if (!existsSync(target)) {
      mkdirSync(target, { mode: initial.mode });
      chmodSync(target, initial.mode);
    }
    throw error;
  }
}

function validateTemplateLayers(runtime, layers) {
  if (layers.length !== 2 || layers[0].id !== 'common-template' || layers[1].id !== `${runtime}-template`) {
    fail(`${runtime} template composition is invalid`);
  }
  const declarations = [];
  for (const asset of layers) declarations.push(...scanTemplateLayer(asset));
  const exact = new Map();
  const folded = new Map();
  for (const entry of declarations) {
    const priorCase = folded.get(entry.relativePath.toLocaleLowerCase('en-US'));
    if (priorCase && priorCase !== entry.relativePath) {
      fail(`template composition has a case-insensitive collision: ${priorCase} vs ${entry.relativePath}`);
    }
    folded.set(entry.relativePath.toLocaleLowerCase('en-US'), entry.relativePath);
    const prior = exact.get(entry.relativePath);
    if (prior) {
      if (prior.type !== 'directory' || entry.type !== 'directory') {
        fail(`template composition file collision: ${entry.relativePath}`);
      }
      if (prior.mode !== entry.mode) {
        fail(`template composition directory mode collision: ${entry.relativePath}`);
      }
      continue;
    }
    exact.set(entry.relativePath, entry);
  }
  for (const entry of exact.values()) {
    const parts = entry.relativePath.split('/');
    for (let index = 1; index < parts.length; index += 1) {
      const ancestor = exact.get(parts.slice(0, index).join('/'));
      if (ancestor?.type === 'file') {
        fail(`template composition file/ancestor collision: ${ancestor.relativePath} vs ${entry.relativePath}`);
      }
    }
  }
  return [...exact.values()].sort((left, right) => {
    if (left.type !== right.type) return left.type === 'directory' ? -1 : 1;
    const depth = left.relativePath.split('/').length - right.relativePath.split('/').length;
    return depth || left.relativePath.localeCompare(right.relativePath);
  });
}

function scanTemplateLayer(asset) {
  const root = assetPath(asset);
  if (!existsSync(root) || lstatSync(root).isSymbolicLink() || !lstatSync(root).isDirectory()) {
    fail(`template layer ${asset.id} must be a real directory`);
  }
  const entries = [];
  const visit = (directory, prefix = '') => {
    for (const name of readdirSync(directory).sort()) {
      const source = join(directory, name);
      const relativePath = prefix ? `${prefix}/${name}` : name;
      validateTemplateRelativePath(relativePath);
      const info = lstatSync(source);
      if (info.isSymbolicLink()) fail(`template layer ${asset.id} contains a symbolic link: ${relativePath}`);
      if (info.isDirectory()) {
        entries.push({ type: 'directory', relativePath, source, mode: info.mode & 0o777 });
        visit(source, relativePath);
      } else if (info.isFile()) {
        entries.push({ type: 'file', relativePath, source, mode: info.mode & 0o777 });
      } else {
        fail(`template layer ${asset.id} contains an unsupported entry: ${relativePath}`);
      }
    }
  };
  visit(root);
  return entries;
}

function validateTemplateRelativePath(relativePath) {
  if (!relativePath || relativePath.includes('\\') || relativePath.includes('\0')) {
    fail(`template composition contains an unsafe path: ${relativePath || '(empty)'}`);
  }
  const parts = relativePath.split('/');
  if (parts.some((part) =>
    !part || part === '.' || part === '..' ||
    /[\u0000-\u001f\u007f<>:"|?*]/.test(part) ||
    /[. ]$/.test(part) ||
    /^(?:con|prn|aux|nul|com[1-9]|lpt[1-9])(?:\.|$)/i.test(part)
  )) {
    fail(`template composition contains an unsafe path: ${relativePath}`);
  }
}

function assertPackagedAsset(asset, label) {
  const path = assetPath(asset);
  const stats = treeStats(path);
  if (stats.files !== asset.files || stats.bytes !== asset.bytes || stats.sha256 !== asset.sha256) {
    fail(`${label} differs from the packaged asset manifest`);
  }
}

function copyBrowserDriver(destination) {
  if (!destination) fail('copy-browser-driver requires a target repo path');
  const targetRoot = resolve(destination);
  if (!existsSync(targetRoot) || !statSync(targetRoot).isDirectory()) fail(`target repo directory does not exist: ${targetRoot}`);
  const sourceRoot = assetPath(requireAsset('typescript-template'));
  const scriptsDir = join(targetRoot, 'scripts');
  mkdirSync(scriptsDir, { recursive: true });
  const files = [
    ['scripts/hunt-driver.mjs', 'hunt-driver.mjs'],
    ['scripts/driver.config.example.json', 'driver.config.example.json'],
  ];
  const outputs = [
    ...files.map(([, targetName]) => join(scriptsDir, targetName)),
    join(scriptsDir, 'driver-config.schema.json'),
  ];
  assertActiveEngagementWrites(outputs, 'copy-browser-driver');
  for (const [sourceRelative, targetName] of files) {
    const target = join(scriptsDir, targetName);
    if (existsSync(target)) fail(`refusing to overwrite existing file: ${target}`);
    copyFileSync(join(sourceRoot, sourceRelative), target);
    chmodSync(target, statSync(join(sourceRoot, sourceRelative)).mode & 0o777);
  }
  const schemaTarget = join(scriptsDir, 'driver-config.schema.json');
  if (existsSync(schemaTarget)) fail(`refusing to overwrite existing file: ${schemaTarget}`);
  copyFileSync(assetPath(requireAsset('runtime-schemas'), 'driver-config.schema.json'), schemaTarget);
  console.log(`COPIED  isolated browser driver -> ${scriptsDir}`);
}

function requireAsset(id) {
  if (!id) fail('asset id is required; run argus-assets list');
  const asset = manifest.assets.find((item) => item.id === id);
  if (!asset) fail(`unknown asset id: ${id}; run argus-assets list`);
  return asset;
}

function assetPath(asset, child = '') {
  const path = resolve(ROOT, asset.destination, child);
  if (path !== ROOT && !path.startsWith(`${ROOT}${sep}`)) fail(`asset path escapes plugin root: ${asset.destination}`);
  return path;
}

function atomicPrivateWrite(path, content) {
  mkdirSync(dirname(path), { recursive: true });
  if (existsSync(path)) {
    const existing = lstatSync(path);
    if (existing.isSymbolicLink() || !existing.isFile() || existing.nlink !== 1) {
      throw new Error(`private output must be a single-link regular file: ${path}`);
    }
  }
  const temporary = join(dirname(path), `.${basename(path)}.${process.pid}.${randomBytes(6).toString('hex')}.tmp`);
  try {
    writeFileSync(temporary, content, { mode: 0o600, flag: 'wx' });
    if (existsSync(path)) {
      const current = lstatSync(path);
      if (current.isSymbolicLink() || !current.isFile() || current.nlink !== 1) {
        throw new Error(`private output changed to an unsafe filesystem entry: ${path}`);
      }
    }
    renameSync(temporary, path);
  } finally {
    rmSync(temporary, { force: true });
  }
}

function atomicPrivateAppend(path, content, validateCurrent = undefined) {
  mkdirSync(dirname(path), { recursive: true });
  const lockPath = `${path}.append-lock`;
  let acquired = false;
  for (let attempt = 0; attempt < 6000; attempt += 1) {
    try {
      mkdirSync(lockPath, { mode: 0o700 });
      writeFileSync(join(lockPath, 'owner.json'), `${JSON.stringify({ pid: process.pid, acquiredAt: new Date().toISOString() })}\n`, { flag: 'wx', mode: 0o600 });
      acquired = true;
      break;
    } catch (error) {
      if (error.code !== 'EEXIST') {
        rmSync(lockPath, { recursive: true, force: true });
        throw new Error(`cannot acquire private append lock for ${path}: ${error.message}`);
      }
      const lock = lstatSync(lockPath);
      if (lock.isSymbolicLink() || !lock.isDirectory()) throw new Error(`private append lock is unsafe: ${lockPath}`);
      reclaimAbandonedModelControlLock(lockPath);
      Atomics.wait(new Int32Array(new SharedArrayBuffer(4)), 0, 0, 10);
    }
  }
  if (!acquired) throw new Error(`timed out acquiring private append lock for ${path}`);
  try {
    let current = '';
    if (existsSync(path)) {
      let descriptor;
      try {
        descriptor = openSync(path, constants.O_RDONLY | (constants.O_NOFOLLOW ?? 0));
        const info = fstatSync(descriptor);
        if (!info.isFile() || info.nlink !== 1) throw new Error(`private append target must be a single-link regular file: ${path}`);
        current = readFileSync(descriptor, 'utf8');
      } finally {
        if (descriptor !== undefined) closeSync(descriptor);
      }
    }
    if (validateCurrent) validateCurrent(current);
    atomicPrivateWrite(path, `${current}${content}`);
  } finally {
    rmSync(lockPath, { recursive: true, force: true });
  }
}

function assertActiveEngagementWrites(paths, label) {
  const discovered = locateEngagementManifest(process.cwd());
  const explicit = process.env.ARGUS_ENGAGEMENT_MANIFEST
    ? locateEngagementManifest(process.cwd(), process.env.ARGUS_ENGAGEMENT_MANIFEST)
    : null;
  if (process.env.ARGUS_ENGAGEMENT_MANIFEST && !explicit) fail(`${label} denied because ARGUS_ENGAGEMENT_MANIFEST does not name an existing manifest`);
  if (discovered && explicit && discovered !== explicit) fail(`${label} denied because the explicit engagement differs from the active working-tree engagement`);
  const manifestPath = explicit ?? discovered;
  if (!manifestPath) return;
  const engagement = readSecureJson(manifestPath, 'active engagement manifest');
  const errors = validateEngagementManifest(engagement);
  if (errors.length > 0) fail(`${label} denied because the active engagement manifest is invalid: ${errors.join('; ')}`);
  for (const candidate of paths) {
    const payload = { tool_name: 'Write', tool_input: { file_path: resolve(candidate) } };
    const decision = evaluateWriteGuard({ manifest: engagement, manifestPath, payload, cwd: process.cwd() });
    if (decision.decision !== 'deny') continue;
    const patterns = readJson(REDACTION_PATTERNS_PATH);
    const patternErrors = validateRedactionPatterns(patterns);
    if (patternErrors.length > 0) fail(`${label} denied and guard audit patterns are invalid: ${patternErrors.join('; ')}`);
    const event = redactValue(buildGuardAudit({ manifest: engagement, payload, decision, timestamp: new Date().toISOString() }), patterns).value;
    const auditPath = resolve(engagement.artifactRoot, engagement.writePolicy.auditPath);
    if (!safePhysicalPath(engagement.artifactRoot, auditPath)) fail(`${label} denied and the guard audit path is unsafe`);
    try {
      atomicPrivateAppend(auditPath, `${JSON.stringify(event)}\n`);
    } catch (error) {
      fail(`${label} denied and guard audit failed closed: ${error.message}`);
    }
    fail(`${label} denied by active engagement rule ${decision.ruleId}: ${decision.reason}`);
  }
}

function inspectEmptyDestination(path) {
  if (!existsSync(path)) return { existed: false, mode: null };
  const info = lstatSync(path);
  if (info.isSymbolicLink()) throw new Error(`destination cannot be a symbolic link: ${path}`);
  if (!info.isDirectory()) throw new Error(`destination is not a directory: ${path}`);
  if (readdirSync(path).length > 0) throw new Error(`refusing to copy into non-empty destination: ${path}`);
  return { existed: true, mode: info.mode & 0o777 };
}

function treeStats(path) {
  const isFile = statSync(path).isFile();
  const files = isFile ? [path] : walkFiles(path);
  const hash = createHash('sha256');
  let bytes = 0;
  for (const file of files.sort()) {
    const rel = isFile ? file.split(sep).at(-1) : relative(path, file).split(sep).join('/');
    const content = readFileSync(file);
    bytes += content.length;
    hash.update('file\0');
    hash.update(rel);
    hash.update('\0');
    hash.update(statSync(file).mode & 0o111 ? 'x' : '-');
    hash.update('\0');
    hash.update(content);
  }
  return { files: files.length, bytes, sha256: hash.digest('hex') };
}

function walkFiles(dir) {
  const out = [];
  for (const name of readdirSync(dir).sort()) {
    const path = join(dir, name);
    const stat = lstatSync(path);
    if (stat.isSymbolicLink()) fail(`unsupported symbolic link in plugin: ${path}`);
    if (stat.isDirectory()) out.push(...walkFiles(path));
    else if (stat.isFile()) out.push(path);
    else fail(`unsupported filesystem entry in plugin: ${path}`);
  }
  return out;
}

function resolveExistingPhysicalInput(input, base = process.cwd()) {
  const candidate = resolve(base, input);
  if (!existsSync(candidate) || lstatSync(candidate).isSymbolicLink()) return candidate;
  return realpathSync(candidate);
}

function readJson(path) {
  try {
    return JSON.parse(readFileSync(path, 'utf8'));
  } catch (error) {
    fail(`cannot parse ${path}: ${error.message}`);
  }
}

function readSecureSingleLink(path, label) {
  let before;
  try { before = lstatSync(path); }
  catch (error) { fail(`${label} is unavailable: ${error.message}`); }
  if (!before.isFile() || before.isSymbolicLink() || before.nlink !== 1) fail(`${label} must be a non-aliased regular file`);
  let descriptor;
  try {
    descriptor = openSync(path, constants.O_RDONLY | (constants.O_NOFOLLOW ?? 0));
    const opened = fstatSync(descriptor);
    if (!opened.isFile() || opened.nlink !== 1 || opened.dev !== before.dev || opened.ino !== before.ino) fail(`${label} changed during secure open`);
    const raw = readFileSync(descriptor);
    const after = fstatSync(descriptor);
    const linked = lstatSync(path);
    if (!linked.isFile() || linked.isSymbolicLink() || linked.nlink !== 1 || linked.dev !== opened.dev || linked.ino !== opened.ino ||
        after.dev !== opened.dev || after.ino !== opened.ino || after.size !== opened.size || after.mtimeMs !== opened.mtimeMs || after.ctimeMs !== opened.ctimeMs) {
      fail(`${label} changed during secure read`);
    }
    return raw;
  } finally {
    if (descriptor !== undefined) closeSync(descriptor);
  }
}

function readSecureJson(path, label) {
  const raw = readSecureSingleLink(path, label);
  try { return JSON.parse(raw.toString('utf8')); }
  catch (error) { fail(`${label} is not valid JSON: ${error.message}`); }
}

function fail(message) {
  console.error(`FAIL  ${message}`);
  process.exit(1);
}
