  const { manifest: engagement } = loadEngagement(options);
  console.log(JSON.stringify(mergeCanonical(engagement, options.owner, leaseToken(options), options.canonical)));
  return 0;
}

function engagementId(args) {
  const options = parseNamedOptions(args, new Set(['--manifest', '--lane', '--token', '--kind', '--identity']));
  requireOptions(options, ['manifest', 'lane', 'kind', 'identity'], 'engagement id');
  const { manifest: engagement } = loadEngagement(options);
  console.log(allocateId(engagement, options.lane, leaseToken(options), options.kind, options.identity));
  return 0;
}

function engagementCheckpoint(args) {
  const options = parseNamedOptions(args, new Set(['--manifest', '--lane', '--token', '--phase', '--sequence', '--input']));
  requireOptions(options, ['manifest', 'lane', 'phase', 'sequence', 'input'], 'engagement checkpoint');
  const sequence = Number(options.sequence);
  const raw = readTextInput(options.input);
  let payload;
  try { payload = JSON.parse(raw); }
  catch { payload = { text: raw }; }
  const { manifest: engagement } = loadEngagement(options);
  console.log(JSON.stringify(writeCheckpoint(engagement, options.lane, leaseToken(options), options.phase, sequence, payload)));
  return 0;
}

function engagementBarrier(args) {
  const [operation, ...rest] = args;
  const options = parseNamedOptions(rest, new Set(['--manifest', '--lane', '--token', '--phase']));
  const { manifest: engagement } = loadEngagement(options);
  if (operation === 'status') {
    console.log(JSON.stringify(getBarrierStatus(engagement, options.phase), null, 2));
    return 0;
  }
  if (operation === 'arrive') {
    requireOptions(options, ['lane', 'phase'], 'engagement barrier arrive');
    console.log(JSON.stringify(arriveBarrier(engagement, options.lane, leaseToken(options), options.phase)));
    return 0;
  }
  if (operation === 'advance') {
    requireOptions(options, ['lane'], 'engagement barrier advance');
    console.log(JSON.stringify(advanceBarrier(engagement, options.lane, leaseToken(options))));
    return 0;
  }
  fail('usage: argus-assets engagement barrier <arrive|status|advance> [options]');
}

function engagementCleanup(args) {
  const options = parseNamedOptions(args, new Set(['--manifest', '--lane', '--token', '--outcome']));
  requireOptions(options, ['manifest', 'lane', 'outcome'], 'engagement cleanup');
  const { manifest: engagement } = loadEngagement(options);
  console.log(JSON.stringify(cleanupWorker(engagement, options.lane, leaseToken(options), options.outcome)));
  return 0;
}

function guardCommand(args) {
  if (args.length > 0) fail('usage: argus-assets guard');
  const raw = readFileSync(0, 'utf8');
  let payload;
  try { payload = JSON.parse(raw); }
  catch { return denyHook('GUARD-MANIFEST-INVALID', 'PreToolUse payload is not valid JSON'); }
  const cwd = resolve(payload.cwd ?? process.cwd());
  const manifestPath = locateEngagementManifest(cwd, process.env.ARGUS_ENGAGEMENT_MANIFEST);
  if (!manifestPath) return 0;
  let engagement;
  try { engagement = JSON.parse(readFileSync(manifestPath, 'utf8')); }
  catch { return denyHook('GUARD-MANIFEST-INVALID', 'engagement manifest is not valid JSON'); }
  const errors = validateEngagementManifest(engagement);
  if (errors.length > 0) return denyHook('GUARD-MANIFEST-INVALID', errors.join('; '));
  const decision = evaluateWriteGuard({
    manifest: engagement,
    manifestPath,
    payload,
    cwd,
    bypassToken: process.env.ARGUS_IMMUTABILITY_BYPASS_TOKEN,
  });
  if (decision.decision === 'deny' || decision.ruleId === 'GUARD-EXPLICIT-BYPASS') {
    const patterns = readJson(REDACTION_PATTERNS_PATH);
    const event = redactValue(buildGuardAudit({ manifest: engagement, payload, decision, timestamp: new Date().toISOString() }), patterns).value;
    const auditPath = resolve(engagement.artifactRoot, engagement.writePolicy.auditPath);
    if (!isWithin(engagement.artifactRoot, auditPath)) return denyHook('GUARD-MANIFEST-INVALID', 'guard audit path escapes artifact root');
    mkdirSync(dirname(auditPath), { recursive: true });
    appendFileSync(auditPath, `${JSON.stringify(event)}\n`, { mode: 0o600 });
    chmodSync(auditPath, 0o600);
  }
  if (decision.decision === 'deny') return denyHook(decision.ruleId, `${decision.reason}; audit=${engagement.writePolicy.auditPath}`);
  return 0;
}

function denyHook(ruleId, reason) {
  console.log(JSON.stringify({
    hookSpecificOutput: {
      hookEventName: 'PreToolUse',
      permissionDecision: 'deny',
      permissionDecisionReason: `${ruleId}: ${String(reason).replace(/[\r\n]+/g, ' ')}`,
    },
  }));
  return 0;
}

function initializeAuthorization(args) {
  const options = parseNamedOptions(args, new Set(['--target', '--environment', '--output', '--engagement-id']));
  if (!options.target) fail('authorization init requires --target');
  const environment = options.environment ?? 'unknown';
  if (!['unknown', 'development', 'test', 'staging', 'production'].includes(environment)) {
    fail('authorization init --environment must be unknown, development, test, staging, or production');
  }
  const output = resolve(options.output ?? 'ai_agents_internal/authorization.json');
  if (existsSync(output)) fail(`refusing to overwrite existing authorization manifest: ${output}`);
  const template = readJson(AUTHORIZATION_TEMPLATE_PATH);
  const authorization = createDefaultAuthorization({
    template,
    target: options.target,
    environment,
    engagementId: options.engagementId,
  });
  const errors = validateAuthorizationManifest(authorization);
  if (errors.length > 0) fail(`generated authorization manifest is invalid: ${errors.join('; ')}`);
  mkdirSync(dirname(output), { recursive: true });
  writeFileSync(output, `${JSON.stringify(authorization, null, 2)}\n`, { mode: 0o600 });
  chmodSync(output, 0o600);
  console.log(`AUTHORIZATION  initialized default-deny manifest=${output} sha256=${manifestSha256(authorization)}`);
  return 0;
}

function checkAuthorization(args) {
  const options = parseNamedOptions(args, new Set([
    '--manifest', '--lane', '--action', '--target', '--source-trust', '--account',
    '--namespace', '--mutation', '--classification', '--rate', '--concurrency',
    '--total-requests', '--duration', '--resource', '--at', '--binary-reviewed',
  ]));
  for (const required of ['manifest', 'lane', 'action', 'target', 'sourceTrust']) {
    if (!options[required]) fail(`authorization check requires --${camelToKebab(required)}`);
  }
  const manifestPath = resolve(options.manifest);
  const authorization = readJson(manifestPath);
  const patterns = readJson(REDACTION_PATTERNS_PATH);
  const patternErrors = validateRedactionPatterns(patterns);
  if (patternErrors.length > 0) fail(`packaged redaction patterns are invalid: ${patternErrors.join('; ')}`);
  const request = {
    lane: options.lane,
    action: options.action,
    target: options.target,
    sourceTrust: options.sourceTrust,
    account: options.account,
    namespace: options.namespace,
    mutation: options.mutation,
    classification: options.classification,
    binaryReviewed: parseBooleanOption(options.binaryReviewed, '--binary-reviewed'),
    rate: parsePositiveOption(options.rate, '--rate'),
    concurrency: parsePositiveOption(options.concurrency, '--concurrency'),
    totalRequests: parsePositiveOption(options.totalRequests, '--total-requests'),
    duration: parsePositiveOption(options.duration, '--duration'),
    resource: options.resource,
  };
  const timestamp = options.at ?? new Date().toISOString();
  const decision = evaluateAuthorization({ manifest: authorization, request, now: timestamp });
  const auditName = nonEmptyString(authorization.audit?.path) && !authorization.audit.path.includes('/')
    ? authorization.audit.path
    : 'authorization-audit.jsonl';
  const auditPath = resolve(dirname(manifestPath), auditName);
  const auditManifest = { ...authorization, engagementId: authorization.engagementId ?? 'INVALID-MANIFEST' };
  const event = buildAuditEvent({ manifest: auditManifest, request, decision, timestamp, patterns });
  appendFileSync(auditPath, `${JSON.stringify(event)}\n`, { mode: 0o600 });
  chmodSync(auditPath, 0o600);
  const safeReason = redactText(decision.reason, patterns).text.replace(/[\r\n]+/g, ' ');
  console.log(`AUTHORIZATION  ${decision.decision.toUpperCase()} rule=${decision.ruleId} reason=${safeReason} audit=${auditPath}`);
  return decision.decision === 'allow' ? 0 : 3;
}

function redactCommand(args) {
  const options = parseNamedOptions(args, new Set(['--input', '--output']));
  const input = options.input ?? '-';
  const output = options.output ?? '-';
  const buffer = input === '-' ? readFileSync(0) : readFileSync(resolve(input));
  if (isBinaryBuffer(buffer)) {
    console.error('REDACTION  DENY rule=AUTH-REDACTION-REQUIRED reason=binary evidence requires approved masking and independent review');
    return 4;
  }
  const patterns = readJson(REDACTION_PATTERNS_PATH);
  const errors = validateRedactionPatterns(patterns);
  if (errors.length > 0) fail(`packaged redaction patterns are invalid: ${errors.join('; ')}`);
  const source = buffer.toString('utf8');
  let redacted;
  let findings;
  try {
    const parsed = JSON.parse(source);
    const result = redactValue(parsed, patterns);
    redacted = `${JSON.stringify(result.value, null, 2)}\n`;
    findings = result.findings;
  } catch {
    const result = redactText(source, patterns);
    redacted = result.text;
    findings = result.findings;
  }
  if (output === '-') {
    process.stdout.write(redacted);
  } else {
    const outputPath = resolve(output);
    mkdirSync(dirname(outputPath), { recursive: true });
    writeFileSync(outputPath, redacted, { mode: 0o600 });
    chmodSync(outputPath, 0o600);
    console.log(`REDACTION  wrote=${outputPath} findings=${findings.length}`);
  }
  return 0;
}

function printPath(id) {
  const asset = requireAsset(id);
  console.log(assetPath(asset));
}

function verify() {
  try {
    const stats = verifyRuntimeAssets();
    console.log(`PASS  ${stats.assets} assets verified (${stats.assetBytes} bytes); plugin ${stats.pluginBytes} bytes`);
  } catch (error) {
    fail(error.message);
  }
}

function verifyRuntimeAssets() {
  let assetBytes = 0;
  for (const asset of manifest.assets) {
    const path = assetPath(asset);
    if (!existsSync(path)) throw new Error(`missing packaged asset: ${asset.id} (${asset.destination})`);
    const stats = treeStats(path);
    if (stats.files !== asset.files || stats.bytes !== asset.bytes || stats.sha256 !== asset.sha256) {
      throw new Error(`packaged asset hash mismatch: ${asset.id}`);
    }
    assetBytes += stats.bytes;
  }
  if (assetBytes > manifest.budgets.generatedAssetsBytes) {
    throw new Error(`generated asset budget exceeded: ${assetBytes} > ${manifest.budgets.generatedAssetsBytes}`);
  }
  const pluginBytes = treeStats(ROOT).bytes;
  if (pluginBytes > manifest.budgets.installedPluginBytes) {
    throw new Error(`installed plugin budget exceeded: ${pluginBytes} > ${manifest.budgets.installedPluginBytes}`);
  }
  if (!existsSync(INVENTORY_PATH)) throw new Error('missing runtime-reference-inventory.json');
  const inventory = readJson(INVENTORY_PATH);
  if (inventory.agentsScanned !== 27) throw new Error(`runtime inventory covers ${inventory.agentsScanned} agents; expected 27`);
  return { assets: manifest.assets.length, assetBytes, pluginBytes };
}

async function preflight(argv) {
  const options = parsePreflightOptions(argv);
  const inventory = readJson(INVENTORY_PATH);
  const profile = options.profile ? readJson(resolve(options.profile)) : {};
  const mode = options.mode ?? 'A';
  if (!['A', 'B', 'C', 'D'].includes(mode)) fail('preflight --mode must be A, B, C, or D');
  if (!options.target) fail('preflight requires --target <url-or-path>');
  const selectedSlugs = new Set(matrix.agents.filter((agent) => agent.modes.includes(mode)).map((agent) => agent.slug));
  for (const feature of options.features) {
    if (!Object.hasOwn(matrix.capabilities, feature)) fail(`unknown preflight feature: ${feature}`);
  }

  const target = await inspectTarget(options.target, profile);
  const targetPath = target.kind === 'path' ? resolve(options.target) : null;
  const artifactRootPath = resolve(options.artifactRoot ?? (targetPath && statSafe(targetPath)?.isDirectory() ? targetPath : process.cwd()));
  const outputRelative = options.output ?? 'ai_agents_internal/preflight.json';
  const requestedOutputPath = resolve(artifactRootPath, outputRelative);
  const fallbackOutputPath = resolve(artifactRootPath, 'ai_agents_internal/preflight.json');
  const requestedOutputSafe = isWithin(artifactRootPath, requestedOutputPath);
  const outputPath = requestedOutputSafe ? requestedOutputPath : fallbackOutputPath;
  const contractedArtifactPaths = [
    ...matrix.orchestration.artifactPaths,
    ...matrix.agents.flatMap((agent) => agent.artifactPaths),
  ];
  const safePaths = requestedOutputSafe && contractedArtifactPaths.every((path) => {
    const stablePrefix = path.replace(/[*?].*$/, '').replace(/\/$/, '');
    return isWithin(artifactRootPath, resolve(artifactRootPath, stablePrefix));
  });
  const artifactWritable = typeof profile.artifactWritable === 'boolean'
    ? profile.artifactWritable
    : isWritableDirectory(artifactRootPath);

  const authorizationEnvironment = options.environment ?? profile.environment ?? 'unknown';
  if (!['unknown', 'development', 'test', 'staging', 'production'].includes(authorizationEnvironment)) {
    fail('preflight --environment must be unknown, development, test, staging, or production');
  }
  const requestedAuthorizationPath = resolve(artifactRootPath, options.authorization ?? 'ai_agents_internal/authorization.json');
  const authorizationPathSafe = isWithin(artifactRootPath, requestedAuthorizationPath);
  let authorization = null;
  let authorizationCreated = false;
  const authorizationErrors = [];
  if (!authorizationPathSafe) {
    authorizationErrors.push('authorization manifest path escapes the artifact root');
  } else if (existsSync(requestedAuthorizationPath)) {
    try {
      authorization = JSON.parse(readFileSync(requestedAuthorizationPath, 'utf8'));
    } catch (error) {
      authorizationErrors.push(`authorization manifest is not valid JSON: ${error.message}`);
    }
  } else if (options.authorization) {
    authorizationErrors.push(`supplied authorization manifest is missing: ${requestedAuthorizationPath}`);
  } else if (!artifactWritable) {
    authorizationErrors.push('artifact root is not writable; cannot create default authorization manifest');
  } else {
    authorization = createDefaultAuthorization({
      template: readJson(AUTHORIZATION_TEMPLATE_PATH),
      target: options.target,
      environment: authorizationEnvironment,
      engagementId: options.engagementId,
    });
    mkdirSync(dirname(requestedAuthorizationPath), { recursive: true });
    writeFileSync(requestedAuthorizationPath, `${JSON.stringify(authorization, null, 2)}\n`, { mode: 0o600 });
    chmodSync(requestedAuthorizationPath, 0o600);
    authorizationCreated = true;
  }
  if (authorization) authorizationErrors.push(...validateAuthorizationManifest(authorization));
  const authorizationAuditPath = authorization && nonEmptyString(authorization.audit?.path)
    ? resolve(dirname(requestedAuthorizationPath), authorization.audit.path)
    : resolve(dirname(requestedAuthorizationPath), 'authorization-audit.jsonl');
  const authorizationAuditPathSafe = isWithin(artifactRootPath, authorizationAuditPath);
  if (!authorizationAuditPathSafe) authorizationErrors.push('authorization audit path escapes the artifact root');
  const production = authorization
    ? detectProductionLike(authorization.target, options.target)
    : { productionLike: true, signals: ['invalid-authorization-manifest'] };
  const authorizationSummary = {
    manifestPath: requestedAuthorizationPath,
    auditPath: authorizationAuditPath,
    sha256: authorization ? manifestSha256(authorization) : null,
    created: authorizationCreated,
    environment: authorization?.target?.environment ?? authorizationEnvironment,
    productionLike: production.productionLike,
    productionSignals: production.signals,
    defaultReadOnly: !authorization || Object.values(authorization.actionGrants ?? {}).every((grant) => !grant.enabled),
  };

  const requestedEngagementPath = resolve(artifactRootPath, options.engagement ?? 'ai_agents_internal/engagement.json');
  const engagementPathSafe = isWithin(artifactRootPath, requestedEngagementPath);
  let engagement = null;
  let engagementCreated = false;
  let engagementState = null;
  const engagementErrors = [];
  if (!engagementPathSafe) {
    engagementErrors.push('engagement manifest path escapes the artifact root');
  } else if (existsSync(requestedEngagementPath)) {
    try { engagement = JSON.parse(readFileSync(requestedEngagementPath, 'utf8')); }
    catch (error) { engagementErrors.push(`engagement manifest is not valid JSON: ${error.message}`); }
  } else if (options.engagement) {
    engagementErrors.push(`supplied engagement manifest is missing: ${requestedEngagementPath}`);
  } else if (!artifactWritable) {
    engagementErrors.push('artifact root is not writable; cannot create engagement manifest');
  } else if (!authorization || authorizationErrors.length > 0) {
    engagementErrors.push('valid authorization manifest is required before engagement initialization');
  } else {
    engagement = createDefaultEngagement({
      template: readJson(ENGAGEMENT_TEMPLATE_PATH),
      target: options.target,
      targetRoot: targetPath,
      artifactRoot: artifactRootPath,
      mode,
      engagementId: authorization.engagementId,
      selectedAgents: [...selectedSlugs],
    });
    mkdirSync(dirname(requestedEngagementPath), { recursive: true });
    writeFileSync(requestedEngagementPath, `${JSON.stringify(engagement, null, 2)}\n`, { mode: 0o600 });
    chmodSync(requestedEngagementPath, 0o600);
    engagementCreated = true;
  }
  if (engagement) {
    engagementErrors.push(...validateEngagementManifest(engagement));
    if (engagement.mode !== mode) engagementErrors.push(`engagement mode ${engagement.mode} does not match preflight mode ${mode}`);
    if (typeof engagement.artifactRoot !== 'string' || resolve(engagement.artifactRoot) !== artifactRootPath) engagementErrors.push('engagement artifactRoot does not match preflight artifact root');
    if (engagement.engagementId !== authorization?.engagementId) engagementErrors.push('engagementId does not match authorization manifest');
    if (!Array.isArray(engagement.selectedAgents) || JSON.stringify([...engagement.selectedAgents].sort()) !== JSON.stringify([...selectedSlugs].sort())) engagementErrors.push('engagement selectedAgents do not match the selected mode');
    if (engagementErrors.length === 0) {
      try { engagementState = initializeEngagementState(engagement); }
      catch (error) { engagementErrors.push(`engagement state initialization failed: ${error.message}`); }
    }
  }
  const engagementUsable = engagement && engagementErrors.length === 0;
  const engagementSummary = {
    manifestPath: requestedEngagementPath,
    statePath: engagementUsable ? resolve(engagement.artifactRoot, engagement.statePath) : resolve(artifactRootPath, 'ai_agents_internal/engagement-state.json'),
    immutabilityAuditPath: engagementUsable ? resolve(engagement.artifactRoot, engagement.writePolicy.auditPath) : resolve(artifactRootPath, 'ai_agents_internal/immutability-audit.jsonl'),
    sha256: engagementUsable ? createHash('sha256').update(JSON.stringify(engagement)).digest('hex') : null,
    created: engagementCreated,
    stateCreated: engagementState?.created ?? false,
    phase: engagementState?.state.currentPhase ?? null,
    selectedAgents: engagementUsable ? engagement.selectedAgents.length : 0,
    hookPath: HOOKS_PATH,
    hookPackaged: existsSync(HOOKS_PATH),
  };

  const availableTools = new Set(profile.availableTools ?? matrix.supportedBuiltinTools);
  const commandAvailability = detectCommands(inventory, profile);
  const mcpServers = profile.mcpServers ?? detectMcpServers();
  const detectedFeatures = new Set([
    ...(Array.isArray(profile.features) ? profile.features : detectTargetFeatures(targetPath)),
    ...options.features,
  ]);

  const capabilityState = {};
  for (const [id, definition] of Object.entries(matrix.capabilities)) {
    let available = detectedFeatures.has(id);
    let evidence = available ? `target/profile feature confirmed: ${id}` : `target/profile feature not detected: ${id}`;
    if (definition.kind === 'mcp') {
      const match = mcpServers.find((server) => definition.serverPatterns.some((pattern) => server.includes(pattern)));
      available = Boolean(match);
      evidence = match ? `connected MCP server: ${match}` : `no connected MCP server matched ${definition.serverPatterns.join(', ')}`;
    }
    if (id === 'browser-runtime' && !available) {
      available = hasBrowserRuntime(targetPath);
      evidence = available
        ? 'target has an installed Playwright runtime and packaged isolated driver is available'
        : 'no installed Playwright runtime detected at target root';
    }
    capabilityState[id] = { available, evidence };
  }

  const checks = [];
  addCheck(checks, 'target-reachable', true, target.reachable, target.evidence);
  addCheck(checks, 'artifact-root-writable', true, artifactWritable, artifactWritable ? `writable: ${artifactRootPath}` : `not writable: ${artifactRootPath}`);
  addCheck(checks, 'artifact-paths-safe', true, safePaths, safePaths ? 'all contracted paths remain under the artifact root' : 'a contracted or output path escapes the artifact root');
  addCheck(
    checks,
    'authorization-manifest',
    true,
    authorizationErrors.length === 0,
    authorizationErrors.length === 0
      ? `${authorizationCreated ? 'created default-deny' : 'loaded'} manifest sha256=${authorizationSummary.sha256}`
      : authorizationErrors.join('; '),
  );
  addCheck(
    checks,
    'engagement-manifest',
    true,
    engagementErrors.length === 0,
    engagementErrors.length === 0
      ? `${engagementCreated ? 'created' : 'loaded'} manifest sha256=${engagementSummary.sha256}; phase=${engagementSummary.phase}`
      : engagementErrors.join('; '),
  );
  addCheck(
    checks,
    'path-immutability-hook',
    true,
    engagementSummary.hookPackaged,
    engagementSummary.hookPackaged ? `packaged PreToolUse hook: ${HOOKS_PATH}` : 'plugin hooks/hooks.json is missing',
  );
  if (authorization && authorizationErrors.length === 0) {
    const boundaryDecision = evaluateAuthorization({
      manifest: authorization,
      request: { lane: 'odysseus', action: 'read', target: options.target, sourceTrust: 'manifest' },
      now: profile.generatedAt ?? new Date().toISOString(),
    });
    addCheck(checks, 'authorization-target-boundary', true, boundaryDecision.decision === 'allow', `${boundaryDecision.ruleId}: ${boundaryDecision.reason}`);
  } else {
    addCheck(checks, 'authorization-target-boundary', true, false, 'authorization manifest unavailable or invalid');
  }
  try {
    const assetStats = verifyRuntimeAssets();
    addCheck(checks, 'packaged-assets', true, true, `${assetStats.assets} assets and hashes verified`);
  } catch (error) {
    addCheck(checks, 'packaged-assets', true, false, error.message);
  }
  for (const tool of matrix.orchestration.requiredTools) {
    addCheck(checks, `tool:${tool}`, true, availableTools.has(tool), availableTools.has(tool) ? 'available' : 'unavailable');
  }
  for (const [id, state] of Object.entries(capabilityState)) {
    addCheck(checks, `capability:${id}`, false, state.available, state.evidence);
  }
  for (const [command, state] of Object.entries(commandAvailability)) {
    const consumers = inventory.commandReferences.find((item) => item.value === command)?.consumers ?? [];
    if (consumers.some((consumer) => selectedSlugs.has(consumer))) {
      addCheck(checks, `command:${command}`, false, state.available, state.evidence);
    }
  }

  const commandConsumers = new Map(inventory.commandReferences.map((item) => [item.value, new Set(item.consumers)]));
  const mandatoryFailure = checks.some((check) => check.mandatory && check.status === 'fail');
  const authorizationByAgent = new Map(matrix.agents.map((contract) => [
    contract.slug,
    evaluateRiskAuthorizations(contract, authorization, options.target, profile.generatedAt ?? new Date().toISOString()),
  ]));
  const agents = matrix.agents.map((contract) => evaluateAgent({
    contract,
    mode,
    availableTools,
    capabilityState,
    commandAvailability,
    commandConsumers,
    matrix,
    mandatoryFailure,
    authorizationDecisions: authorizationByAgent.get(contract.slug),
  }));
  const selectedAgents = agents.filter((agent) => agent.selected);
  const summary = {
    selected: selectedAgents.length,
    ready: selectedAgents.filter((agent) => agent.status === 'ready').length,
    degraded: selectedAgents.filter((agent) => agent.status === 'degraded').length,
    deferred: selectedAgents.filter((agent) => agent.status === 'deferred').length,
    skipped: selectedAgents.filter((agent) => agent.status === 'skipped').length,
    blocked: selectedAgents.filter((agent) => agent.status === 'blocked').length,
    dispatchable: selectedAgents.filter((agent) => agent.dispatchAllowed).length,
  };
  const status = mandatoryFailure || summary.blocked > 0
    ? 'blocked'
    : summary.degraded + summary.deferred + summary.skipped > 0
      ? 'degraded'
      : 'ready';

  const report = {
    $schema: 'https://raw.githubusercontent.com/holi87/holak-teams/master/argus/schemas/preflight-report.schema.json',
    schemaVersion: 1,
    generatedAt: profile.generatedAt ?? new Date().toISOString(),
    mode,
    status,
    target,
    artifactRoot: { path: artifactRootPath, writable: artifactWritable, safePaths },
    authorization: authorizationSummary,
    engagement: engagementSummary,
    checks,
    capabilities: Object.entries(capabilityState).map(([id, state]) => ({ id, ...state })),
    agents,
    summary,
  };

  let persisted = false;
  if (artifactWritable && isWithin(artifactRootPath, outputPath)) {
    mkdirSync(dirname(outputPath), { recursive: true });
    writeFileSync(outputPath, `${JSON.stringify(report, null, 2)}\n`);
    persisted = true;
  }
  if (options.json) console.log(JSON.stringify(report, null, 2));
  console.log(
    `PREFLIGHT  ${status} mode=${mode} selected=${summary.selected} dispatchable=${summary.dispatchable} ` +
    `degraded=${summary.degraded} deferred=${summary.deferred} skipped=${summary.skipped} blocked=${summary.blocked} ` +
    `report=${persisted ? outputPath : 'NOT_PERSISTED'}`,
  );
  return status === 'blocked' ? 2 : 0;
}

function evaluateAgent({ contract, mode, availableTools, capabilityState, commandAvailability, commandConsumers, matrix, mandatoryFailure, authorizationDecisions }) {
  const selected = contract.modes.includes(mode);
  if (!selected) return agentResult(contract, false, 'not-selected', false, [], [], [], contract.artifactPaths, authorizationDecisions);
  if (mandatoryFailure) {
    return agentResult(contract, true, 'blocked', false, [], [], ['Orchestration preflight failed; no specialist may be dispatched.'], contract.artifactPaths, authorizationDecisions);
  }

  const missingTools = contract.requiredTools.filter((tool) => !availableTools.has(tool));
  const missingRequired = (contract.requiredCapabilities ?? []).filter((id) => !capabilityState[id]?.available);
  const missingOptional = (contract.optionalCapabilities ?? []).filter((id) => !capabilityState[id]?.available);
  const missingCommands = Object.entries(commandAvailability)
    .filter(([command, state]) => !state.available && commandConsumers.get(command)?.has(contract.slug))
    .map(([command]) => `command:${command}`);
  const actions = [];

  if (missingTools.length > 0) {
    actions.push(`Mandatory tools unavailable: ${missingTools.join(', ')}. Stop before dispatch.`);
    return agentResult(contract, true, 'blocked', false, missingTools, [...missingRequired, ...missingOptional, ...missingCommands], actions, contract.artifactPaths, authorizationDecisions);
  }

  let status = 'ready';
  for (const id of missingRequired) {
    const capability = matrix.capabilities[id];
    actions.push(`${id}: ${capability.fallback}`);
    if (capability.missingDisposition === 'skipped') status = 'skipped';
    else if (status !== 'skipped') status = 'deferred';
  }
  for (const id of missingOptional) {
    actions.push(`${id}: ${matrix.capabilities[id].fallback}`);
    if (status === 'ready') status = 'degraded';
  }
  if (missingCommands.length > 0) {
    actions.push(`Optional host commands unavailable: ${missingCommands.map((item) => item.slice(8)).join(', ')}; use an available equivalent or record the probe as skipped.`);
    if (status === 'ready') status = 'degraded';
  }
  const deniedAuthorizations = authorizationDecisions.filter((decision) => decision.decision === 'deny');
  if (deniedAuthorizations.length > 0) {
    actions.push(...deniedAuthorizations.map((decision) => (
      `Authorization denied ${decision.action}: ${decision.ruleId} — ${decision.reason}. Restrict the lane to its allowed read-only actions.`
    )));
    if (status === 'ready') status = 'degraded';
  }
  return agentResult(
    contract,
    true,
    status,
    status === 'ready' || status === 'degraded',
    [],
    [...missingRequired, ...missingOptional, ...missingCommands],
    actions,
    contract.artifactPaths,
    authorizationDecisions,
  );
}

function agentResult(contract, selected, status, dispatchAllowed, missingTools, missingCapabilities, actions, artifactPaths, authorization) {
  return { slug: contract.slug, lane: contract.lane, selected, status, dispatchAllowed, missingTools, missingCapabilities, actions, artifactPaths, authorization };
}

function evaluateRiskAuthorizations(contract, authorization, target, now) {
  if (!authorization) {
    return (contract.riskActions ?? []).map((action) => ({
      action,
      decision: 'deny',
      ruleId: 'AUTH-MANIFEST-INVALID',
      reason: 'authorization manifest is unavailable',
    }));
  }
  const account = authorization.accounts?.allowedAliases?.[0];
  const namespace = authorization.dataBoundaries?.allowedNamespaces?.[0];
  const mutation = authorization.allowedMutations?.[0];
  return (contract.riskActions ?? []).map((action) => {
    const decision = evaluateAuthorization({
      manifest: authorization,
      request: {
        lane: contract.slug,
        action,
        target,
        sourceTrust: 'manifest',
        account,
        namespace,
        mutation,
        rate: authorization.rateLimits?.requestsPerSecond,
        concurrency: authorization.rateLimits?.maxConcurrent,
        totalRequests: authorization.rateLimits?.maxTotalRequests,
        duration: authorization.rateLimits?.maxDurationSeconds,
        binaryReviewed: action === 'binary-evidence' ? true : undefined,
      },
      now,
    });
    return { action, decision: decision.decision, ruleId: decision.ruleId, reason: decision.reason };
  });
}

function parsePreflightOptions(args) {
  const options = { features: [], json: false };
  for (let index = 0; index < args.length; index += 1) {
    const name = args[index];
    if (name === '--json') {
      options.json = true;
      continue;
    }
    const value = args[index + 1];
    if (!value || value.startsWith('--')) fail(`preflight ${name} requires a value`);
    index += 1;
    if (name === '--target') options.target = value;
    else if (name === '--mode') options.mode = value.toUpperCase();
    else if (name === '--artifact-root') options.artifactRoot = value;
    else if (name === '--output') options.output = value;
    else if (name === '--authorization') options.authorization = value;
    else if (name === '--engagement') options.engagement = value;
    else if (name === '--environment') options.environment = value;
    else if (name === '--engagement-id') options.engagementId = value;
    else if (name === '--profile') options.profile = value;
    else if (name === '--feature') options.features.push(value);
    else fail(`unknown preflight option: ${name}`);
  }
  return options;
}

async function inspectTarget(value, profile) {
  if (/^https?:\/\//i.test(value)) {
    if (typeof profile.targetReachable === 'boolean') {
      return { value, kind: 'url', reachable: profile.targetReachable, evidence: `profile override: reachable=${profile.targetReachable}` };
    }
    try {
      const response = await fetch(value, { method: 'HEAD', redirect: 'manual', signal: AbortSignal.timeout(5000) });
      return { value, kind: 'url', reachable: true, evidence: `HTTP HEAD responded with ${response.status}` };
    } catch (error) {
      return { value, kind: 'url', reachable: false, evidence: `HTTP HEAD failed: ${error.message}` };
    }
  }
  const path = resolve(value);
  let reachable = typeof profile.targetReachable === 'boolean' ? profile.targetReachable : existsSync(path);
  if (reachable && typeof profile.targetReachable !== 'boolean') {
    try {
      accessSync(path, constants.R_OK);
    } catch {
      reachable = false;
    }
  }
  return {
    value: path,
    kind: 'path',
    reachable,
    evidence: typeof profile.targetReachable === 'boolean'
      ? `profile override: reachable=${profile.targetReachable}`
      : reachable ? `local path exists and is readable: ${path}` : `local path is missing or unreadable: ${path}`,
  };
}

function detectCommands(inventory, profile) {
  const override = Array.isArray(profile.commands) ? new Set(profile.commands) : null;
  const result = {};
  for (const { value } of inventory.commandReferences) {
    const available = override ? override.has(value) : commandExists(value);
    result[value] = { available, evidence: override ? `profile command ${available ? 'available' : 'missing'}` : `PATH command ${available ? 'found' : 'missing'}` };
  }
  return result;
}

function commandExists(command) {
  try {
    execFileSync('sh', ['-c', 'command -v "$1" >/dev/null 2>&1', 'argus-preflight', command]);
    return true;
  } catch {
    return false;
  }
}

function detectMcpServers() {
  try {
    return execFileSync('claude', ['mcp', 'list'], { encoding: 'utf8', timeout: 15000 })
      .split('\n')
      .filter((line) => /Connected/.test(line))
      .map((line) => line.split(': ').at(0).trim());
  } catch {
    return [];
  }
}

function detectTargetFeatures(targetPath) {
  if (!targetPath || !existsSync(targetPath)) return [];
  const features = [];
  const has = (...paths) => paths.some((path) => existsSync(join(targetPath, path)));
  if (has('src', 'app', 'lib', 'package.json', 'pyproject.toml', 'pom.xml', 'build.gradle')) features.push('source-access');
  if (has('tests', 'test', 'spec', 'playwright.config.ts', 'pytest.ini', 'vitest.config.ts', 'jest.config.js')) features.push('existing-suite');
  if (has('docker-compose.yml', 'docker-compose.yaml', 'compose.yml', 'compose.yaml')) features.push('multi-service');
  const manifests = ['package.json', 'pyproject.toml', 'pom.xml'].filter((path) => existsSync(join(targetPath, path)));
  if (manifests.some((path) => /graphql|grpc|websocket|socket\.io|kafka|rabbitmq|nats/i.test(readFileSync(join(targetPath, path), 'utf8')))) {
    features.push('non-rest-surface');
  }
  if (process.env.DATABASE_URL || process.env.PGHOST || process.env.MYSQL_HOST) features.push('db-access');
  return features;
}

function hasBrowserRuntime(targetPath) {
  if (!targetPath || !existsSync(targetPath)) return false;
  return existsSync(join(targetPath, 'node_modules', 'playwright')) || existsSync(join(targetPath, 'node_modules', '@playwright', 'test'));
}

function isWritableDirectory(path) {
  try {
    if (!statSync(path).isDirectory()) return false;
    accessSync(path, constants.W_OK);
    return true;
  } catch {
    return false;
  }
}

function statSafe(path) {
  try {
    return statSync(path);
  } catch {
    return null;
  }
}

function isWithin(root, path) {
  return path === root || path.startsWith(`${root}${sep}`);
}

function addCheck(checks, id, mandatory, passed, evidence) {
  checks.push({ id, mandatory, status: passed ? 'pass' : mandatory ? 'fail' : 'degraded', evidence });
}

function parseNamedOptions(args, allowed) {
  const options = {};
  for (let index = 0; index < args.length; index += 1) {
    const name = args[index];
    if (!allowed.has(name)) fail(`unknown option: ${name}`);
    const value = args[index + 1];
    if (value == null || value.startsWith('--')) fail(`${name} requires a value`);
    index += 1;
    options[kebabToCamel(name.slice(2))] = value;
  }
  return options;
}

function loadEngagement(options) {
  const path = resolve(options.manifest ?? process.env.ARGUS_ENGAGEMENT_MANIFEST ?? 'ai_agents_internal/engagement.json');
  const engagement = readJson(path);
  const errors = validateEngagementManifest(engagement);
  if (errors.length > 0) throw new Error(`invalid manifest ${path}: ${errors.join('; ')}`);
  return { manifest: engagement, path };
}

function requireOptions(options, required, command) {
  for (const key of required) if (!options[key]) fail(`${command} requires --${camelToKebab(key)}`);
}

function leaseToken(options) {
  const token = options.token ?? process.env.ARGUS_ENGAGEMENT_LEASE_TOKEN;
  if (!token) fail('engagement operation requires --token or ARGUS_ENGAGEMENT_LEASE_TOKEN');
  return token;
}

function readTextInput(input) {
  return input === '-' ? readFileSync(0, 'utf8') : readFileSync(resolve(input), 'utf8');
}

function parsePositiveOption(value, label) {
  if (value == null) return undefined;
  const number = Number(value);
  if (!Number.isFinite(number) || number <= 0) fail(`${label} must be a positive number`);
  return number;
}

function parseBooleanOption(value, label) {
  if (value == null) return undefined;
  if (value === 'true') return true;
  if (value === 'false') return false;
  fail(`${label} must be true or false`);
}

function kebabToCamel(value) {
  return value.replace(/-([a-z])/g, (_, letter) => letter.toUpperCase());
}

function camelToKebab(value) {
  return value.replace(/[A-Z]/g, (letter) => `-${letter.toLowerCase()}`);
}

function nonEmptyString(value) {
  return typeof value === 'string' && value.trim().length > 0;
}

function copyTemplate(runtime, destination) {
  const ids = {
    typescript: 'typescript-template',
    java: 'java-template',
    python: 'python-template',
  };
  if (!ids[runtime]) fail('copy-template runtime must be typescript, java, or python');
  if (!destination) fail('copy-template requires an empty destination path');
  const source = assetPath(requireAsset(ids[runtime]));
  const target = resolve(destination);
  assertEmptyDestination(target);
  mkdirSync(target, { recursive: true });
  for (const name of readdirSync(source)) cpSync(join(source, name), join(target, name), { recursive: true, force: false, errorOnExist: true });
  console.log(`COPIED  ${runtime} template -> ${target}`);
}

function copyBrowserDriver(destination) {
  if (!destination) fail('copy-browser-driver requires a target repo path');
  const targetRoot = resolve(destination);
  if (!existsSync(targetRoot) || !statSync(targetRoot).isDirectory()) fail(`target repo directory does not exist: ${targetRoot}`);
  const sourceRoot = assetPath(requireAsset('typescript-template'));
  const scriptsDir = join(targetRoot, 'scripts');
  mkdirSync(scriptsDir, { recursive: true });
  const files = [
    ['scripts/hunt-driver.mjs', 'hunt-driver.mjs'],
    ['scripts/driver.config.example.json', 'driver.config.example.json'],
  ];
  for (const [sourceRelative, targetName] of files) {
    const target = join(scriptsDir, targetName);
    if (existsSync(target)) fail(`refusing to overwrite existing file: ${target}`);
    copyFileSync(join(sourceRoot, sourceRelative), target);
    chmodSync(target, statSync(join(sourceRoot, sourceRelative)).mode & 0o777);
  }
  const schemaTarget = join(scriptsDir, 'driver-config.schema.json');
  if (existsSync(schemaTarget)) fail(`refusing to overwrite existing file: ${schemaTarget}`);
  copyFileSync(assetPath(requireAsset('runtime-schemas'), 'driver-config.schema.json'), schemaTarget);
  console.log(`COPIED  isolated browser driver -> ${scriptsDir}`);
}

function requireAsset(id) {
  if (!id) fail('asset id is required; run argus-assets list');
  const asset = manifest.assets.find((item) => item.id === id);
  if (!asset) fail(`unknown asset id: ${id}; run argus-assets list`);
  return asset;
}

function assetPath(asset, child = '') {
  const path = resolve(ROOT, asset.destination, child);
  if (path !== ROOT && !path.startsWith(`${ROOT}${sep}`)) fail(`asset path escapes plugin root: ${asset.destination}`);
  return path;
}

function assertEmptyDestination(path) {
  if (!existsSync(path)) return;
  if (!statSync(path).isDirectory()) fail(`destination is not a directory: ${path}`);
  if (readdirSync(path).length > 0) fail(`refusing to copy into non-empty destination: ${path}`);
}

function treeStats(path) {
  const isFile = statSync(path).isFile();
  const files = isFile ? [path] : walkFiles(path);
  const hash = createHash('sha256');
  let bytes = 0;
  for (const file of files.sort()) {
    const rel = isFile ? file.split(sep).at(-1) : relative(path, file).split(sep).join('/');
    const content = readFileSync(file);
    bytes += content.length;
    hash.update(rel);
    hash.update('\0');
    hash.update(content);
  }
  return { files: files.length, bytes, sha256: hash.digest('hex') };
}

function walkFiles(dir) {
  const out = [];
  for (const name of readdirSync(dir).sort()) {
    const path = join(dir, name);
    const stat = statSync(path);
    if (stat.isDirectory()) out.push(...walkFiles(path));
    else if (stat.isFile()) out.push(path);
    else fail(`unsupported filesystem entry in plugin: ${path}`);
  }
  return out;
}

function readJson(path) {
  try {
    return JSON.parse(readFileSync(path, 'utf8'));
  } catch (error) {
    fail(`cannot parse ${path}: ${error.message}`);
  }
}

function fail(message) {
  console.error(`FAIL  ${message}`);
  process.exit(1);
}
