function techniqueCommand(args) {
  const [operation, ...rest] = args;
  if (!['scopes', 'select'].includes(operation)) fail('usage: argus-assets technique scopes|select --role <atalanta|proteus|metis> [--inventory <surface-inventory.json>]');
  const options = parseNamedOptions(rest, operation === 'scopes' ? new Set(['--role']) : new Set(['--role', '--inventory']));
  requireOptions(options, operation === 'scopes' ? ['role'] : ['role', 'inventory'], `technique ${operation}`);
  const declaration = matrix.techniqueCatalogs?.[options.role];
  if (!declaration || !matrix.agents.some((agent) => agent.slug === options.role && agent.techniqueCatalogs?.includes(options.role))) {
    fail(`technique ${operation}: ${options.role} is not a catalog-owning role`);
  }

  const document = loadTechniqueCatalog(options.role, declaration);
  if (operation === 'scopes') {
    process.stdout.write(`${JSON.stringify({
      schema: 'argus/technique-scope-list@1',
      schemaVersion: 1,
      role: options.role,
      catalogId: declaration.catalogId,
      catalogSha256: declaration.sha256,
      scopes: techniqueScopes(document).map((scope) => `${options.role}:${scope}`),
    }, null, 2)}\n`);
    return 0;
  }

  let inventory;
  try { inventory = JSON.parse(readTextInput(options.inventory)); }
  catch (error) { fail(`technique select: inventory is not valid JSON: ${error.message}`); }
  const inventoryErrors = validateSurfaceInventory(inventory);
  if (inventoryErrors.length) fail(`technique select: invalid surface inventory: ${inventoryErrors.join('; ')}`);
  const invalidScopes = inventory.items.flatMap((item) => item.techniqueScopes ?? []).filter((scope) =>
    typeof scope !== 'string' || !/^(atalanta|proteus|metis):[a-z0-9]+(?:-[a-z0-9]+)*$/.test(scope));
  if (invalidScopes.length) fail(`technique select: invalid techniqueScopes: ${[...new Set(invalidScopes)].join(', ')}`);

  const declared = [...new Set(inventory.items.flatMap((item) => item.techniqueScopes ?? [])
    .filter((scope) => scope.startsWith(`${options.role}:`))
    .map((scope) => scope.slice(options.role.length + 1)))].sort();
  const selection = selectTechniqueCatalog(options.role, document, declared);
  process.stdout.write(`${JSON.stringify({
    schema: 'argus/technique-selection@1',
    schemaVersion: 1,
    role: options.role,
    catalogId: declaration.catalogId,
    catalogSha256: declaration.sha256,
    inventorySchema: inventory.$schema,
    disposition: selection.disposition,
    reason: selection.reason,
    declaredScopes: declared,
    selectedIds: selection.selectedIds,
    catalog: selection.catalog,
  }, null, 2)}\n`);
  return 0;
}

function loadTechniqueCatalog(role, declaration) {
  const asset = requireAsset('technique-catalogs-bundle');
  assertPackagedAsset(asset, 'trusted technique-catalogs-bundle');
  let bundle;
  try {
    const compressed = Buffer.from(readFileSync(TECHNIQUE_BUNDLE_PATH, 'utf8').trim(), 'base64');
    bundle = JSON.parse(brotliDecompressSync(compressed).toString('utf8'));
  } catch (error) {
    fail(`technique select: cannot decode trusted bundle: ${error.message}`);
  }
  if (bundle.schema !== 'argus/technique-catalog-bundle@1' || bundle.schemaVersion !== 1 || !plainObject(bundle.catalogs)) {
    fail('technique select: trusted bundle envelope is invalid');
  }
  const record = bundle.catalogs[role];
  if (!plainObject(record) || typeof record.source !== 'string' || typeof record.sha256 !== 'string') {
    fail(`technique select: trusted bundle has no ${role} catalog`);
  }
  const digest = createHash('sha256').update(record.source).digest('hex');
  if (digest !== record.sha256 || digest !== declaration.sha256) fail(`technique select: ${role} catalog hash mismatch`);
  let document;
  try { document = JSON.parse(record.source); }
  catch (error) { fail(`technique select: ${role} catalog is not valid JSON: ${error.message}`); }
  if (document.$schema !== 'argus/technique-catalog@1' || document.catalogId !== declaration.catalogId || document.role !== role) {
    fail(`technique select: ${role} catalog identity mismatch`);
  }
  return document;
}

function selectTechniqueCatalog(role, document, declaredScopes) {
  const full = (reason) => ({
    disposition: 'full-fallback',
    reason,
    selectedIds: techniqueIds(document),
    catalog: document,
  });
  if (declaredScopes.length === 0) return full('missing-role-scopes');

  if (document.catalogType === 'hunter') {
    const known = new Set(document.entries.flatMap((entry) => entry.scope));
    const unknown = declaredScopes.filter((scope) => !known.has(scope));
    if (unknown.length) return full(`unknown-role-scopes:${unknown.join(',')}`);
    const selected = document.entries.filter((entry) =>
      entry.appliesWhen === 'always' || entry.scope.some((scope) => declaredScopes.includes(scope)));
    if (selected.length === 0) return full('empty-selection');
    return {
      disposition: 'selected',
      reason: 'explicit-role-scopes',
      selectedIds: selected.map((entry) => entry.id),
      catalog: { ...document, entries: selected },
    };
  }

  const sections = ['iso25010', 'journeyClasses', 'archetypes'];
  const known = new Set(sections.flatMap((section) => document[section].map((entry) => entry.id)));
  const unknown = declaredScopes.filter((scope) => !known.has(scope));
  if (unknown.length) return full(`unknown-role-scopes:${unknown.join(',')}`);
  const selected = Object.fromEntries(sections.map((section) => [
    section,
    document[section].filter((entry) => declaredScopes.includes(entry.id)),
  ]));
  const selectedIds = sections.flatMap((section) => selected[section].map((entry) => entry.id));
  if (selectedIds.length === 0) return full('empty-selection');
  return {
    disposition: 'selected',
    reason: 'explicit-role-scopes-with-universal-istqb-and-boundary-register',
    selectedIds,
    catalog: {
      $schema: document.$schema,
      schemaVersion: document.schemaVersion,
      catalogId: document.catalogId,
      role: document.role,
      catalogType: document.catalogType,
      valuePolicy: document.valuePolicy,
      executionRule: document.executionRule,
      ...selected,
      istqb: document.istqb,
      boundaryRegister: document.boundaryRegister,
    },
  };
}

function techniqueIds(document) {
  if (document.catalogType === 'hunter') return document.entries.map((entry) => entry.id);
  return [...document.iso25010, ...document.journeyClasses, ...document.archetypes].map((entry) => entry.id);
}

function techniqueScopes(document) {
  if (document.catalogType === 'hunter') return [...new Set(document.entries.flatMap((entry) => entry.scope))].sort();
  return [...new Set([...document.iso25010, ...document.journeyClasses, ...document.archetypes].map((entry) => entry.id))].sort();
}

function templateCommand(args) {
  const [operation, ...rest] = args;
  if (operation === 'detect') {
    const options = parseNamedOptions(rest, new Set(['--target', '--output']));
    requireOptions(options, ['target'], 'template detect');
    const detected = detectTemplateCapabilities(options.target);
    writeTemplateOutput(detected, options.output ?? '-');
    return 0;
  }
  if (operation === 'select') {
    const options = parseNamedOptions(rest, new Set(['--target', '--runtime', '--package-manager', '--test-root', '--harness-root', '--ci', '--output']));
    requireOptions(options, ['target', 'runtime', 'testRoot', 'harnessRoot', 'output'], 'template select');
    const capabilities = detectTemplateCapabilities(options.target);
    const packageManager = options.packageManager ?? resolveDetectedPackageManager(capabilities, options.runtime, templateContract);
    const selection = selectTemplate({
      capabilities,
      contract: templateContract,
      runtime: options.runtime,
      packageManager,
      testRoot: options.testRoot,
      harnessRoot: options.harnessRoot,
      ci: options.ci ? options.ci.split(',').map((value) => value.trim()).filter(Boolean) : undefined,
    });
    writeTemplateOutput(selection, options.output);
    return 0;
  }
  if (operation === 'scaffold') {
    const options = parseNamedOptions(rest, new Set(['--selection', '--destination']));
    requireOptions(options, ['selection', 'destination'], 'template scaffold');
    const selection = readJson(resolve(options.selection));
    const selectionErrors = validateTemplateSelection(selection, templateContract);
    if (selectionErrors.length) fail(`template scaffold selection invalid: ${selectionErrors.join('; ')}`);
    if (selection.action !== 'build') fail('template scaffold refuses action=adapt; extend the detected suite and its existing runner in place');
    const current = detectTemplateCapabilities(selection.targetRoot);
    const digest = createHash('sha256').update(stableTemplateJson(current)).digest('hex');
    if (digest !== selection.capabilitiesSha256) fail('target capabilities changed after selection; detect and select again');
    if (selection.unsupported?.length) fail(`template scaffold has unsupported capabilities: ${selection.unsupported.join(', ')}`);
    const entries = prepareTemplateComposition(selection.runtime);
    try {
      assertActiveEngagementWrites([resolve(options.destination)], 'template scaffold');
      scaffoldTemplateAtomically(selection, options.destination, entries);
    } catch (error) {
      fail(`template scaffold failed: ${error.message}`);
    }
    console.log(`SCAFFOLDED  ${selection.runtime}/${selection.packageManager} testRoot=${selection.testRoot} harnessRoot=${selection.harnessRoot} -> ${resolve(options.destination)}`);
    return 0;
  }
  fail('usage: argus-assets template <detect|select|scaffold> [options]');
}

function writeTemplateOutput(document, output) {
  const serialized = stableTemplateJson(document);
  if (output === '-') process.stdout.write(serialized);
  else {
    const path = resolve(output);
    assertActiveEngagementWrites([path], 'template output');
    mkdirSync(dirname(path), { recursive: true });
    atomicPrivateWrite(path, serialized);
    console.log(`WROTE  ${path}`);
  }
}

function launchCommand(args) {
  const [operation, ...rest] = args;
  if (operation === 'request') {
    const options = parseNamedOptions(rest, new Set([
      '--target', '--workspace', '--artifact-root', '--mode', '--engagement-id', '--launcher',
      '--launcher-pid', '--claude-executable', '--runtime-key-id', '--trust-store', '--output',
      '--ttl-seconds', '--capability-sha256',
      '--sandbox-probe-path',
    ]));
    requireOptions(options, [
      'target', 'workspace', 'artifactRoot', 'mode', 'engagementId', 'launcher', 'launcherPid',
      'claudeExecutable', 'runtimeKeyId', 'trustStore', 'output', 'capabilitySha256', 'sandboxProbePath',
    ], 'launch request');
    const mode = options.mode.toUpperCase();
    if (!['A', 'B', 'C', 'D'].includes(mode)) fail('launch request --mode must be A, B, C, or D');
    requireStableIdentifier(options.engagementId, 'launch request --engagement-id');
    const launcherPid = positiveInteger(options.launcherPid, 'launch request --launcher-pid');
    if (!/^[a-f0-9]{64}$/.test(options.capabilitySha256)) fail('launch request --capability-sha256 must be a SHA-256 digest');
    requireLiveProcess(launcherPid, 'launch request launcher');
    const target = identifyTarget(options.target);
    const workspace = existingPhysicalDirectory(options.workspace, 'launch request workspace');
    const artifactRoot = existingPhysicalDirectory(options.artifactRoot, 'launch request artifact root');
    requireSecureOwnedDirectory(artifactRoot, 'launch request artifact root');
    if (target.targetPath && (isWithin(target.targetPath, artifactRoot) || isWithin(artifactRoot, target.targetPath))) {
      fail('launch request target and artifact root must be physically disjoint');
    }
    const launcher = existingPhysicalFile(options.launcher, 'launch request launcher');
    const claudeExecutable = existingPhysicalFile(options.claudeExecutable, 'launch request Claude executable');
    const sandboxProbePath = existingPhysicalDirectory(options.sandboxProbePath, 'launch request sandbox probe');
    if (isWithin(artifactRoot, sandboxProbePath) || (target.targetPath && isWithin(target.targetPath, sandboxProbePath))) {
      fail('launch request sandbox probe must stay outside target and artifact roots');
    }
    const sandboxProbe = sandboxProbeIdentity(sandboxProbePath, 'launch request sandbox probe', true);
    const trust = loadNativeLaunchTrust(options.runtimeKeyId, options.trustStore, { artifactRoot, targetRoot: target.targetPath });
    const ttlSeconds = options.ttlSeconds === undefined ? 300 : positiveInteger(options.ttlSeconds, 'launch request --ttl-seconds');
    if (ttlSeconds < 30 || ttlSeconds > 300) fail('launch request TTL must be between 30 and 300 seconds');
    const output = secureOperatorOutputPath(options.output, [artifactRoot, target.targetPath].filter(Boolean), 'launch request output');
    const requestNonce = randomBytes(32).toString('hex');
    const issuedAt = new Date();
    const claudeVersion = claudeExecutableVersion(claudeExecutable);
    const request = {
      schema: 'argus/native-launch-authorization@1',
      schemaVersion: 1,
      kind: 'ARGUS_NATIVE_LAUNCH_AUTHORIZATION',
      launchId: `LCH-${createHash('sha256').update(`${requestNonce}\0${launcherPid}`).digest('hex').slice(0, 24)}`,
      engagementId: options.engagementId,
      requestNonce,
      launcherPid,
      launchCapabilitySha256: options.capabilitySha256,
      runtime: 'claude',
      model: 'opus',
      effort: 'max',
      maxTurns: 96,
      mode,
      targetKind: target.kind,
      target: target.targetIdentity,
      workspace,
      artifactRoot,
      launcherExecutable: launcher,
      launcherSha256: sha256File(launcher),
      claudeExecutable,
      claudeExecutableSha256: sha256File(claudeExecutable),
      claudeVersion,
      sandboxPolicy: 'os-native-target-readonly@2',
      sandboxProbePath,
      sandboxProbeDevice: sandboxProbe.device,
      sandboxProbeInode: sandboxProbe.inode,
      sandboxProbeUid: sandboxProbe.uid,
      sandboxProbeMode: sandboxProbe.mode,
      environmentPolicy: 'argus-launch-allowlist@1',
      issuedBy: trust.record.subjectId,
      issuedAt: issuedAt.toISOString(),
      expiresAt: new Date(issuedAt.getTime() + ttlSeconds * 1000).toISOString(),
      authentication: {
        algorithm: 'Ed25519',
        keyId: trust.record.keyId,
        purpose: 'runtime-attestation',
        keyFingerprintSha256: modelPublicKeyFingerprint(trust.record.publicKeyPem),
        signatureBase64: '',
      },
    };
    writeFileSync(output, `${JSON.stringify(request, null, 2)}\n`, { flag: 'wx', mode: 0o600 });
    chmodSync(output, 0o600);
    console.log(`LAUNCH_REQUEST  created launch=${request.launchId} output=${output} expires=${request.expiresAt}`);
    return 0;
  }
  if (operation === 'verify') {
    const options = parseNamedOptions(rest, new Set(['--request', '--authorization', '--receipt', '--trust-store']));
    requireOptions(options, ['request', 'authorization', 'receipt', 'trustStore'], 'launch verify');
    const requestPath = existingPhysicalFile(options.request, 'native launch request');
    const authorizationPath = existingPhysicalFile(options.authorization, 'native launch authorization');
    requireSecureOperatorInput(requestPath, 'native launch request');
    requireSecureOperatorInput(authorizationPath, 'native launch authorization');
    if (requestPath === authorizationPath) fail('native launch request and signed authorization must be distinct files');
    const request = readSecureJson(requestPath, 'native launch request');
    const authorization = readSecureJson(authorizationPath, 'native launch authorization');
    assertSchemaDocument(validateNativeLaunchAuthorizationSchema, authorization, 'native launch authorization');
    const unsignedAuthorization = structuredClone(authorization);
    unsignedAuthorization.authentication.signatureBase64 = '';
    if (modelAuthenticationPayload(request) !== modelAuthenticationPayload(unsignedAuthorization)) {
      fail('signed native launch authorization differs from the exact launcher request');
    }
    const target = identifyTarget(authorization.target);
    if (target.kind !== authorization.targetKind || target.targetIdentity !== authorization.target) {
      fail('native launch authorization target identity is not canonical');
    }
    const workspace = existingPhysicalDirectory(authorization.workspace, 'authorized launch workspace');
    const artifactRoot = existingPhysicalDirectory(authorization.artifactRoot, 'authorized launch artifact root');
    requireSecureOwnedDirectory(artifactRoot, 'authorized launch artifact root');
    if (workspace !== authorization.workspace || artifactRoot !== authorization.artifactRoot) {
      fail('native launch authorization paths changed after request creation');
    }
    if (target.targetPath && (isWithin(target.targetPath, artifactRoot) || isWithin(artifactRoot, target.targetPath))) {
      fail('authorized native launch target and artifact root are not physically disjoint');
    }
    const sandboxProbePath = existingPhysicalDirectory(authorization.sandboxProbePath, 'authorized sandbox probe');
    if (isWithin(artifactRoot, sandboxProbePath) || (target.targetPath && isWithin(target.targetPath, sandboxProbePath)) ||
        !directoryIsWritable(sandboxProbePath)) {
      fail('authorized sandbox probe is not a host-writable path outside target and artifact roots');
    }
    const sandboxProbe = sandboxProbeIdentity(sandboxProbePath, 'authorized sandbox probe', true);
    for (const [field, current] of Object.entries({
      sandboxProbeDevice: sandboxProbe.device,
      sandboxProbeInode: sandboxProbe.inode,
      sandboxProbeUid: sandboxProbe.uid,
      sandboxProbeMode: sandboxProbe.mode,
    })) if (authorization[field] !== current) fail(`authorized sandbox probe ${field} identity changed after signing`);
    const trust = loadNativeLaunchTrust(authorization.authentication.keyId, options.trustStore, {
      artifactRoot,
      targetRoot: target.targetPath,
    });
    const pinnedRuntimeKey = pinnedTrustKey(trust.record);
    let authentication;
    try { authentication = verifyNativeLaunchAuthorization(authorization, pinnedRuntimeKey); }
    catch (error) { fail(`native launch authorization authentication failed: ${error.message}`); }
    const now = Date.now();
    const issuedAt = Date.parse(authorization.issuedAt);
    const expiresAt = Date.parse(authorization.expiresAt);
    if (!Number.isFinite(issuedAt) || !Number.isFinite(expiresAt) || expiresAt <= issuedAt || expiresAt - issuedAt > 300_000) {
      fail('native launch authorization validity window is invalid or exceeds five minutes');
    }
    if (issuedAt > now + 30_000 || expiresAt <= now) fail('native launch authorization is not currently valid');
    requireLiveProcess(authorization.launcherPid, 'authorized native launcher');
    const launcher = existingPhysicalFile(authorization.launcherExecutable, 'authorized launcher');
    if (sha256File(launcher) !== authorization.launcherSha256) fail('authorized launcher executable changed after signing');
    const claudeExecutable = existingPhysicalFile(authorization.claudeExecutable, 'authorized Claude executable');
    if (sha256File(claudeExecutable) !== authorization.claudeExecutableSha256 || claudeExecutableVersion(claudeExecutable) !== authorization.claudeVersion) {
      fail('authorized Claude executable or version changed after signing');
    }
    const receipt = resolve(options.receipt);
    const expectedReceipt = join(artifactRoot, 'ai_agents_internal', 'native-launch-receipt.json');
    if (receipt !== expectedReceipt || !safePhysicalPath(artifactRoot, receipt)) {
      fail('native launch receipt must be ai_agents_internal/native-launch-receipt.json under the artifact root');
    }
    if (existsSync(receipt)) {
      const current = readSecureJson(receipt, 'existing native launch receipt');
      const active = Number.isFinite(Date.parse(current.expiresAt)) && Date.parse(current.expiresAt) > now && processIsLive(current.launcherPid);
      if (active && current.launchId !== authorization.launchId) fail('artifact root already has a different active native launch');
    }
    const document = {
      schema: 'argus/native-launch-receipt@1',
      schemaVersion: 1,
      launchId: authorization.launchId,
      engagementId: authorization.engagementId,
      launcherPid: authorization.launcherPid,
      launchCapabilitySha256: authorization.launchCapabilitySha256,
      authorizationPath,
      authorizationSha256: modelAuthenticatedDocumentSha256(authorization),
      trustStorePath: trust.path,
      trustStoreSha256: trust.sha256,
      runtimeKeyId: authentication.keyId,
      runtimeKeyFingerprintSha256: authentication.keyFingerprintSha256,
      targetKind: authorization.targetKind,
      target: authorization.target,
      workspace: authorization.workspace,
      artifactRoot: authorization.artifactRoot,
      mode: authorization.mode,
      runtime: authorization.runtime,
      model: authorization.model,
      effort: authorization.effort,
      maxTurns: authorization.maxTurns,
      launcherExecutable: authorization.launcherExecutable,
      launcherSha256: authorization.launcherSha256,
      claudeExecutable: authorization.claudeExecutable,
      claudeExecutableSha256: authorization.claudeExecutableSha256,
      claudeVersion: authorization.claudeVersion,
      sandboxPolicy: authorization.sandboxPolicy,
      sandboxProbePath: authorization.sandboxProbePath,
      sandboxProbeDevice: authorization.sandboxProbeDevice,
      sandboxProbeInode: authorization.sandboxProbeInode,
      sandboxProbeUid: authorization.sandboxProbeUid,
      sandboxProbeMode: authorization.sandboxProbeMode,
      environmentPolicy: authorization.environmentPolicy,
      verifiedAt: new Date().toISOString(),
      expiresAt: authorization.expiresAt,
    };
    assertSchemaDocument(validateNativeLaunchReceiptSchema, document, 'native launch receipt');
    atomicPrivateWrite(receipt, `${JSON.stringify(document, null, 2)}\n`);
    console.log(`LAUNCH_VERIFIED  launch=${document.launchId} receipt=${receipt}`);
    return 0;
  }
  fail('usage: argus-assets launch <request|verify> [options]');
}

function requireStableIdentifier(value, label) {
  if (typeof value !== 'string' || !/^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$/.test(value)) {
    fail(`${label} must be a stable identifier`);
  }
}

function processIsLive(pid) {
  if (!Number.isInteger(pid) || pid < 1) return false;
  try { process.kill(pid, 0); return true; }
  catch (error) { return error.code === 'EPERM'; }
}

function requireLiveProcess(pid, label) {
  if (!processIsLive(pid)) fail(`${label} process is not live`);
}

function existingPhysicalDirectory(value, label) {
  if (typeof value !== 'string' || !value.startsWith('/') || resolve(value) !== value) fail(`${label} must be an absolute normalized path`);
  let stats;
  try { stats = lstatSync(value); }
  catch (error) { fail(`${label} is unavailable: ${error.message}`); }
  if (!stats.isDirectory() || stats.isSymbolicLink() || realpathSync(value) !== value) fail(`${label} must be a physical directory without symbolic links`);
  return value;
}

function existingPhysicalFile(value, label) {
  if (typeof value !== 'string' || !value.startsWith('/') || resolve(value) !== value) fail(`${label} must be an absolute normalized path`);
  let stats;
  try { stats = lstatSync(value); }
  catch (error) { fail(`${label} is unavailable: ${error.message}`); }
  if (!stats.isFile() || stats.isSymbolicLink() || stats.nlink !== 1 || realpathSync(value) !== value) {
    fail(`${label} must be a physical single-link regular file`);
  }
  return value;
}

function directoryIsWritable(path) {
  try { accessSync(path, constants.W_OK); return true; }
  catch { return false; }
}

function requireSecureOwnedDirectory(path, label) {
  const stats = lstatSync(path);
  const uid = typeof process.getuid === 'function' ? process.getuid() : stats.uid;
  if (stats.uid !== uid || (stats.mode & 0o022) !== 0) {
    fail(`${label} must be current-user-owned and not group/world writable`);
  }
}

function sandboxProbeIdentity(path, label, requireWritable) {
  const stats = lstatSync(path);
  const uid = typeof process.getuid === 'function' ? process.getuid() : stats.uid;
  const mode = stats.mode & 0o777;
  if (stats.uid !== uid || mode !== 0o700 || readdirSync(path).length !== 0 || (requireWritable && !directoryIsWritable(path))) {
    fail(`${label} must be empty, current-user-owned, mode 0700${requireWritable ? ', and host-writable' : ''}`);
  }
  return { device: stats.dev, inode: stats.ino, uid: stats.uid, mode };
}

function secureOperatorOutputPath(value, forbiddenRoots, label) {
  if (typeof value !== 'string' || !value.startsWith('/') || resolve(value) !== value) fail(`${label} must be an absolute normalized path`);
  if (existsSync(value)) fail(`${label} already exists; requests are immutable and may not be overwritten`);
  const parent = dirname(value);
  const stats = lstatSync(parent);
  const uid = typeof process.getuid === 'function' ? process.getuid() : null;
  if (!stats.isDirectory() || stats.isSymbolicLink() || realpathSync(parent) !== parent ||
      (uid !== null && stats.uid !== uid) || (stats.mode & 0o022) !== 0) {
    fail(`${label} parent must be a physical current-user-owned directory that is not group/world writable`);
  }
  for (const root of forbiddenRoots) if (isWithin(root, value) || isWithin(value, root)) fail(`${label} must stay outside target and artifact roots`);
  return value;
}

function requireSecureOperatorInput(path, label) {
  const pathStats = lstatSync(path);
  const parent = dirname(path);
  const parentStats = lstatSync(parent);
  const uid = typeof process.getuid === 'function' ? process.getuid() : null;
  if (!parentStats.isDirectory() || parentStats.isSymbolicLink() || realpathSync(parent) !== parent ||
      (uid !== null && parentStats.uid !== uid) || (parentStats.mode & 0o022) !== 0) {
    fail(`${label} parent must be a physical current-user-owned directory that is not group/world writable`);
  }
  if ((uid !== null && pathStats.uid !== uid) || (pathStats.mode & 0o133) !== 0) {
    fail(`${label} must be current-user-owned, non-executable, and not writable by others`);
  }
}

function sha256File(path) {
  const digest = createHash('sha256');
  const buffer = Buffer.allocUnsafe(1024 * 1024);
  const descriptor = openSync(path, 'r');
  try {
    for (;;) {
      const bytes = readSync(descriptor, buffer, 0, buffer.length, null);
      if (bytes === 0) break;
      digest.update(buffer.subarray(0, bytes));
    }
  } finally {
    closeSync(descriptor);
  }
  return digest.digest('hex');
}

function claudeExecutableVersion(path) {
  let version;
  try { version = execFileSync(path, ['--version'], { encoding: 'utf8', stdio: ['ignore', 'pipe', 'pipe'], timeout: 10_000 }).trim(); }
  catch (error) { fail(`Claude executable version probe failed: ${error.stderr?.toString().trim() || error.message}`); }
  if (!version || version.length > 128 || /[\r\n]/.test(version)) fail('Claude executable returned an invalid version identity');
  return version;
}

function loadNativeLaunchTrust(keyId, explicitStorePath, { artifactRoot, targetRoot }) {
  requireStableIdentifier(keyId, 'native launch runtime key ID');
  if (typeof explicitStorePath !== 'string' || !explicitStorePath.startsWith('/') || resolve(explicitStorePath) !== explicitStorePath) {
    fail('native launch trust store path must be absolute and normalized');
  }
  if (isWithin(artifactRoot, explicitStorePath) || (targetRoot && isWithin(targetRoot, explicitStorePath))) {
    fail('native launch trust store must stay outside target and artifact roots');
  }
  const directory = dirname(explicitStorePath);
  let directoryStat;
  let pathStat;
  try {
    directoryStat = lstatSync(directory);
    pathStat = lstatSync(explicitStorePath);
  } catch (error) {
    fail(`native launch trust store is unavailable: ${error.message}`);
  }
  const uid = typeof process.getuid === 'function' ? process.getuid() : null;
  if (!directoryStat.isDirectory() || directoryStat.isSymbolicLink() || realpathSync(directory) !== directory ||
      (uid !== null && directoryStat.uid !== uid) || (directoryStat.mode & 0o022) !== 0) {
    fail('native launch trust store directory must be physical, current-user-owned, and not group/world writable');
  }
  if (!pathStat.isFile() || pathStat.isSymbolicLink() || pathStat.nlink !== 1 || realpathSync(explicitStorePath) !== explicitStorePath ||
      (uid !== null && pathStat.uid !== uid) || (pathStat.mode & 0o133) !== 0) {
    fail('native launch trust store must be a physical, single-link, current-user-owned, non-executable file that is not writable by others');
  }
  const raw = readSecureSingleLink(explicitStorePath, 'native launch trust store');
  let document;
  try { document = JSON.parse(raw.toString('utf8')); }
  catch (error) { fail(`native launch trust store is not valid JSON: ${error.message}`); }
  assertSchemaDocument(validateModelTrustStoreSchema, document, 'native launch trust store');
  if (new Set(document.keys.map((record) => record.keyId)).size !== document.keys.length) fail('native launch trust store key IDs must be unique');
  const record = document.keys.find((candidate) => candidate.keyId === keyId);
  if (!record || record.status !== 'active' || record.purpose !== 'runtime-attestation') {
    fail(`native launch trust store has no active runtime-attestation key ${keyId}`);
  }
  return { record, path: explicitStorePath, sha256: createHash('sha256').update(raw).digest('hex') };
}

function modelCommand(args) {
  const [operation, ...rest] = args;
  const policy = modelPolicy;
  if (operation === 'list') {
    assertPackagedAsset(requireAsset('model-policy'), 'trusted model-policy');
    for (const role of policy.roles) {
      const tier = policy.tiers[role.tier];
      console.log(`${role.slug}\t${role.tier}\tclaude=${tier.claude.model}/${tier.claude.effort}\tcodex=${tier.codex.model}/${tier.codex.reasoningEffort}\tturns=${role.maxTurns}\tescalation=${role.escalationProfile}\tfallback=${role.fallbackPolicy}`);
    }
    return 0;
  }
  if (operation === 'benchmark') {
    if (rest.length > 0) fail('usage: argus-assets model benchmark');
    assertPackagedAsset(requireAsset('model-policy'), 'trusted model-policy');
    assertPackagedAsset(requireAsset('model-policy-benchmark'), 'trusted model-policy-benchmark');
    console.log(JSON.stringify(modelBenchmark, null, 2));
    return 0;
  }
  if (operation === 'trust') {
    const options = parseNamedOptions(rest, new Set(['--manifest', '--runtime-key-id', '--operator-key-id']));
    requireOptions(options, ['manifest', 'runtimeKeyId', 'operatorKeyId'], 'model trust');
    assertTrustedModelRoutingAssets();
    return pinModelTrust(options);
  }
  if (operation === 'payload') {
    const options = parseNamedOptions(rest, new Set(['--document']));
    requireOptions(options, ['document'], 'model payload');
    assertTrustedModelRoutingAssets();
    const path = resolveExistingPhysicalInput(options.document);
    if (!statSafe(path)?.isFile() || lstatSync(path).isSymbolicLink() || lstatSync(path).nlink !== 1) fail('model payload document must be a non-aliased real file');
    const document = readSecureJson(path, 'model payload document');
    if (!['argus/model-operator-decision@1', 'argus/model-dispatch-authorization@1', 'argus/native-launch-authorization@1'].includes(document.schema)) fail('model payload document has an unsupported schema');
    process.stdout.write(modelAuthenticationPayload(document));
    return 0;
  }
  if (operation === 'request') {
    const options = parseNamedOptions(rest, new Set(['--manifest', '--agent', '--runtime', '--signal', '--dispatch-id', '--attempt', '--checkpoint-ref', '--token']));
    requireOptions(options, ['manifest', 'agent', 'runtime', 'signal', 'dispatchId', 'attempt', 'checkpointRef'], 'model request');
    assertTrustedModelRoutingAssets();
    const engagementContext = loadModelEngagement(options.manifest, options.agent);
    requirePinnedModelTrust(engagementContext);
    requireCurrentModelPreflight(engagementContext, options.agent, options.runtime);
    requireActiveLaneCapability(engagementContext, options.agent, laneCapabilityToken(options));
    const request = persistModelEscalationRequest(engagementContext, options, positiveInteger(options.attempt, '--attempt'));
    console.log(`MODEL_REQUEST  persisted path=${request.path} sha256=${request.sha256}`);
    return 0;
  }
  if (operation === 'route') {
    const options = parseNamedOptions(rest, new Set(['--manifest', '--agent', '--runtime', '--signal', '--dispatch-id', '--attempt', '--request', '--operator-decision', '--controller-token']));
    requireOptions(options, ['manifest', 'agent', 'runtime', 'signal', 'dispatchId', 'attempt'], 'model route');
    assertTrustedModelRoutingAssets();
    const engagementContext = loadModelEngagement(options.manifest, options.agent);
    const attempt = positiveInteger(options.attempt, '--attempt');
    requirePinnedModelTrust(engagementContext);
    requireCurrentModelPreflight(engagementContext, options.agent, options.runtime);
    requireModelRouteAuthority(engagementContext, options);
    requirePreAllocationInitialRoute(engagementContext, options, attempt);
    const escalationBinding = bindModelEscalation(engagementContext, options, attempt);
    const availabilityBinding = bindModelUnavailable(engagementContext, options, attempt);
    const operatorDecision = bindOperatorDecision(engagementContext, options, attempt, escalationBinding, availabilityBinding);
    const createdAt = new Date().toISOString();
    const routingInput = {
      slug: options.agent,
      runtime: options.runtime,
      signal: options.signal,
      engagementId: engagementContext.engagement.engagementId,
      engagementManifestSha256: engagementContext.sha256,
      dispatchId: options.dispatchId,
      attempt,
      escalationBinding,
      availabilityBinding,
      operatorDecision,
      createdAt,
    };
    const preview = resolveModelDecision(policy, runtimeAdapters, routingInput);
    const candidate = preview;
    assertSchemaDocument(validateModelDecisionSchema, candidate, 'model decision');
    const decision = persistModelDecision(policy, candidate, engagementContext);
    console.log(JSON.stringify(decision));
    return decision.status === 'blocked' ? 2 : 0;
  }
  if (operation === 'telemetry') {
    const options = parseNamedOptions(rest, new Set([
      '--manifest', '--decision', '--token', '--input-tokens', '--output-tokens', '--duration-ms',
      '--reported-cost-usd', '--success',
    ]));
    requireOptions(options, ['manifest', 'decision', 'inputTokens', 'outputTokens', 'durationMs', 'success'], 'model telemetry');
    assertTrustedModelRoutingAssets();
    const engagementContext = loadModelEngagement(options.manifest);
    requirePinnedModelTrust(engagementContext);
    const decisionPath = resolveExistingPhysicalInput(options.decision, engagementContext.artifactRoot);
    const decisionDirectory = resolve(engagementContext.artifactRoot, policy.routing.decisionDirectory);
    if (!isWithin(engagementContext.artifactRoot, decisionPath) || dirname(decisionPath) !== decisionDirectory) {
      fail('model telemetry decision must be an exact file under ai_agents_internal/model-decisions');
    }
    assertPhysicalWithin(engagementContext.artifactRoot, decisionPath, 'model telemetry decision');
    if (existsSync(decisionPath) && (lstatSync(decisionPath).isSymbolicLink() || lstatSync(decisionPath).nlink !== 1)) fail('model telemetry decision cannot be a symbolic link or hard-link alias');
    if (!existsSync(decisionPath) || !statSync(decisionPath).isFile()) fail(`model telemetry decision is missing: ${decisionPath}`);
    const decision = readSecureJson(decisionPath, 'model telemetry decision');
    assertSchemaDocument(validateModelDecisionSchema, decision, 'model telemetry decision');
    const bindingErrors = validateModelDecisionBinding(policy, runtimeAdapters, decision, {
      engagementId: engagementContext.engagement.engagementId,
      engagementManifestSha256: engagementContext.sha256,
      decisionPath,
      artifactRoot: engagementContext.artifactRoot,
      modelTrust: engagementContext.engagement.modelTrust,
    });
    if (bindingErrors.length) fail(`model telemetry decision binding invalid: ${bindingErrors.join('; ')}`);
    if (!engagementContext.engagement.selectedAgents.includes(decision.agent)) fail(`model telemetry decision agent ${decision.agent} is not selected for the engagement`);
    if (decision.status === 'blocked') fail('model telemetry cannot record a blocked model decision');
    requireActiveLaneCapability(engagementContext, decision.agent, laneCapabilityToken(options), executionBindingForDecision(decision));
    const event = buildModelTelemetryEvent(policy, decision, {
      inputTokens: nonNegativeNumber(options.inputTokens, '--input-tokens'),
      outputTokens: nonNegativeNumber(options.outputTokens, '--output-tokens'),
      durationMs: nonNegativeNumber(options.durationMs, '--duration-ms'),
      reportedCostUsd: options.reportedCostUsd === undefined ? undefined : nonNegativeNumber(options.reportedCostUsd, '--reported-cost-usd'),
      success: parseBooleanOption(options.success, '--success'),
    });
    assertSchemaDocument(validateModelTelemetrySchema, event, 'model telemetry event');
    const relativeOutput = policy.telemetry.defaultPath;
    if (relativeOutput.startsWith('/') || relativeOutput.split('/').includes('..') || !relativeOutput.startsWith('ai_agents_internal/')) {
      fail('model telemetry output must stay under ai_agents_internal/');
    }
    const output = resolve(engagementContext.artifactRoot, relativeOutput);
    if (!isWithin(engagementContext.artifactRoot, output)) fail('model telemetry output escapes the engagement artifact root');
    mkdirSync(dirname(output), { recursive: true });
    assertPhysicalWithin(engagementContext.artifactRoot, output, 'model telemetry output');
    if (existsSync(output) && (lstatSync(output).isSymbolicLink() || lstatSync(output).nlink !== 1 || !statSync(output).isFile())) fail('model telemetry output must be a non-aliased real file');
    try {
      atomicPrivateAppend(output, `${JSON.stringify(event)}\n`, (current) => {
        const prior = current.trim().split('\n').filter(Boolean).map((line) => JSON.parse(line));
        if (prior.some((record) => record.decisionId === decision.decisionId)) throw new Error('model telemetry already contains an event for this immutable decision');
      });
    } catch (error) {
      fail(`model telemetry append failed: ${error.message}`);
    }
    console.log(`MODEL_TELEMETRY  recorded output=${output} event=${event.eventId}`);
    return 0;
  }
  fail('usage: argus-assets model <list|benchmark|trust|payload|request|route|telemetry> [options]');
}

function orchestrationCommand(args) {
  const [operation, ...rest] = args;
  if (operation !== 'plan') {
    fail('usage: argus-assets orchestration plan --mode <A|B|C|D> [--dispatchable <slug,slug>] [--artifact-root <path>] [--output <json|->]');
  }
  const options = parseNamedOptions(rest, new Set(['--mode', '--dispatchable', '--artifact-root', '--output']));
  requireOptions(options, ['mode'], 'orchestration plan');
  const dispatchable = options.dispatchable === undefined
    ? undefined
    : options.dispatchable.split(',').map((slug) => slug.trim()).filter(Boolean);
  if (dispatchable !== undefined && dispatchable.length !== new Set(dispatchable).size) {
    fail('orchestration plan --dispatchable contains duplicate slugs');
  }
  const projection = projectOrchestrationPlan(orchestrationPlan, matrix, options.mode, dispatchable, raciContract);
  const serialized = `${JSON.stringify(projection, null, 2)}\n`;
  if (options.output === undefined || options.output === '-') {
    process.stdout.write(serialized);
  } else {
    const artifactRoot = resolve(options.artifactRoot ?? process.cwd());
    if (!statSafe(artifactRoot)?.isDirectory()) fail('orchestration plan artifact root must be an existing directory');
    const output = resolve(artifactRoot, options.output);
    const controlRoot = join(artifactRoot, 'ai_agents_internal');
    const expectedOutput = join(controlRoot, 'orchestration-plan.json');
    if (output !== expectedOutput) fail('orchestration plan output must be ai_agents_internal/orchestration-plan.json');
    if (!safePhysicalPath(artifactRoot, output)) fail('orchestration plan output escapes its physical artifact root or crosses a symbolic link');
    mkdirSync(controlRoot, { recursive: true });
    if (existsSync(output)) {
      if (lstatSync(output).isSymbolicLink() || !statSync(output).isFile()) fail('existing orchestration plan output must be a real file');
      if (readFileSync(output, 'utf8') !== serialized) fail(`existing orchestration plan conflicts with requested projection: ${output}`);
      console.log(`UNCHANGED  ${output}`);
      return 0;
    }
    writeFileSync(output, serialized, { mode: 0o600, flag: 'wx' });
    chmodSync(output, 0o600);
    console.log(`WROTE  ${output}`);
  }
  return 0;
}

function persistPreflightOrchestrationPlan(artifactRoot, mode, dispatchable) {
  const projection = projectOrchestrationPlan(orchestrationPlan, matrix, mode, dispatchable, raciContract);
  const path = join(artifactRoot, 'ai_agents_internal', 'orchestration-plan.json');
  if (!safePhysicalPath(artifactRoot, path)) throw new Error('orchestration plan output is not physically safe');
  if (existsSync(path)) {
    const current = readSecureJson(path, 'orchestration plan');
    if (current.mode !== mode) throw new Error(`existing orchestration plan belongs to Mode ${current.mode}, not ${mode}`);
  }
  const serialized = `${JSON.stringify(projection, null, 2)}\n`;
  atomicPrivateWrite(path, serialized);
  return {
    path,
    sha256: createHash('sha256').update(serialized).digest('hex'),
    specialists: projection.waves.reduce((count, wave) => count + wave.roles.length, 0),
  };
}

function loadModelEngagement(explicitPath, requiredAgent) {
  const locatedManifestPath = locateEngagementManifest(process.cwd(), explicitPath);
  if (!locatedManifestPath) fail(`model routing engagement manifest is missing: ${resolve(explicitPath)}`);
  if (lstatSync(locatedManifestPath).isSymbolicLink()) fail('model routing engagement manifest may not be a symbolic link');
  const manifestPath = realpathSync(locatedManifestPath);
  const engagement = readSecureJson(manifestPath, 'model routing engagement manifest');
  const errors = validateEngagementManifest(engagement);
  if (errors.length) fail(`model routing engagement manifest invalid: ${errors.join('; ')}`);
  const declaredArtifactRoot = resolve(engagement.artifactRoot);
  if (!statSafe(declaredArtifactRoot)?.isDirectory()) fail('model routing artifactRoot must be an existing directory');
  const artifactRoot = realpathSync(declaredArtifactRoot);
  if (!isWithin(artifactRoot, manifestPath)) fail('model routing engagement manifest must stay under its artifactRoot');
  assertPhysicalWithin(artifactRoot, manifestPath, 'model routing engagement manifest');
  if (requiredAgent && !engagement.selectedAgents.includes(requiredAgent)) fail(`${requiredAgent} is not selected for engagement ${engagement.engagementId}`);
  return { engagement, manifestPath, artifactRoot, sha256: manifestSha256(engagement) };
}

function pinModelTrust(options) {
  const context = loadModelEngagement(options.manifest);
  const runtimeTrust = loadHostModelTrust(options.runtimeKeyId, 'runtime-attestation', context);
  const operatorTrust = loadHostModelTrust(options.operatorKeyId, 'operator-approval', context);
  if (runtimeTrust.sha256 !== operatorTrust.sha256) fail('model trust keys must come from the same secure host trust-store snapshot');
  const runtimeKey = pinnedTrustKey(runtimeTrust.record);
  const operatorKey = pinnedTrustKey(operatorTrust.record);
  if (runtimeKey.keyId === operatorKey.keyId || runtimeKey.keyFingerprintSha256 === operatorKey.keyFingerprintSha256) {
    fail('runtime-attestation and operator-approval trust anchors must be distinct');
  }
  const existing = context.engagement.modelTrust;
  if (existing) {
    if (existing.keys?.runtimeAttestation?.keyId === runtimeKey.keyId && existing.keys?.operatorApproval?.keyId === operatorKey.keyId && existing.trustStoreSha256 === runtimeTrust.sha256) {
      console.log(`MODEL_TRUST  unchanged runtime=${runtimeKey.keyFingerprintSha256} operator=${operatorKey.keyFingerprintSha256}`);
      return 0;
    }
    fail('model trust is immutable once pinned');
  }
  const state = getEngagementStatus(context.engagement);
  if (Object.values(state.allocations).some((allocation) => allocation.status === 'active')) {
    fail('model trust must be pinned before any allocation becomes active');
  }
  const decisionDirectory = join(context.artifactRoot, modelPolicy.routing.decisionDirectory);
  if (statSafe(decisionDirectory)?.isDirectory() && readdirSync(decisionDirectory).some((name) => /^MDR-[a-f0-9]{24}\.json$/.test(name))) {
    fail('model trust must be pinned before any model decision');
  }
  const updated = structuredClone(context.engagement);
  updated.modelTrust = {
    schema: 'argus/model-trust-bundle@1',
    source: 'host-trust-store',
    trustStorePath: runtimeTrust.path,
    trustStoreSha256: runtimeTrust.sha256,
    pinnedAt: new Date().toISOString(),
    keys: { runtimeAttestation: runtimeKey, operatorApproval: operatorKey },
  };
  const errors = validateEngagementManifest(updated);
  if (errors.length) fail(`pinned model trust makes engagement invalid: ${errors.join('; ')}`);
  atomicPrivateWrite(context.manifestPath, `${JSON.stringify(updated, null, 2)}\n`);
  console.log(`MODEL_TRUST  pinned runtimeKeyId=${runtimeKey.keyId} operatorKeyId=${operatorKey.keyId}`);
  return 0;
}

function loadHostModelTrust(keyId, expectedPurpose, context, explicitStorePath) {
  if (typeof keyId !== 'string' || !/^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$/.test(keyId)) fail('model trust key IDs must be stable identifiers');
  const configured = explicitStorePath ?? process.env.ARGUS_MODEL_TRUST_STORE;
  const storePath = configured ? resolve(configured) : join(userInfo().homedir, '.config', 'argus', 'model-trust.json');
  if (configured && configured !== resolve(configured)) fail('host model trust store path must be absolute');
  if (isWithin(context.artifactRoot, storePath)) fail('host model trust store must stay outside the engagement artifact root');
  const declaredTargetRoot = context.engagement.target?.root && resolve(context.engagement.target.root);
  const targetRoot = declaredTargetRoot && statSafe(declaredTargetRoot)?.isDirectory() ? realpathSync(declaredTargetRoot) : declaredTargetRoot;
  if (targetRoot && isWithin(targetRoot, storePath)) fail('host model trust store must stay outside the target root');
  const directory = dirname(storePath);
  let directoryStat;
  let pathStat;
  try {
    directoryStat = lstatSync(directory);
    pathStat = lstatSync(storePath);
  } catch (error) {
    fail(`host model trust store is unavailable: ${error.message}`);
  }
  const uid = typeof process.getuid === 'function' ? process.getuid() : null;
  if (!directoryStat.isDirectory() || directoryStat.isSymbolicLink() || (uid !== null && directoryStat.uid !== uid) || (directoryStat.mode & 0o022) !== 0) {
    fail('host model trust store directory must be a real, current-user-owned, non-group/world-writable directory');
  }
  if (!pathStat.isFile() || pathStat.isSymbolicLink() || pathStat.nlink !== 1 || (uid !== null && pathStat.uid !== uid) || (pathStat.mode & 0o133) !== 0) {
    fail('host model trust store must be a real, single-link, current-user-owned, non-writable-by-others, non-executable file');
  }
  if (realpathSync(storePath) !== storePath) fail('host model trust store path may not traverse symbolic links');
  let descriptor;
  let raw;
  try {
    descriptor = openSync(storePath, constants.O_RDONLY | (constants.O_NOFOLLOW ?? 0));
    const opened = fstatSync(descriptor);
    if (opened.dev !== pathStat.dev || opened.ino !== pathStat.ino || !opened.isFile() || opened.nlink !== 1) fail('host model trust store changed during secure open');
    raw = readFileSync(descriptor);
  } finally {
    if (descriptor !== undefined) closeSync(descriptor);
  }
  let document;
  try { document = JSON.parse(raw.toString('utf8')); }
  catch (error) { fail(`host model trust store is not valid JSON: ${error.message}`); }
  assertSchemaDocument(validateModelTrustStoreSchema, document, 'host model trust store');
  const keyIds = document.keys.map((record) => record.keyId);
  if (new Set(keyIds).size !== keyIds.length) fail('host model trust store keyIds must be unique');
  const record = document.keys.find((candidate) => candidate.keyId === keyId);
  if (!record) fail(`host model trust store has no keyId ${keyId}`);
  if (record.status !== 'active') fail(`host model trust key ${keyId} is not active`);
  if (record.purpose !== expectedPurpose) fail(`host model trust key ${keyId} is not authorized for ${expectedPurpose}`);
  return { record, sha256: createHash('sha256').update(raw).digest('hex'), path: storePath };
}

function pinnedTrustKey(record) {
  let keyFingerprintSha256;
  try { keyFingerprintSha256 = modelPublicKeyFingerprint(record.publicKeyPem); }
  catch (error) { fail(`model trust public key invalid: ${error.message}`); }
  return {
    keyId: record.keyId,
    purpose: record.purpose,
    subjectId: record.subjectId,
    algorithm: 'Ed25519',
    publicKeyPem: record.publicKeyPem,
    keyFingerprintSha256,
  };
}

function requirePinnedModelTrust(context) {
  const trust = context.engagement.modelTrust;
  if (!trust || trust.schema !== 'argus/model-trust-bundle@1' || trust.source !== 'host-trust-store' || !/^[a-f0-9]{64}$/.test(trust.trustStoreSha256 ?? '')) {
    fail('model routing requires a complete purpose-separated host trust bundle');
  }
  const expected = { runtimeAttestation: 'runtime-attestation', operatorApproval: 'operator-approval' };
  for (const [slot, purpose] of Object.entries(expected)) {
    const key = trust.keys?.[slot];
    let fingerprint;
    try { fingerprint = modelPublicKeyFingerprint(key?.publicKeyPem); }
    catch (error) { fail(`model trust ${slot} key invalid: ${error.message}`); }
    if (key?.algorithm !== 'Ed25519' || key.purpose !== purpose || !nonEmptyString(key.subjectId) ||
        !/^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$/.test(key.keyId ?? '') || key.keyFingerprintSha256 !== fingerprint) {
      fail(`model trust ${slot} binding is incomplete`);
    }
  }
  if (trust.keys.runtimeAttestation.keyId === trust.keys.operatorApproval.keyId ||
      trust.keys.runtimeAttestation.keyFingerprintSha256 === trust.keys.operatorApproval.keyFingerprintSha256) {
    fail('model trust purposes must use distinct keys');
  }
  for (const [slot, purpose] of Object.entries(expected)) {
    const live = loadHostModelTrust(trust.keys[slot].keyId, purpose, context, trust.trustStorePath).record;
    const fingerprint = modelPublicKeyFingerprint(live.publicKeyPem);
    if (live.subjectId !== trust.keys[slot].subjectId || fingerprint !== trust.keys[slot].keyFingerprintSha256) {
      fail(`live model trust ${slot} differs from the pinned identity; abort this engagement`);
    }
  }
}

function requireCurrentModelPreflight(context, agent, runtime) {
  const path = join(context.artifactRoot, 'ai_agents_internal', 'preflight.json');
  if (!safePhysicalPath(context.artifactRoot, path) || !statSafe(path)?.isFile() || lstatSync(path).isSymbolicLink() || lstatSync(path).nlink !== 1) {
    fail('model routing requires a current, non-aliased ai_agents_internal/preflight.json');
  }
  const raw = readSecureSingleLink(path, 'model routing preflight report');
  let report;
  try { report = JSON.parse(raw.toString('utf8')); }
  catch (error) { fail(`model routing preflight report is not valid JSON: ${error.message}`); }
  assertSchemaDocument(validatePreflightReportSchema, report, 'model routing preflight report');
  if (!['ready', 'degraded'].includes(report.status)) fail(`model routing preflight status is not dispatchable: ${report.status}`);
  if (report.modelRuntime !== runtime) fail(`model routing preflight runtime ${report.modelRuntime} differs from ${runtime}`);
  if (resolve(report.artifactRoot.path) !== context.artifactRoot || resolve(report.engagement.manifestPath) !== context.manifestPath) {
    fail('model routing preflight is bound to a different artifact root or engagement manifest');
  }
  if (report.engagement.sha256 !== context.sha256) fail('model routing preflight engagement digest is stale; rerun preflight after every manifest change');
  if (report.mode !== context.engagement.mode) fail('model routing preflight mode differs from the engagement');
  const disposition = report.agents.find((entry) => entry.slug === agent);
  if (!disposition?.selected || !['ready', 'degraded'].includes(disposition.status) || (agent !== 'odysseus' && disposition.dispatchAllowed !== true)) {
    fail(`${agent} is not dispatchable in the current model routing preflight`);
  }
  return { report, path, sha256: createHash('sha256').update(raw).digest('hex') };
}

function requirePreAllocationInitialRoute(context, options, attempt) {
  if (options.signal !== 'normal' || attempt !== 1) return;
  const existing = selectedModelDecisions(context, options.agent, options.runtime, options.dispatchId, attempt);
  if (existing.length > 1) fail('multiple selected model decisions already exist for the exact dispatch attempt');
  if (existing.length === 1) return;
  const state = getEngagementStatus(context.engagement);
  const active = Object.values(state.allocations).filter((allocation) => allocation.status === 'active');
  if (active.length > 0) fail('normal attempt 1 must be selected before any allocation becomes active');
}

function laneCapabilityToken(options) {
  const token = options.token ?? process.env.ARGUS_ENGAGEMENT_LEASE_TOKEN;
  if (!nonEmptyString(token)) fail('model operation requires --token or ARGUS_ENGAGEMENT_LEASE_TOKEN for the active lane');
  return token;
}

function controllerCapabilityToken(options) {
  return options.controllerToken ?? process.env.ARGUS_ENGAGEMENT_CONTROLLER_TOKEN;
}

function requireModelRouteAuthority(context, options) {
  const state = getEngagementStatus(context.engagement);
  if (!Object.values(state.allocations).some((allocation) => allocation.status === 'active')) return;
  const token = controllerCapabilityToken(options);
  if (!nonEmptyString(token)) fail('model route requires the active Odysseus controller token after allocation starts');
  requireActiveLaneCapability(context, 'odysseus', token);
}

function requireActiveLaneCapability(context, lane, token, expectedBinding) {
  const state = getEngagementStatus(context.engagement);
  const allocation = state.allocations?.[lane];
  if (!allocation || allocation.status !== 'active' || !nonEmptyString(token) ||
      createHash('sha256').update(token).digest('hex') !== allocation.leaseTokenSha256) {
    fail(`model operation requires the exact active ${lane} lane capability`);
  }
  if (expectedBinding && Object.entries(expectedBinding).some(([field, value]) => allocation[field] !== value)) {
    fail(`model operation decision differs from the active ${lane} allocation`);
  }
  const path = join(context.artifactRoot, context.engagement.writePolicy.workerRoot, lane, '.lease');
  if (!safePhysicalPath(context.artifactRoot, path) || !statSafe(path)?.isFile() || lstatSync(path).isSymbolicLink() || lstatSync(path).nlink !== 1) {
    fail(`model operation requires the live non-aliased ${lane} lease marker`);
  }
  const content = readSecureSingleLink(path, `${lane} lease marker`).toString('utf8').trim();
  if (content !== `allocation:${allocation.allocationId}`) {
    fail(`model operation ${lane} lease marker differs from the active allocation`);
  }
  return allocation;
}

function persistModelEscalationRequest(context, options, attempt) {
  const role = modelPolicy.roles.find((item) => item.slug === options.agent);
  if (!role) fail(`unknown model-policy role: ${options.agent}`);
  if (!['claude', 'codex'].includes(options.runtime)) fail('model request --runtime must be claude or codex');
  if (!modelPolicy.escalationProfiles[role.escalationProfile].includes(options.signal)) {
    fail(`model request signal is not declared for ${options.agent}: ${options.signal}`);
  }
  const request = {
    schema: 'argus/model-escalation-request@1',
    kind: 'MODEL_ESCALATION_REQUEST',
    engagementId: context.engagement.engagementId,
    dispatchId: options.dispatchId,
    attempt,
    agent: options.agent,
    signal: options.signal,
    checkpointRef: options.checkpointRef,
    resumable: true,
  };
  const errors = validateCanonicalDocument('model-escalation-request', request);
  if (errors.length > 0) fail(`model escalation request is invalid: ${errors.join('; ')}`);
  const serialized = `${JSON.stringify(request, null, 2)}\n`;
  validateModelEscalationState(context, request, options.runtime, serialized);
  const sha256 = createHash('sha256').update(serialized).digest('hex');
  const path = join(context.artifactRoot, 'ai_agents_internal', 'model-requests', `MER-${sha256.slice(0, 24)}.json`);
  if (!safePhysicalPath(context.artifactRoot, path)) fail('model escalation request output is physically unsafe');
  if (existsSync(path)) {
    if (lstatSync(path).isSymbolicLink() || lstatSync(path).nlink !== 1 || !statSync(path).isFile() || readFileSync(path, 'utf8') !== serialized) {
      fail('existing model escalation request differs from its deterministic identity');
    }
  } else atomicPrivateWrite(path, serialized);
  return { path, relativePath: relative(context.artifactRoot, path).split(sep).join('/'), sha256 };
}

function bindModelEscalation(context, options, attempt) {
  const role = modelPolicy.roles.find((item) => item.slug === options.agent);
  if (!role) fail(`unknown model-policy role: ${options.agent}`);
  const workerSignal = modelPolicy.escalationProfiles[role.escalationProfile].includes(options.signal);
  if (!workerSignal) {
    if (options.request) fail('model route --request is valid only for a declared worker escalation signal');
    if (options.signal === 'normal' && attempt !== 1) fail('normal model routing is valid only for attempt 1');
    return null;
  }
  if (!options.request) fail('declared worker escalation requires --request <model-escalation-request.json>');
  const requestPath = resolveExistingPhysicalInput(options.request, context.artifactRoot);
  const requestDirectory = join(context.artifactRoot, 'ai_agents_internal', 'model-requests');
  if (dirname(requestPath) !== requestDirectory || !safePhysicalPath(context.artifactRoot, requestPath) || !statSafe(requestPath)?.isFile() || lstatSync(requestPath).isSymbolicLink() || lstatSync(requestPath).nlink !== 1) {
    fail('model escalation request must be an exact non-aliased file under ai_agents_internal/model-requests');
  }
  const raw = readSecureSingleLink(requestPath, 'model escalation request');
  const requestSha256 = createHash('sha256').update(raw).digest('hex');
  if (basename(requestPath) !== `MER-${requestSha256.slice(0, 24)}.json`) fail('model escalation request filename differs from its deterministic content digest');
  let request;
  try { request = JSON.parse(raw); }
  catch { fail('model escalation request is not valid JSON'); }
  const requestErrors = validateCanonicalDocument('model-escalation-request', request);
  if (requestErrors.length > 0) fail(`model escalation request is invalid: ${requestErrors.join('; ')}`);
  for (const [field, expected] of Object.entries({
    engagementId: context.engagement.engagementId,
    dispatchId: options.dispatchId,
    attempt,
    agent: options.agent,
    signal: options.signal,
  })) {
    if (request[field] !== expected) fail(`model escalation request ${field} does not match the route`);
  }
  return validateModelEscalationState(context, request, options.runtime, raw);
}

function bindModelUnavailable(context, options, attempt) {
  if (options.signal !== 'model-unavailable') return null;
  if (options.request) fail('model-unavailable is bound to a prior selected decision and does not accept --request');
  if (attempt < 2) fail('model-unavailable requires an attempt after a selected route');
  const state = getEngagementStatus(context.engagement);
  const allocation = state.allocations[options.agent];
  if (!allocation || allocation.status !== 'active') fail('model-unavailable requires an active allocation for the exact agent');
  const previous = findPreviousModelDecision(context, {
    agent: options.agent,
    dispatchId: options.dispatchId,
    attempt,
  }, options.runtime);
  requireAllocationExecutionAncestor(allocation, previous, 'model-unavailable');
  const statePath = resolve(context.artifactRoot, context.engagement.statePath);
  if (!isWithin(context.artifactRoot, statePath) || !safePhysicalPath(context.artifactRoot, statePath) || !statSafe(statePath)?.isFile() || lstatSync(statePath).isSymbolicLink() || lstatSync(statePath).nlink !== 1) {
    fail('model-unavailable engagement state is missing, aliased, or physically unsafe');
  }
  return {
    previousDecisionId: previous.decisionId,
    previousDecisionIntegritySha256: previous.integritySha256,
    allocationId: allocation.allocationId,
    allocationSha256: createHash('sha256').update(JSON.stringify(allocation)).digest('hex'),
  };
}

function validateModelEscalationState(context, request, runtime, raw) {
  const state = getEngagementStatus(context.engagement);
  const checkpoint = state.checkpoints[request.agent];
  const allocation = state.allocations[request.agent];
  if (!checkpoint || !allocation || allocation.status !== 'active') fail('model escalation requires an active allocation and current checkpoint');
  if (checkpoint.path !== request.checkpointRef || checkpoint.dispatchId !== request.dispatchId || checkpoint.attempt !== request.attempt - 1 || checkpoint.allocationId !== allocation.allocationId) {
    fail('model escalation checkpoint is stale or belongs to another execution');
  }
  const checkpointPath = resolve(context.artifactRoot, checkpoint.path);
  if (!isWithin(context.artifactRoot, checkpointPath) || !safePhysicalPath(context.artifactRoot, checkpointPath) || !statSafe(checkpointPath)?.isFile() || lstatSync(checkpointPath).isSymbolicLink() || lstatSync(checkpointPath).nlink !== 1) {
    fail('model escalation checkpoint is missing, aliased, or physically unsafe');
  }
  const checkpointSha256 = createHash('sha256').update(readFileSync(checkpointPath)).digest('hex');
  if (checkpointSha256 !== checkpoint.sha256) fail('model escalation checkpoint digest differs from engagement state');
  const previous = findPreviousModelDecision(context, request, runtime);
  requireAllocationExecutionAncestor(allocation, previous, 'model escalation');
  return {
    requestSha256: createHash('sha256').update(raw).digest('hex'),
    checkpointRef: checkpoint.path,
    checkpointSha256,
    previousDecisionId: previous.decisionId,
  };
}

function requireAllocationExecutionAncestor(allocation, previous, label) {
  if (allocation.modelDecisionId !== previous.decisionId ||
      allocation.modelDecisionIntegritySha256 !== previous.integritySha256 ||
      allocation.dispatchId !== previous.dispatchId ||
      allocation.attempt !== previous.attempt ||
      allocation.runtime !== previous.runtime) {
    fail(`${label} attempt-1 ancestor differs from the active allocation model decision`);
  }
}

function bindOperatorDecision(context, options, attempt, escalationBinding, availabilityBinding) {
  if (!options.operatorDecision) return null;
  const role = modelPolicy.roles.find((item) => item.slug === options.agent);
  const unavailable = options.signal === 'model-unavailable';
  const declared = role && modelPolicy.escalationProfiles[role.escalationProfile].includes(options.signal);
  if (role?.tier !== 'frontier' || (!declared && !unavailable)) fail('operator decision is valid only for a declared or unavailable frontier escalation');
  if (unavailable && (!availabilityBinding || escalationBinding || options.request)) fail('frontier unavailability requires the exact prior-decision/allocation binding');
  if (!unavailable && (!escalationBinding || !options.request || availabilityBinding)) fail('declared frontier escalation requires a validated worker escalation request');
  const path = resolveExistingPhysicalInput(options.operatorDecision);
  const directory = join(context.artifactRoot, 'ai_agents_internal', 'operator-decisions');
  if (dirname(path) !== directory || !safePhysicalPath(context.artifactRoot, path) || !statSafe(path)?.isFile() || lstatSync(path).isSymbolicLink() || lstatSync(path).nlink !== 1) {
    fail('operator decision must be a non-aliased real file directly under ai_agents_internal/operator-decisions');
  }
  const raw = readSecureSingleLink(path, 'operator decision');
  let document;
  try { document = JSON.parse(raw); }
  catch { fail('operator decision is not valid JSON'); }
  assertSchemaDocument(validateModelOperatorDecisionSchema, document, 'operator decision');
  let authentication;
  try { authentication = verifyModelDocumentAuthentication(document, context.engagement.modelTrust); }
  catch (error) { fail(`operator decision authentication failed: ${error.message}`); }
  if (unavailable && !['retry-frontier', 'abort'].includes(document.action)) fail('model-unavailable operator action must be retry-frontier or abort');
  if (!unavailable && !['continue-frontier', 'abort'].includes(document.action)) fail('declared frontier escalation operator action must be continue-frontier or abort');
  for (const [field, expected] of Object.entries({
    engagementId: context.engagement.engagementId,
    dispatchId: options.dispatchId,
    attempt,
    agent: options.agent,
    signal: options.signal,
  })) {
    if (document[field] !== expected) fail(`operator decision ${field} does not match the route`);
  }
  const blockedPath = join(context.artifactRoot, modelPolicy.routing.decisionDirectory, `${document.blockedDecisionId}.json`);
  if (!safePhysicalPath(context.artifactRoot, blockedPath) || !statSafe(blockedPath)?.isFile() || lstatSync(blockedPath).isSymbolicLink() || lstatSync(blockedPath).nlink !== 1) {
    fail('operator decision references a missing, aliased, or unsafe blocked decision');
  }
  const blocked = readSecureJson(blockedPath, 'operator-blocked model decision');
  assertSchemaDocument(validateModelDecisionSchema, blocked, 'operator-blocked model decision');
  const bindingErrors = validateModelDecisionBinding(modelPolicy, runtimeAdapters, blocked, {
    engagementId: context.engagement.engagementId,
    engagementManifestSha256: context.sha256,
    decisionPath: blockedPath,
    artifactRoot: context.artifactRoot,
    modelTrust: context.engagement.modelTrust,
  });
  if (bindingErrors.length > 0) fail(`operator-blocked decision binding invalid: ${bindingErrors.join('; ')}`);
  const expectedBlockedReason = unavailable ? 'FRONTIER_UNAVAILABLE' : 'OPERATOR_ESCALATION_REQUIRED';
  const exactRouteBinding = unavailable
    ? JSON.stringify(blocked.availabilityBinding) === JSON.stringify(availabilityBinding) && blocked.escalationBinding === null
    : JSON.stringify(blocked.escalationBinding) === JSON.stringify(escalationBinding) && blocked.availabilityBinding === null;
  if (blocked.status !== 'blocked' || blocked.reasonCode !== expectedBlockedReason || blocked.operatorEscalation !== true ||
      blocked.dispatchId !== options.dispatchId || blocked.attempt !== attempt || blocked.agent !== options.agent || blocked.runtime !== options.runtime || blocked.signal !== options.signal ||
      !exactRouteBinding) {
    fail('operator decision does not reference the exact pending frontier escalation');
  }
  if (Date.parse(document.approvedAt) < Date.parse(blocked.createdAt)) fail('operator decision predates the blocked escalation');
  if (Date.parse(document.approvedAt) > Date.now() + 300_000) fail('operator decision approval time is unreasonably far in the future');
  const binding = {
    action: document.action,
    documentSha256: modelAuthenticatedDocumentSha256(document),
    blockedDecisionId: blocked.decisionId,
    approvedBy: document.approvedBy,
    approvedAt: document.approvedAt,
    reason: document.reason,
    authentication,
  };
  persistOperatorResolution(context, binding);
  return binding;
}

function persistOperatorResolution(context, binding) {
  const output = join(context.artifactRoot, modelPolicy.routing.decisionDirectory, `OPR-${binding.blockedDecisionId.slice(4)}.json`);
  if (!safePhysicalPath(context.artifactRoot, output)) fail('operator resolution output is physically unsafe');
  const serialized = `${JSON.stringify(binding, null, 2)}\n`;
  mkdirSync(dirname(output), { recursive: true });
  const temporary = `${output}.${process.pid}.${randomBytes(6).toString('hex')}.tmp`;
  writeFileSync(temporary, serialized, { flag: 'wx', mode: 0o600 });
  let created = false;
  try {
    linkSync(temporary, output);
    created = true;
  } catch (error) {
    if (error.code !== 'EEXIST') throw error;
    if (lstatSync(output).isSymbolicLink() || lstatSync(output).nlink !== 1 || !statSync(output).isFile() || readFileSync(output, 'utf8') !== serialized) {
      fail('frontier escalation already has a different immutable operator resolution');
    }
  } finally {
    rmSync(temporary, { force: true });
  }
  if (created) chmodSync(output, 0o600);
}

function findPreviousModelDecision(context, request, runtime) {
  const matches = selectedModelDecisions(context, request.agent, runtime, request.dispatchId, request.attempt - 1);
  if (matches.length !== 1) fail(`model escalation requires exactly one selected decision for attempt ${request.attempt - 1}`);
  return matches[0];
}

function selectedModelDecisions(context, agent, runtime, dispatchId, attempt) {
  const directory = join(context.artifactRoot, modelPolicy.routing.decisionDirectory);
  if (!existsSync(directory)) return [];
  if (!safePhysicalPath(context.artifactRoot, directory) || !statSafe(directory)?.isDirectory() || lstatSync(directory).isSymbolicLink()) fail('model decision directory is unsafe');
  const matches = [];
  for (const name of readdirSync(directory).filter((item) => /^MDR-[a-f0-9]{24}\.json$/.test(item))) {
    const path = join(directory, name);
    if (!safePhysicalPath(context.artifactRoot, path) || !statSafe(path)?.isFile() || lstatSync(path).isSymbolicLink() || lstatSync(path).nlink !== 1) fail(`model decision path is unsafe or aliased: ${name}`);
    const decision = readSecureJson(path, 'previous model decision');
    assertSchemaDocument(validateModelDecisionSchema, decision, 'previous model decision');
    if ((agent !== undefined && decision.agent !== agent) ||
        (runtime !== undefined && decision.runtime !== runtime) ||
        (dispatchId !== undefined && decision.dispatchId !== dispatchId) ||
        (attempt !== undefined && decision.attempt !== attempt) ||
        decision.status !== 'selected') continue;
    const errors = validateModelDecisionBinding(modelPolicy, runtimeAdapters, decision, {
      engagementId: context.engagement.engagementId,
      engagementManifestSha256: context.sha256,
      decisionPath: path,
      artifactRoot: context.artifactRoot,
      modelTrust: context.engagement.modelTrust,
    });
    if (errors.length > 0) fail(`previous model decision binding invalid: ${errors.join('; ')}`);
    matches.push(decision);
  }
  return matches;
}

function assertTrustedModelRoutingAssets() {
  for (const id of ['model-policy', 'runtime-adapters', 'runtime-schemas']) {
    assertPackagedAsset(requireAsset(id), `trusted ${id}`);
  }
  assertSchemaDocument(validateModelPolicySchema, modelPolicy, 'model policy');
  assertSchemaDocument(validateRuntimeAdapters, runtimeAdapters, 'runtime adapter snapshot');
}

function persistModelDecision(policy, candidate, context) {
  if (candidate.status === 'selected' && candidate.signal === 'normal' && candidate.attempt === 1) {
    return withInitialModelControlLock(context, () => {
      const exact = selectedModelDecisions(context, candidate.agent, candidate.runtime, candidate.dispatchId, candidate.attempt);
      const allInitial = selectedModelDecisions(context, candidate.agent, undefined, undefined, candidate.attempt)
        .filter((decision) => decision.signal === 'normal');
      if (allInitial.some((decision) => !sameSelectedExecution(decision, candidate))) {
        fail('a different selected normal attempt-1 decision already exists for this agent in the engagement');
      }
      if (exact.length === 0) {
        if (loadModelControlSeal(context, { required: false })) fail('normal attempt 1 cannot be added after the initial model-control set was sealed');
        const state = getEngagementStatus(context.engagement);
        if (Object.values(state.allocations).some((allocation) => allocation.status === 'active')) {
          fail('normal attempt 1 must be selected before any allocation becomes active');
        }
      }
      return persistModelDecisionUnlocked(policy, candidate, context);
    });
  }
  return persistModelDecisionUnlocked(policy, candidate, context);
}

function persistModelDecisionUnlocked(policy, candidate, context) {
  if (candidate.status !== 'selected') return persistModelDecisionFile(policy, candidate, context);
  const directory = resolve(context.artifactRoot, policy.routing.decisionDirectory);
  if (!safePhysicalPath(context.artifactRoot, directory)) fail('model selection directory is physically unsafe');
  mkdirSync(directory, { recursive: true });
  if (lstatSync(directory).isSymbolicLink() || !statSync(directory).isDirectory()) fail('model selection directory must be a real directory');
  const key = createHash('sha256').update(`${candidate.engagementId}\0${candidate.agent}\0${candidate.runtime}\0${candidate.dispatchId}\0${candidate.attempt}`).digest('hex').slice(0, 24);
  const lock = join(directory, `.selection-${key}.lock`);
  let acquired = false;
  for (let attempt = 0; attempt < 6000; attempt += 1) {
    try {
      mkdirSync(lock, { mode: 0o700 });
      writeFileSync(join(lock, 'owner.json'), `${JSON.stringify({ pid: process.pid, acquiredAt: new Date().toISOString() })}\n`, { flag: 'wx', mode: 0o600 });
      acquired = true;
      break;
    }
    catch (error) {
      if (error.code !== 'EEXIST') {
        rmSync(lock, { recursive: true, force: true });
        fail(`cannot acquire unique model selection lock: ${error.message}`);
      }
      const current = lstatSync(lock);
      if (current.isSymbolicLink() || !current.isDirectory()) fail('model selection lock is unsafe');
      reclaimAbandonedModelControlLock(lock);
      Atomics.wait(new Int32Array(new SharedArrayBuffer(4)), 0, 0, 10);
    }
  }
  if (!acquired) fail('timed out acquiring unique model selection lock');
  try {
    const existing = selectedModelDecisions(context, candidate.agent, candidate.runtime, candidate.dispatchId, candidate.attempt);
    if (existing.length > 1) fail('multiple selected model decisions exist for the exact dispatch attempt');
    if (existing.length === 1) {
      if (!sameSelectedExecution(existing[0], candidate)) fail('a conflicting selected model decision already exists for the exact dispatch attempt');
      return existing[0];
    }
    return persistModelDecisionFile(policy, candidate, context);
  } finally {
    rmSync(lock, { recursive: true, force: true });
  }
}

function sameSelectedExecution(left, right) {
  const select = (decision) => {
    const { createdAt, decisionId, integritySha256, relativePath, ...immutableExecution } = decision;
    return immutableExecution;
  };
  return JSON.stringify(select(left)) === JSON.stringify(select(right));
}

function persistModelDecisionFile(policy, candidate, context) {
  const output = resolve(context.artifactRoot, candidate.relativePath);
  if (!isWithin(context.artifactRoot, output)) fail('model decision path escapes the engagement artifact root');
  mkdirSync(dirname(output), { recursive: true });
  assertPhysicalWithin(context.artifactRoot, output, 'model decision output');
  if (existsSync(output) && (lstatSync(output).isSymbolicLink() || lstatSync(output).nlink !== 1 || !statSync(output).isFile())) fail('model decision output must be a non-aliased real file');
  if (existsSync(output)) {
    const existing = readJson(output);
    assertSchemaDocument(validateModelDecisionSchema, existing, 'persisted model decision');
    const errors = validateModelDecisionBinding(policy, runtimeAdapters, existing, {
      engagementId: context.engagement.engagementId,
      engagementManifestSha256: context.sha256,
      decisionPath: output,
      artifactRoot: context.artifactRoot,
      modelTrust: context.engagement.modelTrust,
    });
    if (errors.length) fail(`persisted model decision binding invalid: ${errors.join('; ')}`);
    if (existing.decisionId !== candidate.decisionId) fail('model decision identity collision');
    return existing;
  }
  const serialized = `${JSON.stringify(candidate, null, 2)}\n`;
  const temporary = `${output}.${process.pid}.${createHash('sha256').update(`${candidate.decisionId}:${Date.now()}`).digest('hex').slice(0, 12)}.tmp`;
  writeFileSync(temporary, serialized, { flag: 'wx', mode: 0o600 });
  let created = false;
  try {
    linkSync(temporary, output);
    created = true;
  } catch (error) {
    if (error.code !== 'EEXIST') throw error;
    if (lstatSync(output).isSymbolicLink() || lstatSync(output).nlink !== 1 || !statSync(output).isFile() || readFileSync(output, 'utf8') !== serialized) {
      fail('concurrent model decision differs from the immutable candidate or uses an aliased inode');
    }
    const existing = readJson(output);
    if (existing.decisionId !== candidate.decisionId) fail('concurrent model decision identity collision');
  } finally {
    rmSync(temporary, { force: true });
  }
  if (created) chmodSync(output, 0o600);
  const persisted = readJson(output);
  const errors = validateModelDecisionBinding(policy, runtimeAdapters, persisted, {
    engagementId: context.engagement.engagementId,
    engagementManifestSha256: context.sha256,
    decisionPath: output,
    artifactRoot: context.artifactRoot,
    modelTrust: context.engagement.modelTrust,
  });
  if (errors.length) fail(`persisted model decision binding invalid: ${errors.join('; ')}`);
  return persisted;
}

function assertSchemaDocument(validate, document, label) {
  const errors = validate(document);
  if (errors.length) fail(`${label} does not satisfy its schema: ${formatSchemaErrors(errors)}`);
}

function formatSchemaErrors(errors) {
  return errors.map((error) => `${error.instancePath || '/'} ${error.message}`).join('; ');
}

function positiveInteger(value, label) {
  if (!/^[1-9][0-9]*$/.test(String(value))) fail(`${label} must be a positive integer`);
  const parsed = Number(value);
  if (!Number.isSafeInteger(parsed)) fail(`${label} must be a safe positive integer`);
  return parsed;
}

function nonNegativeInteger(value, label) {
  if (!/^(?:0|[1-9][0-9]*)$/.test(String(value))) fail(`${label} must be a non-negative integer`);
  const parsed = Number(value);
  if (!Number.isSafeInteger(parsed)) fail(`${label} must be a safe non-negative integer`);
  return parsed;
}

function nonNegativeNumber(value, label) {
  const parsed = Number(value);
  if (!Number.isFinite(parsed) || parsed < 0) fail(`${label} must be a non-negative number`);
  return parsed;
}

function assertPhysicalWithin(root, path, label) {
  if (!safePhysicalPath(root, path)) fail(`${label} escapes the physical engagement artifact root or crosses a symbolic link`);
}

function safePhysicalPath(root, path) {
  try {
    const lexicalRoot = resolve(root);
    const lexicalPath = resolve(path);
    if (!isWithin(lexicalRoot, lexicalPath)) return false;
    let cursor = lexicalPath;
    const suffix = [];
    while (!existsSync(cursor)) {
      const parent = dirname(cursor);
      if (parent === cursor) return false;
      suffix.unshift(basename(cursor));
      cursor = parent;
    }
    const physical = resolve(realpathSync(cursor), ...suffix);
    if (!isWithin(realpathSync(lexicalRoot), physical)) return false;
    cursor = lexicalRoot;
    for (const part of relative(lexicalRoot, lexicalPath).split(sep).filter(Boolean)) {
      cursor = join(cursor, part);
      if (!existsSync(cursor)) break;
      if (lstatSync(cursor).isSymbolicLink()) return false;
    }
    return true;
  } catch {
    return false;
  }
}

function raciCommand(args) {
  const [operation, ...rest] = args;
  const raci = readJson(RACI_PATH);
  if (operation === 'list') {
    for (const route of raci.surfaceRoutes) console.log(`${route.surface}\tdiscover=${route.discover}\tbaseline=${route.baseline}\tautomate=${route.automate}\tvalidate=${route.validate}\treport=${route.report}${route.gate ? `\tgate=${route.gate}` : ''}`);
    return 0;
  }
  if (operation !== 'route') fail('usage: argus-assets raci <list|route> [options]');
  const options = parseNamedOptions(rest, new Set(['--surface', '--activity', '--artifact', '--transition']));
  const selectors = ['artifact', 'transition', 'surface'].filter((key) => options[key]);
  if (options.activity && !options.surface) selectors.push('activity');
  if (selectors.length !== 1) fail('raci route requires exactly one of --surface, --artifact, or --transition');
  let result;
  if (options.artifact) {
    const artifact = raci.artifacts.find((item) => item.path === options.artifact);
    if (!artifact) fail(`raci route: unknown canonical artifact ${options.artifact}`);
    result = { selector: 'artifact', artifact: artifact.path, accountable: artifact.accountable };
  } else if (options.transition) {
    const [stateMachine, from, to, ...extra] = options.transition.split(':');
    if (!stateMachine || !from || !to || extra.length) fail('raci route --transition must be machine:from:to');
    const transition = raci.stateTransitions.find((item) => item.stateMachine === stateMachine && item.from === from && item.to === to);
    if (!transition) fail(`raci route: unknown state transition ${options.transition}`);
    result = { selector: 'transition', stateMachine, from, to, accountable: transition.accountable };
  } else if (options.surface) {
    requireOptions(options, ['surface', 'activity'], 'raci route');
    const route = raci.surfaceRoutes.find((item) => item.surface === options.surface);
    if (!route) fail(`raci route: unknown surface ${options.surface}`);
    if (!['discover', 'baseline', 'automate', 'validate', 'report'].includes(options.activity)) fail('raci route --activity must be discover, baseline, automate, validate, or report for a surface');
    result = { selector: 'surface', surface: route.surface, activity: options.activity, accountable: route[options.activity], gate: route.gate ?? null };
  } else {
    const activity = raci.defectLifecycle.find((item) => item.activity === options.activity);
    if (!activity) fail(`raci route: unknown defect activity ${options.activity}`);
    result = { selector: 'defect-activity', activity: activity.activity, accountable: activity.accountable, responsible: activity.responsible, consulted: activity.consulted ?? [] };
  }
  console.log(JSON.stringify(result));
  return 0;
}

function coverageCommand(args) {
  const [operation, ...rest] = args;
  if (!['validate', 'calculate'].includes(operation)) fail('usage: argus-assets coverage <validate|calculate> --inventory <json> --observations <json> [--output <json|->]');
  const allowed = operation === 'calculate' ? new Set(['--inventory', '--observations', '--output']) : new Set(['--inventory', '--observations']);
  const options = parseNamedOptions(rest, allowed);
  requireOptions(options, ['inventory', 'observations'], `coverage ${operation}`);
  let inventory;
  let observations;
  try {
    inventory = JSON.parse(readTextInput(options.inventory));
    observations = JSON.parse(readTextInput(options.observations));
  } catch (error) {
    fail(`coverage ${operation}: input is not valid JSON: ${error.message}`);
  }
  const errors = [...validateSurfaceInventory(inventory), ...validateCoverageObservations(observations, inventory)];
  if (errors.length) fail(`coverage ${operation}: ${errors.join('; ')}`);
  if (operation === 'validate') {
    console.log(`PASS  coverage inventory=${options.inventory} observations=${options.observations}`);
    return 0;
  }
  const output = options.output ?? '-';
  const content = `${JSON.stringify(calculateCoverage(inventory, observations), null, 2)}\n`;
  if (output === '-') process.stdout.write(content);
  else {
    const outputPath = resolve(output);
    assertActiveEngagementWrites([outputPath], 'coverage output');
    mkdirSync(dirname(outputPath), { recursive: true });
    atomicPrivateWrite(outputPath, content);
    console.log(`COVERAGE  calculated output=${outputPath}`);
  }
  return 0;
}

function schemaCommand(args) {
  const [operation, ...rest] = args;
  if (operation === 'list') {
    for (const kind of CONTRACT_KINDS) console.log(`${kind}\t${schemaId(kind)}`);
    console.log(`preflight-report\t${preflightReportSchema.properties.$schema.const}\tschemaVersion=2\treadCompatible=2\treport-only`);
    return 0;
  }
  if (operation === 'validate') {
    const options = parseNamedOptions(rest, new Set(['--kind', '--input']));
    requireOptions(options, ['kind', 'input'], 'schema validate');
    const supportedKinds = [...CONTRACT_KINDS, 'preflight-report'];
    if (!supportedKinds.includes(options.kind)) fail(`schema validate --kind must be one of: ${supportedKinds.join(', ')}`);
    let document;
    try { document = JSON.parse(readTextInput(options.input)); }
    catch (error) { fail(`schema validate: input is not valid JSON: ${error.message}`); }
    if (options.kind === 'preflight-report') {
      const version = document?.schemaVersion;
      const validate = version === 2 ? validatePreflightReportSchema : null;
      if (!validate) fail(`schema validate preflight-report: unsupported schemaVersion ${String(version)}; expected 2`);
      const errors = validate(document);
      if (errors.length) fail(`schema validate preflight-report@${version}: ${formatSchemaErrors(errors)}`);
      console.log(`PASS  schema preflight-report schemaVersion=${version} validator=${document.$schema} report-only input=${options.input}`);
      return 0;
    }
    const errors = validateCanonicalDocument(options.kind, document);
    if (errors.length) fail(`schema validate ${options.kind}: ${errors.join('; ')}`);
    console.log(`PASS  schema ${schemaId(options.kind)} input=${options.input}`);
    return 0;
  }
  fail('usage: argus-assets schema <list|validate> [options]');
}

function authorizationCommand(args) {
  const [operation, ...rest] = args;
  if (operation === 'init') return initializeAuthorization(rest);
  if (operation === 'check') return checkAuthorization(rest);
  fail('usage: argus-assets authorization <init|check> [options]');
}

function engagementCommand(args) {
  const [operation, ...rest] = args;
  try {
    if (operation === 'init') return initializeEngagement(rest);
    if (operation === 'validate') return validateEngagement(rest);
    if (operation === 'allocate') return engagementAllocate(rest);
    if (operation === 'start-attempt') return engagementStartAttempt(rest);
    if (operation === 'status') return engagementStatus(rest);
    if (operation === 'claim') return engagementClaim(rest);
    if (operation === 'release') return engagementRelease(rest);
    if (operation === 'fragment') return engagementFragment(rest);
    if (operation === 'merge') return engagementMerge(rest);
    if (operation === 'id') return engagementId(rest);
    if (operation === 'checkpoint') return engagementCheckpoint(rest);
    if (operation === 'heartbeat') return engagementHeartbeat(rest);
    if (operation === 'barrier') return engagementBarrier(rest);
    if (operation === 'cleanup') return engagementCleanup(rest);
  } catch (error) {
    fail(`engagement ${operation ?? '(missing)'}: ${error.message}`);
  }
  fail('usage: argus-assets engagement <init|validate|allocate|start-attempt|status|claim|release|fragment|merge|id|checkpoint|heartbeat|barrier|cleanup> [options]');
}

function initializeEngagement(args) {
  const options = parseNamedOptions(args, new Set(['--target', '--artifact-root', '--mode', '--output', '--engagement-id', '--browser-support', '--accessibility-requirement']));
  for (const required of ['target', 'artifactRoot', 'mode']) if (!options[required]) fail(`engagement init requires --${camelToKebab(required)}`);
  if (!['A', 'B', 'C', 'D'].includes(options.mode)) fail('engagement init --mode must be A, B, C, or D');
  const artifactRoot = realpathSync(resolve(options.artifactRoot));
  const output = resolve(artifactRoot, options.output ?? 'ai_agents_internal/engagement.json');
  if (!statSafe(artifactRoot)?.isDirectory() || !safePhysicalPath(artifactRoot, output)) fail('engagement manifest path escapes its physical artifact root or crosses a symbolic link');
  if (existsSync(output)) fail(`refusing to overwrite existing engagement manifest: ${output}`);
  const selectedAgents = matrix.agents.filter((agent) => agent.modes.includes(options.mode)).map((agent) => agent.slug);
  const targetPath = statSafe(resolve(options.target)) ? realpathSync(resolve(options.target)) : null;
  const targetIdentifier = targetPath ?? (/^https?:\/\//i.test(options.target) ? new URL(options.target).toString() : options.target);
  const engagement = createDefaultEngagement({
    template: readJson(ENGAGEMENT_TEMPLATE_PATH),
    target: targetIdentifier,
    targetRoot: targetPath,
    artifactRoot,
    mode: options.mode,
    engagementId: options.engagementId ?? `argus-${new Date().toISOString().replace(/[:.]/g, '-')}`,
    selectedAgents,
    browserSupport: options.browserSupport ? readJson(resolve(options.browserSupport)) : undefined,
    accessibilityRequirement: options.accessibilityRequirement ? readJson(resolve(options.accessibilityRequirement)) : undefined,
  });
  const errors = validateEngagementManifest(engagement);
  if (errors.length > 0) fail(`generated engagement manifest is invalid: ${errors.join('; ')}`);
  mkdirSync(dirname(output), { recursive: true });
  writeFileSync(output, `${JSON.stringify(engagement, null, 2)}\n`, { mode: 0o600 });
  chmodSync(output, 0o600);
  const state = initializeEngagementState(engagement);
  console.log(`ENGAGEMENT  initialized manifest=${output} state=${state.path} selected=${selectedAgents.length}`);
  return 0;
}

function validateEngagement(args) {
  const options = parseNamedOptions(args, new Set(['--manifest']));
  const { manifest: engagement, path } = loadEngagement(options);
  initializeEngagementState(engagement);
  console.log(`PASS  engagement manifest=${path} selected=${engagement.selectedAgents.length}`);
  return 0;
}

function engagementAllocate(args) {
  const options = parseNamedOptions(args, new Set(['--manifest', '--lane', '--decision', '--dispatch-authorization', '--token', '--controller-token']));
  requireOptions(options, ['manifest', 'lane', 'decision'], 'engagement allocate');
  assertTrustedModelRoutingAssets();
  const initialContext = loadModelEngagement(options.manifest, options.lane);
  withInitialModelControlLock(initialContext, () => {
    const context = loadModelEngagement(options.manifest, options.lane);
    requirePinnedModelTrust(context);
    const initialState = getEngagementStatus(context.engagement);
    const activeAllocation = initialState.allocations?.[options.lane];
    const resumingBoundAttempt = activeAllocation?.status === 'active' &&
      ['modelDecisionId', 'modelDecisionIntegritySha256', 'dispatchId', 'attempt', 'runtime'].every((field) => Object.hasOwn(activeAllocation, field));
    const decision = resumingBoundAttempt
      ? loadSelectedDecision(context, options.lane, options.decision, 'resume')
      : loadSelectedAllocationDecision(context, options.lane, options.decision);
    const dispatchAuthorization = loadDispatchAuthorization(context, options.dispatchAuthorization, decision);
    const preflight = requireCurrentModelPreflight(context, options.lane, decision.runtime);
    const state = getEngagementStatus(context.engagement);
    let seal;
    if (Object.keys(state.allocations).length === 0) {
      if (options.lane !== 'odysseus') fail('the first allocation must be Odysseus');
      seal = createModelControlSeal(context, decision.runtime, preflight);
    } else {
      seal = loadModelControlSeal(context);
      if (seal.preflightSha256 !== preflight.sha256) {
        fail('engagement allocation preflight differs from the sealed model-control report');
      }
    }
    if (resumingBoundAttempt) requireActiveAllocationDecision(state, options.lane, seal, decision);
    else requireSealedAllocationDecision(seal, decision);
    console.log(JSON.stringify(allocateWorker(context.engagement, options.lane, {
      resumeToken: options.token,
      controllerToken: options.controllerToken,
      executionBinding: executionBindingForDecision(decision),
      dispatchAuthorization,
    })));
  });
  return 0;
}

function engagementStartAttempt(args) {
  const options = parseNamedOptions(args, new Set(['--manifest', '--lane', '--decision', '--dispatch-authorization', '--token', '--controller-token']));
  requireOptions(options, ['manifest', 'lane', 'decision', 'token'], 'engagement start-attempt');
  assertTrustedModelRoutingAssets();
  const context = loadModelEngagement(options.manifest, options.lane);
  requirePinnedModelTrust(context);
  const decision = loadSelectedRetryDecision(context, options.lane, options.decision);
  const dispatchAuthorization = loadDispatchAuthorization(context, options.dispatchAuthorization, decision);
  const preflight = requireCurrentModelPreflight(context, options.lane, decision.runtime);
  const seal = loadModelControlSeal(context);
  if (seal.runtime !== decision.runtime || seal.preflightSha256 !== preflight.sha256 || !seal.decisions[options.lane]) {
    fail('retry decision is outside the sealed dispatchable model-control set');
  }
  console.log(JSON.stringify(startWorkerAttempt(context.engagement, options.lane, {
    token: options.token,
    controllerToken: options.controllerToken,
    executionBinding: executionBindingForDecision(decision),
    dispatchAuthorization,
  })));
  return 0;
}

function loadDispatchAuthorization(context, explicitPath, decision) {
  if (decision.runtime !== 'codex') {
    if (explicitPath) fail('--dispatch-authorization is valid only for Codex decisions');
    return undefined;
  }
  if (!explicitPath) fail('Codex allocation or retry requires --dispatch-authorization from the trusted JIT dispatch wrapper');
  const path = resolveExistingPhysicalInput(explicitPath, context.artifactRoot);
  const directory = join(context.artifactRoot, 'ai_agents_internal', 'operator-decisions');
  if (dirname(path) !== directory || !safePhysicalPath(context.artifactRoot, path) || !statSafe(path)?.isFile() ||
      lstatSync(path).isSymbolicLink() || lstatSync(path).nlink !== 1) {
    fail('dispatch authorization must be a non-aliased real file directly under ai_agents_internal/operator-decisions');
  }
  const raw = readSecureSingleLink(path, 'dispatch authorization');
  const digest = createHash('sha256').update(raw).digest('hex');
  if (basename(path) !== `MDA-${digest.slice(0, 24)}.json`) fail('dispatch authorization filename differs from its deterministic content digest');
  let document;
  try { document = JSON.parse(raw); }
  catch { fail('dispatch authorization is not valid JSON'); }
  assertSchemaDocument(validateModelDispatchAuthorizationSchema, document, 'dispatch authorization');
  try { verifyModelDocumentAuthentication(document, context.engagement.modelTrust); }
  catch (error) { fail(`dispatch authorization authentication failed: ${error.message}`); }
  return document;
}

function loadSelectedAllocationDecision(context, lane, explicitPath) {
  const decision = loadSelectedDecision(context, lane, explicitPath, 'allocation');
  if (decision.signal !== 'normal' || decision.attempt !== 1) {
    fail('engagement allocation requires a selected normal attempt-1 model decision');
  }
  return decision;
}

function loadSelectedRetryDecision(context, lane, explicitPath) {
  const decision = loadSelectedDecision(context, lane, explicitPath, 'retry');
  if (decision.signal === 'normal' || decision.attempt < 2) {
    fail('engagement start-attempt requires a selected non-normal decision after attempt 1');
  }
  return decision;
}

function loadSelectedDecision(context, lane, explicitPath, operation) {
  const decisionPath = resolveExistingPhysicalInput(explicitPath, context.artifactRoot);
  const decisionDirectory = resolve(context.artifactRoot, modelPolicy.routing.decisionDirectory);
  if (!isWithin(context.artifactRoot, decisionPath) || dirname(decisionPath) !== decisionDirectory || !/^MDR-[a-f0-9]{24}\.json$/.test(basename(decisionPath))) {
    fail(`engagement ${operation} decision must be an exact model-decision file under ai_agents_internal/model-decisions`);
  }
  assertPhysicalWithin(context.artifactRoot, decisionPath, `engagement ${operation} model decision`);
  if (!existsSync(decisionPath) || !statSync(decisionPath).isFile() || lstatSync(decisionPath).isSymbolicLink() || lstatSync(decisionPath).nlink !== 1) {
    fail(`engagement ${operation} model decision must be a non-aliased real file`);
  }
  const decision = readSecureJson(decisionPath, `engagement ${operation} model decision`);
  assertSchemaDocument(validateModelDecisionSchema, decision, `engagement ${operation} model decision`);
  const bindingErrors = validateModelDecisionBinding(modelPolicy, runtimeAdapters, decision, {
    engagementId: context.engagement.engagementId,
    engagementManifestSha256: context.sha256,
    decisionPath,
    artifactRoot: context.artifactRoot,
    modelTrust: context.engagement.modelTrust,
  });
  if (bindingErrors.length) fail(`engagement ${operation} model decision binding invalid: ${bindingErrors.join('; ')}`);
  if (decision.agent !== lane) fail(`engagement ${operation} model decision belongs to ${decision.agent}, not ${lane}`);
  if (decision.status !== 'selected') fail(`engagement ${operation} requires a selected model decision`);
  return decision;
}

function executionBindingForDecision(decision) {
  return {
    modelDecisionId: decision.decisionId,
    modelDecisionIntegritySha256: decision.integritySha256,
    dispatchId: decision.dispatchId,
    attempt: decision.attempt,
    runtime: decision.runtime,
  };
}

function createModelControlSeal(context, runtime, preflight) {
  const existingSeal = loadModelControlSeal(context, { required: false });
  if (existingSeal) {
    if (existingSeal.runtime !== runtime || existingSeal.preflightSha256 !== preflight.sha256) {
      fail('existing initial model-control seal differs from the current runtime or preflight report');
    }
    bindDispatchableAgents(context.engagement, existingSeal.dispatchableAgents);
    return existingSeal;
  }
  const decisions = {};
  const errors = [];
  const dispatchableAgents = dispatchablePreflightAgents(context.engagement, preflight.report);
  if (!dispatchableAgents.includes('odysseus')) errors.push('odysseus: current preflight is not dispatchable');
  for (const agent of dispatchableAgents) {
    const selected = selectedModelDecisions(context, agent, runtime, undefined, 1)
      .filter((decision) => decision.signal === 'normal');
    if (selected.length !== 1) {
      errors.push(`${agent}: expected exactly one selected normal attempt-1 decision, found ${selected.length}`);
      continue;
    }
    decisions[agent] = executionBindingForDecision(selected[0]);
  }
  if (errors.length > 0) fail(`Odysseus bootstrap cannot seal the initial model-control set: ${errors.join('; ')}`);
  bindDispatchableAgents(context.engagement, dispatchableAgents);
  const seal = {
    schema: 'argus/model-control-seal@1',
    schemaVersion: 1,
    engagementId: context.engagement.engagementId,
    engagementManifestSha256: context.sha256,
    runtime,
    preflightSha256: preflight.sha256,
    dispatchableAgents,
    decisions: Object.fromEntries(Object.entries(decisions).sort(([left], [right]) => left.localeCompare(right))),
    sealedAt: new Date().toISOString(),
  };
  seal.integritySha256 = modelControlSealSha256(seal);
  const path = modelControlSealPath(context);
  const serialized = `${JSON.stringify(seal, null, 2)}\n`;
  atomicPrivateWrite(path, serialized);
  return loadModelControlSeal(context);
}

function loadModelControlSeal(context, { required = true } = {}) {
  const path = modelControlSealPath(context);
  if (!existsSync(path)) {
    if (required) fail('engagement allocation requires the immutable initial model-control seal');
    return null;
  }
  if (!safePhysicalPath(context.artifactRoot, path) || !statSafe(path)?.isFile() || lstatSync(path).isSymbolicLink() || lstatSync(path).nlink !== 1) {
    fail('initial model-control seal must be a non-aliased real file');
  }
  const seal = readSecureJson(path, 'initial model-control seal');
  if (seal?.schema !== 'argus/model-control-seal@1' || seal.schemaVersion !== 1 || seal.engagementId !== context.engagement.engagementId ||
      seal.engagementManifestSha256 !== context.sha256 || !['claude', 'codex'].includes(seal.runtime) ||
      !/^[a-f0-9]{64}$/.test(seal.preflightSha256 ?? '') || !Array.isArray(seal.dispatchableAgents) ||
      !seal.dispatchableAgents.every((agent) => typeof agent === 'string') || new Set(seal.dispatchableAgents).size !== seal.dispatchableAgents.length ||
      !plainObject(seal.decisions) ||
      !validDateTime(seal.sealedAt) || seal.integritySha256 !== modelControlSealSha256(seal)) {
    fail('initial model-control seal is malformed or stale');
  }
  const preflightPath = join(context.artifactRoot, 'ai_agents_internal', 'preflight.json');
  const preflightRaw = readSecureSingleLink(preflightPath, 'sealed model-control preflight report');
  let preflight;
  try { preflight = JSON.parse(preflightRaw.toString('utf8')); }
  catch { fail('sealed model-control preflight report is not valid JSON'); }
  assertSchemaDocument(validatePreflightReportSchema, preflight, 'sealed model-control preflight report');
  if (createHash('sha256').update(preflightRaw).digest('hex') !== seal.preflightSha256) fail('initial model-control seal preflight digest is stale');
  const expectedAgents = dispatchablePreflightAgents(context.engagement, preflight);
  if (JSON.stringify([...seal.dispatchableAgents].sort()) !== JSON.stringify(expectedAgents)) fail('initial model-control seal dispatchable agent set differs from preflight');
  if (JSON.stringify(Object.keys(seal.decisions).sort()) !== JSON.stringify(expectedAgents)) fail('initial model-control seal agent set differs from the engagement');
  const state = getEngagementStatus(context.engagement);
  if (Array.isArray(state.dispatchableAgents) && JSON.stringify(state.dispatchableAgents) !== JSON.stringify(expectedAgents)) {
    fail('engagement state dispatchable projection differs from the model-control seal');
  }
  if (state.dispatchableAgents === null && Object.keys(state.allocations).length > 0) {
    fail('allocated engagement state has no sealed dispatchable projection');
  }
  for (const [agent, binding] of Object.entries(seal.decisions)) {
    if (agent !== binding.agent && binding.agent !== undefined) fail(`initial model-control seal decision key differs for ${agent}`);
    executionBindingForSeal(binding, agent, seal.runtime);
  }
  return seal;
}

function dispatchablePreflightAgents(engagement, report) {
  const selected = new Set(engagement.selectedAgents);
  return report.agents
    .filter((entry) => selected.has(entry.slug) && entry.selected && ['ready', 'degraded'].includes(entry.status) &&
      (entry.slug === 'odysseus' || entry.dispatchAllowed === true))
    .map((entry) => entry.slug)
    .sort();
}

function requireSealedAllocationDecision(seal, decision) {
  if (seal.runtime !== decision.runtime) fail('allocation decision runtime differs from the sealed model-control runtime');
  const expected = seal.decisions[decision.agent];
  if (!expected || JSON.stringify(expected) !== JSON.stringify(executionBindingForDecision(decision))) {
    fail(`${decision.agent} allocation decision differs from the immutable model-control seal`);
  }
}

function requireActiveAllocationDecision(state, lane, seal, decision) {
  const allocation = state.allocations?.[lane];
  const binding = executionBindingForDecision(decision);
  if (allocation?.status !== 'active' || seal.runtime !== decision.runtime || !seal.decisions[lane] ||
      !Object.entries(binding).every(([field, value]) => allocation[field] === value)) {
    fail(`${lane} resume decision differs from the active allocation or sealed dispatchable set`);
  }
}

function executionBindingForSeal(binding, agent, runtime) {
  if (!plainObject(binding) || !/^MDR-[a-f0-9]{24}$/.test(binding.modelDecisionId ?? '') ||
      !/^[a-f0-9]{64}$/.test(binding.modelDecisionIntegritySha256 ?? '') ||
      !/^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$/.test(binding.dispatchId ?? '') ||
      binding.attempt !== 1 || binding.runtime !== runtime || Object.keys(binding).length !== 5) {
    fail(`initial model-control seal has an invalid execution binding for ${agent}`);
  }
}

function modelControlSealPath(context) {
  return join(context.artifactRoot, 'ai_agents_internal', 'model-control-seal.json');
}

function modelControlSealSha256(seal) {
  const copy = structuredClone(seal);
  copy.integritySha256 = '';
  return createHash('sha256').update(stableCanonicalJson(copy)).digest('hex');
}

function withInitialModelControlLock(context, operation) {
  const directory = resolve(context.artifactRoot, modelPolicy.routing.decisionDirectory);
  if (!safePhysicalPath(context.artifactRoot, directory)) fail('initial model-control directory is physically unsafe');
  mkdirSync(directory, { recursive: true });
  const lock = join(directory, '.initial-control.lock');
  let acquired = false;
  for (let attempt = 0; attempt < 6000; attempt += 1) {
    try {
      mkdirSync(lock, { mode: 0o700 });
      writeFileSync(join(lock, 'owner.json'), `${JSON.stringify({ pid: process.pid, acquiredAt: new Date().toISOString() })}\n`, { flag: 'wx', mode: 0o600 });
      acquired = true;
      break;
    } catch (error) {
      if (error.code !== 'EEXIST') {
        rmSync(lock, { recursive: true, force: true });
        fail(`cannot acquire initial model-control lock: ${error.message}`);
      }
      reclaimAbandonedModelControlLock(lock);
      Atomics.wait(new Int32Array(new SharedArrayBuffer(4)), 0, 0, 10);
    }
  }
  if (!acquired) fail('timed out acquiring initial model-control lock');
  try { return operation(); }
  finally { rmSync(lock, { recursive: true, force: true }); }
}

function modelControlLockIsAbandoned(lock) {
  try {
    const ownerPath = join(lock, 'owner.json');
    if (!existsSync(ownerPath)) return Date.now() - statSync(lock).mtimeMs > 30_000;
    const ownerStat = lstatSync(ownerPath);
    if (!ownerStat.isFile() || ownerStat.isSymbolicLink() || ownerStat.nlink !== 1) return false;
    let owner;
    try { owner = JSON.parse(readFileSync(ownerPath, 'utf8')); }
    catch { return Date.now() - statSync(lock).mtimeMs > 30_000; }
    if (!Number.isInteger(owner.pid) || owner.pid < 1) return Date.now() - statSync(lock).mtimeMs > 30_000;
    try {
      process.kill(owner.pid, 0);
      return false;
    } catch (error) {
      if (error.code === 'EPERM') return false;
      return error.code === 'ESRCH';
    }
  } catch {
    return false;
  }
}

function reclaimAbandonedModelControlLock(lock) {
  let lockEntry;
  try { lockEntry = lstatSync(lock); }
  catch (error) {
    if (error.code === 'ENOENT') return true;
    throw error;
  }
  if (lockEntry.isSymbolicLink() || !lockEntry.isDirectory()) throw new Error(`model-control lock path is unsafe: ${lock}`);
  if (!modelControlLockIsAbandoned(lock)) return false;
  const ownerEntry = lstatSafe(join(lock, 'owner.json'));
  const claim = join(lock, '.reclaim');
  try {
    mkdirSync(claim, { mode: 0o700 });
    writeFileSync(join(claim, 'owner.json'), `${JSON.stringify({ pid: process.pid, acquiredAt: new Date().toISOString() })}\n`, { flag: 'wx', mode: 0o600 });
  } catch (error) {
    if (error.code === 'EEXIST') return false;
    throw error;
  }
  let quarantine = null;
  try {
    if (!sameDirectoryIdentity(lockEntry, lstatSafe(lock)) ||
        !sameFilesystemEntry(ownerEntry, lstatSafe(join(lock, 'owner.json')))) return false;
    quarantine = `${lock}.stale-${process.pid}-${randomBytes(6).toString('hex')}`;
    renameSync(lock, quarantine);
    rmSync(quarantine, { recursive: true, force: true });
    return true;
  } finally {
    if (!quarantine && sameDirectoryIdentity(lockEntry, lstatSafe(lock))) rmSync(claim, { recursive: true, force: true });
  }
}

function lstatSafe(path) {
  try { return lstatSync(path); }
  catch (error) {
    if (error.code === 'ENOENT') return null;
    throw error;
  }
}

function sameDirectoryIdentity(left, right) {
  return Boolean(left && right && left.dev === right.dev && left.ino === right.ino);
}

function sameFilesystemEntry(left, right) {
  if (!left || !right) return left === right;
  return left.dev === right.dev && left.ino === right.ino && left.size === right.size && left.mtimeMs === right.mtimeMs;
}

