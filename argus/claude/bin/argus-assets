const ROOT = resolve(dirname(fileURLToPath(import.meta.url)), '..');
const MANIFEST_PATH = join(ROOT, 'runtime-assets.json');
const INVENTORY_PATH = join(ROOT, 'runtime-reference-inventory.json');
const CAPABILITY_MATRIX_PATH = join(ROOT, 'capabilities', 'capability-matrix.json');
const TECHNIQUE_BUNDLE_PATH = join(ROOT, 'capabilities', 'technique-catalogs.bundle.b64');
const RACI_PATH = join(ROOT, 'references', 'raci.json');
const MODEL_POLICY_PATH = join(ROOT, 'capabilities', 'model-policy.json');
const MODEL_POLICY_SCHEMA_PATH = join(ROOT, 'schemas', 'model-policy.schema.json');
const MODEL_BENCHMARK_PATH = join(ROOT, 'capabilities', 'model-policy.benchmark.json');
const RUNTIME_ADAPTERS_PATH = join(ROOT, 'capabilities', 'runtime-adapters.json');
const RUNTIME_ADAPTERS_SCHEMA_PATH = join(ROOT, 'schemas', 'runtime-adapters.schema.json');
const MODEL_DECISION_SCHEMA_PATH = join(ROOT, 'schemas', 'model-decision.schema.json');
const MODEL_DISPATCH_AUTHORIZATION_SCHEMA_PATH = join(ROOT, 'schemas', 'model-dispatch-authorization.schema.json');
const MODEL_OPERATOR_DECISION_SCHEMA_PATH = join(ROOT, 'schemas', 'model-operator-decision.schema.json');
const NATIVE_LAUNCH_AUTHORIZATION_SCHEMA_PATH = join(ROOT, 'schemas', 'native-launch-authorization.schema.json');
const NATIVE_LAUNCH_RECEIPT_SCHEMA_PATH = join(ROOT, 'schemas', 'native-launch-receipt.schema.json');
const MODEL_TRUST_STORE_SCHEMA_PATH = join(ROOT, 'schemas', 'model-trust-store.schema.json');
const MODEL_TELEMETRY_SCHEMA_PATH = join(ROOT, 'schemas', 'model-telemetry-event.schema.json');
const PREFLIGHT_REPORT_SCHEMA_PATH = join(ROOT, 'schemas', 'preflight-report.schema.json');
const ORCHESTRATION_PLAN_PATH = join(ROOT, 'capabilities', 'orchestration-plan.json');
const TEMPLATE_CONTRACT_PATH = join(ROOT, 'capabilities', 'template-contract.json');
const AUTHORIZATION_TEMPLATE_PATH = join(ROOT, 'policies', 'authorization.template.json');
const ENGAGEMENT_TEMPLATE_PATH = join(ROOT, 'policies', 'engagement.template.json');
const REDACTION_PATTERNS_PATH = join(ROOT, 'policies', 'redaction-patterns.json');
const HOOKS_PATH = join(ROOT, 'hooks', 'hooks.json');
const manifest = readJson(MANIFEST_PATH);
const matrix = readJson(CAPABILITY_MATRIX_PATH);
const modelPolicy = readJson(MODEL_POLICY_PATH);
const validateModelPolicySchema = compileJsonSchema(readJson(MODEL_POLICY_SCHEMA_PATH));
assertSchemaDocument(validateModelPolicySchema, modelPolicy, 'model policy');
const raciContract = readJson(RACI_PATH);
const modelPolicyErrors = validateModelPolicy(modelPolicy, matrix.agents.map((agent) => agent.slug));
if (modelPolicyErrors.length) fail(`model policy invalid: ${modelPolicyErrors.join('; ')}`);
const modelBenchmark = readJson(MODEL_BENCHMARK_PATH);
if (modelBenchmark.policyId !== modelPolicy.policyId) fail('model policy benchmark is bound to a different policy');
const runtimeAdapters = readJson(RUNTIME_ADAPTERS_PATH);
const validateRuntimeAdapters = compileJsonSchema(readJson(RUNTIME_ADAPTERS_SCHEMA_PATH));
const runtimeAdapterErrors = validateRuntimeAdapters(runtimeAdapters);
if (runtimeAdapterErrors.length) fail(`runtime adapter snapshot invalid: ${formatSchemaErrors(runtimeAdapterErrors)}`);
const validateModelDecisionSchema = compileJsonSchema(readJson(MODEL_DECISION_SCHEMA_PATH));
const validateModelDispatchAuthorizationSchema = compileJsonSchema(readJson(MODEL_DISPATCH_AUTHORIZATION_SCHEMA_PATH));
const validateModelOperatorDecisionSchema = compileJsonSchema(readJson(MODEL_OPERATOR_DECISION_SCHEMA_PATH));
const validateNativeLaunchAuthorizationSchema = compileJsonSchema(readJson(NATIVE_LAUNCH_AUTHORIZATION_SCHEMA_PATH));
const validateNativeLaunchReceiptSchema = compileJsonSchema(readJson(NATIVE_LAUNCH_RECEIPT_SCHEMA_PATH));
const validateModelTrustStoreSchema = compileJsonSchema(readJson(MODEL_TRUST_STORE_SCHEMA_PATH));
const validateModelTelemetrySchema = compileJsonSchema(readJson(MODEL_TELEMETRY_SCHEMA_PATH));
const preflightReportSchema = readJson(PREFLIGHT_REPORT_SCHEMA_PATH);
const validatePreflightReportSchema = compileJsonSchema(preflightReportSchema);
const orchestrationPlan = readJson(ORCHESTRATION_PLAN_PATH);
const orchestrationPlanErrors = validateOrchestrationPlan(orchestrationPlan, matrix, raciContract);
if (orchestrationPlanErrors.length) fail(`orchestration plan invalid: ${orchestrationPlanErrors.join('; ')}`);
const templateContract = readJson(TEMPLATE_CONTRACT_PATH);
const templateContractErrors = validateTemplateContract(templateContract);
if (templateContractErrors.length) fail(`template contract invalid: ${templateContractErrors.join('; ')}`);
const [command = 'help', ...args] = process.argv.slice(2);

switch (command) {
  case 'help':
  case '--help':
  case '-h':
    usage();
    break;
  case 'list':
    for (const asset of manifest.assets) {
      console.log(`${asset.id}\t${asset.kind}\t${asset.destination}\t${asset.files} files\t${asset.bytes} bytes`);
    }
    break;
  case 'path':
    printPath(args[0]);
    break;
  case 'inventory':
    console.log(INVENTORY_PATH);
    break;
  case 'verify':
    verify();
    break;
  case 'preflight':
    process.exitCode = await preflight(args);
    break;
  case 'authorization':
    process.exitCode = authorizationCommand(args);
    break;
  case 'engagement':
    process.exitCode = engagementCommand(args);
    break;
  case 'schema':
    process.exitCode = schemaCommand(args);
    break;
  case 'coverage':
    process.exitCode = coverageCommand(args);
    break;
  case 'raci':
    process.exitCode = raciCommand(args);
    break;
  case 'model':
    process.exitCode = modelCommand(args);
    break;
  case 'launch':
    process.exitCode = launchCommand(args);
    break;
  case 'orchestration':
    process.exitCode = orchestrationCommand(args);
    break;
  case 'template':
    process.exitCode = templateCommand(args);
    break;
  case 'technique':
    process.exitCode = techniqueCommand(args);
    break;
  case 'guard':
    process.exitCode = guardCommand(args);
    break;
  case 'redact':
    process.exitCode = redactCommand(args);
    break;
  case 'copy-template':
    copyTemplate(args[0], args[1]);
    break;
  case 'copy-browser-driver':
    copyBrowserDriver(args[0]);
    break;
  default:
    fail(`unknown command: ${command}`);
}

