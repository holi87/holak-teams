#!/usr/bin/env node

import { execFileSync } from 'node:child_process';
import { createHash } from 'node:crypto';
import {
  accessSync,
  appendFileSync,
  chmodSync,
  copyFileSync,
  cpSync,
  constants,
  existsSync,
  mkdirSync,
  readFileSync,
  readdirSync,
  statSync,
  writeFileSync,
} from 'node:fs';
import { dirname, join, relative, resolve, sep } from 'node:path';
import { fileURLToPath } from 'node:url';
import {
  buildAuditEvent,
  createDefaultAuthorization,
  detectProductionLike,
  evaluateAuthorization,
  isBinaryBuffer,
  manifestSha256,
  redactText,
  redactValue,
  validateAuthorizationManifest,
  validateRedactionPatterns,
} from '../lib/authorization.mjs';
import {
  advanceBarrier,
  allocateId,
  allocateWorker,
  arriveBarrier,
  buildGuardAudit,
  claimExclusive,
  cleanupWorker,
  createDefaultEngagement,
  evaluateWriteGuard,
  getBarrierStatus,
  getEngagementStatus,
  initializeEngagementState,
  locateEngagementManifest,
  mergeCanonical,
  releaseExclusive,
  validateEngagementManifest,
  writeCheckpoint,
  writeFragment,
} from '../lib/engagement.mjs';
import { CONTRACT_KINDS, schemaId, validateCanonicalDocument } from '../lib/contracts.mjs';

const ROOT = resolve(dirname(fileURLToPath(import.meta.url)), '..');
const MANIFEST_PATH = join(ROOT, 'runtime-assets.json');
const INVENTORY_PATH = join(ROOT, 'runtime-reference-inventory.json');
const CAPABILITY_MATRIX_PATH = join(ROOT, 'capabilities', 'capability-matrix.json');
const AUTHORIZATION_TEMPLATE_PATH = join(ROOT, 'policies', 'authorization.template.json');
const ENGAGEMENT_TEMPLATE_PATH = join(ROOT, 'policies', 'engagement.template.json');
const REDACTION_PATTERNS_PATH = join(ROOT, 'policies', 'redaction-patterns.json');
const HOOKS_PATH = join(ROOT, 'hooks', 'hooks.json');
const manifest = readJson(MANIFEST_PATH);
const matrix = readJson(CAPABILITY_MATRIX_PATH);
const [command = 'help', ...args] = process.argv.slice(2);

switch (command) {
  case 'help':
  case '--help':
  case '-h':
    usage();
    break;
  case 'list':
    for (const asset of manifest.assets) {
      console.log(`${asset.id}\t${asset.kind}\t${asset.destination}\t${asset.files} files\t${asset.bytes} bytes`);
    }
    break;
  case 'path':
    printPath(args[0]);
    break;
  case 'inventory':
    console.log(INVENTORY_PATH);
    break;
  case 'verify':
    verify();
    break;
  case 'preflight':
    process.exitCode = await preflight(args);
    break;
  case 'authorization':
    process.exitCode = authorizationCommand(args);
    break;
  case 'engagement':
    process.exitCode = engagementCommand(args);
    break;
  case 'schema':
    process.exitCode = schemaCommand(args);
    break;
  case 'guard':
    process.exitCode = guardCommand(args);
    break;
  case 'redact':
    process.exitCode = redactCommand(args);
    break;
  case 'copy-template':
    copyTemplate(args[0], args[1]);
    break;
  case 'copy-browser-driver':
    copyBrowserDriver(args[0]);
    break;
  default:
    fail(`unknown command: ${command}`);
}

function usage() {
  console.log(`Argus packaged runtime assets

Usage:
  argus-assets list
  argus-assets path <asset-id>
  argus-assets inventory
  argus-assets verify
  argus-assets preflight --target <url-or-path> --mode <A|B|C|D> [options]
  argus-assets authorization init --target <url-or-path> [options]
  argus-assets authorization check --manifest <path> --lane <slug> --action <action> --target <target> [options]
  argus-assets engagement <init|validate|allocate|status|claim|release|fragment|merge|id|checkpoint|barrier|cleanup> [options]
  argus-assets schema <list|validate> [options]
  argus-assets guard
  argus-assets redact --input <text-file|-> --output <safe-file|->
  argus-assets copy-template <typescript|java|python> <empty-destination>
  argus-assets copy-browser-driver <target-repo>

Preflight options:
  --artifact-root <path>       Root for QA artifacts (defaults to a path target or cwd)
  --output <relative-path>     Report path under artifact root
  --authorization <path>      Existing manifest under artifact root (default is generated)
  --engagement <path>         Existing engagement manifest under artifact root
  --environment <name>        unknown|development|test|staging|production
  --engagement-id <id>        Stable authorization/audit correlation identifier
  --feature <capability>       Confirm a target capability; repeat as needed
  --profile <json>             Deterministic capability override for CI
  --json                       Print the complete report to stdout

Authorization init options:
  --environment <name>         unknown|development|test|staging|production
  --output <path>              Defaults to ai_agents_internal/authorization.json
  --engagement-id <id>         Stable audit correlation identifier

Authorization check boundaries:
  --source-trust <class>       manifest|user|untrusted (required)
  --account/--namespace/--mutation/--classification <value>
  --binary-reviewed <true|false> Confirm synthetic/masked + independently reviewed evidence
  --rate/--concurrency/--total-requests/--duration <positive-number>
  --resource <safe-label>      Optional label; audit output is always redacted
  --at <ISO-timestamp>         Deterministic evaluation time (tests only)

Engagement coordination:
  init --target <target> --artifact-root <root> --mode <A|B|C|D> [--output <path>]
  allocate --manifest <path> --lane <slug>
  fragment --manifest <path> --lane <slug> --token <lease> --canonical <path> --id <id> --input <file|->
  merge --manifest <path> --owner <slug> --token <lease> --canonical <path>
  claim|release --manifest <path> --lane <slug> --token <lease> --resource <reset|fault>
  id --manifest <path> --lane <slug> --token <lease> --kind <kind> --identity <stable-key>
  checkpoint --manifest <path> --lane <slug> --token <lease> --phase <phase> --sequence <n> --input <json-file|->
  barrier arrive|status|advance --manifest <path> [lease options]
  cleanup --manifest <path> --lane <slug> --token <lease> --outcome <success|failure>

Templates are copied only to a new or empty directory. In ADAPT mode, copy to a
temporary directory, diff against the target's existing harness, and merge explicitly.`);
}

function schemaCommand(args) {
  const [operation, ...rest] = args;
  if (operation === 'list') {
    for (const kind of CONTRACT_KINDS) console.log(`${kind}\t${schemaId(kind)}`);
    return 0;
  }
  if (operation === 'validate') {
    const options = parseNamedOptions(rest, new Set(['--kind', '--input']));
    requireOptions(options, ['kind', 'input'], 'schema validate');
    if (!CONTRACT_KINDS.includes(options.kind)) fail(`schema validate --kind must be one of: ${CONTRACT_KINDS.join(', ')}`);
    let document;
    try { document = JSON.parse(readTextInput(options.input)); }
    catch (error) { fail(`schema validate: input is not valid JSON: ${error.message}`); }
    const errors = validateCanonicalDocument(options.kind, document);
    if (errors.length) fail(`schema validate ${options.kind}: ${errors.join('; ')}`);
    console.log(`PASS  schema ${schemaId(options.kind)} input=${options.input}`);
    return 0;
  }
  fail('usage: argus-assets schema <list|validate> [options]');
}

function authorizationCommand(args) {
  const [operation, ...rest] = args;
  if (operation === 'init') return initializeAuthorization(rest);
  if (operation === 'check') return checkAuthorization(rest);
  fail('usage: argus-assets authorization <init|check> [options]');
}

function engagementCommand(args) {
  const [operation, ...rest] = args;
  try {
    if (operation === 'init') return initializeEngagement(rest);
    if (operation === 'validate') return validateEngagement(rest);
    if (operation === 'allocate') return engagementAllocate(rest);
    if (operation === 'status') return engagementStatus(rest);
    if (operation === 'claim') return engagementClaim(rest);
    if (operation === 'release') return engagementRelease(rest);
    if (operation === 'fragment') return engagementFragment(rest);
    if (operation === 'merge') return engagementMerge(rest);
    if (operation === 'id') return engagementId(rest);
    if (operation === 'checkpoint') return engagementCheckpoint(rest);
    if (operation === 'barrier') return engagementBarrier(rest);
    if (operation === 'cleanup') return engagementCleanup(rest);
  } catch (error) {
    fail(`engagement ${operation ?? '(missing)'}: ${error.message}`);
  }
  fail('usage: argus-assets engagement <init|validate|allocate|status|claim|release|fragment|merge|id|checkpoint|barrier|cleanup> [options]');
}

function initializeEngagement(args) {
  const options = parseNamedOptions(args, new Set(['--target', '--artifact-root', '--mode', '--output', '--engagement-id']));
  for (const required of ['target', 'artifactRoot', 'mode']) if (!options[required]) fail(`engagement init requires --${camelToKebab(required)}`);
  if (!['A', 'B', 'C', 'D'].includes(options.mode)) fail('engagement init --mode must be A, B, C, or D');
  const artifactRoot = resolve(options.artifactRoot);
  const output = resolve(artifactRoot, options.output ?? 'ai_agents_internal/engagement.json');
  if (!isWithin(artifactRoot, output)) fail('engagement manifest path escapes artifact root');
  if (existsSync(output)) fail(`refusing to overwrite existing engagement manifest: ${output}`);
  const selectedAgents = matrix.agents.filter((agent) => agent.modes.includes(options.mode)).map((agent) => agent.slug);
  const targetPath = statSafe(resolve(options.target)) ? resolve(options.target) : null;
  const engagement = createDefaultEngagement({
    template: readJson(ENGAGEMENT_TEMPLATE_PATH),
    target: options.target,
    targetRoot: targetPath,
    artifactRoot,
    mode: options.mode,
    engagementId: options.engagementId ?? `argus-${new Date().toISOString().replace(/[:.]/g, '-')}`,
    selectedAgents,
  });
  const errors = validateEngagementManifest(engagement);
  if (errors.length > 0) fail(`generated engagement manifest is invalid: ${errors.join('; ')}`);
  mkdirSync(dirname(output), { recursive: true });
  writeFileSync(output, `${JSON.stringify(engagement, null, 2)}\n`, { mode: 0o600 });
  chmodSync(output, 0o600);
  const state = initializeEngagementState(engagement);
  console.log(`ENGAGEMENT  initialized manifest=${output} state=${state.path} selected=${selectedAgents.length}`);
  return 0;
}

function validateEngagement(args) {
  const options = parseNamedOptions(args, new Set(['--manifest']));
  const { manifest: engagement, path } = loadEngagement(options);
  initializeEngagementState(engagement);
  console.log(`PASS  engagement manifest=${path} selected=${engagement.selectedAgents.length}`);
  return 0;
}

function engagementAllocate(args) {
  const options = parseNamedOptions(args, new Set(['--manifest', '--lane']));
  requireOptions(options, ['manifest', 'lane'], 'engagement allocate');
  const { manifest: engagement } = loadEngagement(options);
  console.log(JSON.stringify(allocateWorker(engagement, options.lane)));
  return 0;
}

function engagementStatus(args) {
  const options = parseNamedOptions(args, new Set(['--manifest']));
  const { manifest: engagement } = loadEngagement(options);
  console.log(JSON.stringify(getEngagementStatus(engagement), null, 2));
  return 0;
}

