  const options = parseNamedOptions(args, new Set(['--manifest', '--lane', '--token', '--resource']));
  requireOptions(options, ['manifest', 'lane', 'resource'], 'engagement claim');
  const { manifest: engagement } = loadEngagement(options);
  console.log(JSON.stringify(claimExclusive(engagement, options.lane, leaseToken(options), options.resource)));
  return 0;
}

