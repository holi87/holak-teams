  const options = parseNamedOptions(args, new Set(['--manifest', '--lane', '--token', '--resource']));
  requireOptions(options, ['manifest', 'lane', 'resource'], 'engagement release');
  const { manifest: engagement } = loadEngagement(options);
  console.log(JSON.stringify(releaseExclusive(engagement, options.lane, leaseToken(options), options.resource)));
  return 0;
}

function engagementFragment(args) {
