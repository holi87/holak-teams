    "Read",
    "TaskCreate",
    "TaskGet",
    "TaskList",
    "TaskUpdate",
    "WebFetch",
    "WebSearch",
    "Write"
  ],
  "legacyToolReplacements": {
    "LS": "Glob or Bash",
    "MultiEdit": "Edit",
    "Task": "Agent",
    "TodoWrite": "TaskCreate, TaskGet, TaskList, and TaskUpdate"
  },
  "toolProfiles": {
    "official-docs": {
      "tools": [
        "WebSearch",
        "WebFetch",
        "mcp__plugin_context7_context7__resolve-library-id",
        "mcp__plugin_context7_context7__query-docs"
      ]
    },
    "remote-spec": {
      "tools": ["WebFetch"]
    },
    "public-browser-recon": {
      "tools": [
        "mcp__plugin_playwright_playwright__browser_navigate",
        "mcp__plugin_playwright_playwright__browser_snapshot"
      ]
    }
  },
  "doctrineProfiles": {
    "orchestration-core": { "requiredAsset": "orchestration-core-skill" },
