    "artifactPaths": [
      "ai_agents_internal/authorization.json",
      "ai_agents_internal/authorization-audit.jsonl",
      "ai_agents_internal/engagement.json",
      "ai_agents_internal/engagement-state.json",
      "ai_agents_internal/immutability-audit.jsonl",
      "ai_agents_internal/model-decisions/*.json",
      "ai_agents_internal/model-telemetry.jsonl",
      "ai_agents_internal/preflight.json",
      "solution/",
      "bugs/"
    ]
  },
  "capabilities": {
    "browser-runtime": {
      "kind": "browser",
      "missingDisposition": "deferred",
      "fallback": "Atlas must provision the packaged isolated driver and a Playwright browser, then rerun preflight before any browser lane is dispatched."
    },
    "context7": {
      "kind": "mcp",
      "serverPatterns": ["plugin:context7:context7", "context7"],
      "missingDisposition": "degraded",
      "fallback": "Use WebFetch against current official documentation and record the exact source URL."
    },
    "db-access": {
      "kind": "target",
      "missingDisposition": "skipped",
      "fallback": "Route data-integrity coverage to Atalanta through the public API and record direct DB coverage as skipped."
    },
    "existing-suite": {
      "kind": "target",
      "missingDisposition": "skipped",
      "fallback": "Do not dispatch suite sanitation when no existing test suite is present."
    },
    "multi-service": {
      "kind": "target",
      "missingDisposition": "skipped",
      "fallback": "Record consumer-driven contract coverage as not applicable until multiple services or consumers are confirmed."
    },
    "non-rest-surface": {
      "kind": "target",
      "missingDisposition": "skipped",
      "fallback": "Record GraphQL, gRPC, WebSocket, SSE, messaging, and webhook coverage as not applicable when recon finds none."
    },
    "playwright-mcp": {
      "kind": "mcp",
      "serverPatterns": ["plugin:playwright:playwright", "playwright"],
      "missingDisposition": "degraded",
      "fallback": "Use scripted CLI probes; browser lanes use the isolated hunt-driver. Shared MCP is never a fallback for authenticated or multi-step flows."
    },
    "source-access": {
      "kind": "target",
      "missingDisposition": "skipped",
      "fallback": "Keep the engagement black-box and record white-box source analysis as skipped."
    }
  },
