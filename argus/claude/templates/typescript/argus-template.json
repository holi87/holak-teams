{
  "schemaVersion": 1,
  "runtime": "typescript",
  "sharedContract": "argus/template-contract@1",
  "framework": "playwright",
  "runner": "playwright-test",
  "packageManagers": ["npm"],
  "layoutPlaceholders": { "testRoot": "tests", "harnessRoot": "src" },
  "tagAdapter": { "contract-smoke": "@contract-smoke", "quarantine": "@quarantine", "regression": "@regression", "bug-provenance": "@bug:<canonical-or-origin>" },
  "extensionPoints": ["package-manager-adapter", "test-root", "harness-root", "ci-command"],
  "unsupportedByDefault": ["pnpm", "yarn", "bun", "jest", "vitest"]
}
