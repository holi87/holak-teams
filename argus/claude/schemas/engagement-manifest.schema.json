{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/holi87/holak-teams/argus/schemas/engagement-manifest.schema.json",
  "title": "Argus engagement manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion", "engagementId", "mode", "target", "artifactRoot",
    "selectedAgents", "accessibilityPolicy", "browserPolicy", "phasePlan", "writePolicy", "resourcePolicy",
    "idAllocators", "cleanup", "statePath"
  ],
  "properties": {
    "$schema": { "type": "string" },
    "schemaVersion": { "const": 1 },
    "engagementId": { "type": "string", "minLength": 1 },
    "mode": { "enum": ["A", "B", "C", "D"] },
    "target": {
      "type": "object",
      "additionalProperties": false,
      "required": ["identifier", "root"],
      "properties": {
        "identifier": { "type": "string", "minLength": 1 },
        "root": { "type": ["string", "null"] }
      }
    },
    "artifactRoot": { "type": "string", "minLength": 1 },
    "selectedAgents": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/slug" }
    },
    "modelTrust": {
      "oneOf": [
        { "type": "null" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["schema", "source", "trustStoreSha256", "pinnedAt", "keys", "legacyBootstrap"],
          "properties": {
            "schema": { "const": "argus/model-trust-bundle@1" },
            "source": { "const": "host-trust-store" },
            "trustStoreSha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
            "pinnedAt": { "type": "string", "format": "date-time" },
            "keys": {
              "type": "object",
              "additionalProperties": false,
              "required": ["runtimeAttestation", "operatorApproval"],
              "properties": {
                "runtimeAttestation": { "$ref": "#/$defs/runtimeAttestationTrustKey" },
                "operatorApproval": { "$ref": "#/$defs/operatorApprovalTrustKey" }
              }
            },
            "legacyBootstrap": {
              "oneOf": [
                { "type": "null" },
                {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["kind", "authenticatedLane", "allocationId", "migrationId", "migrationSourceSha256"],
                  "properties": {
                    "kind": { "const": "legacy-v1-active-allocation" },
                    "authenticatedLane": { "$ref": "#/$defs/slug" },
                    "allocationId": { "type": "string", "pattern": "^[a-f0-9]{24}$" },
                    "migrationId": { "type": "string", "pattern": "^state-v1-[a-f0-9]{24}$" },
                    "migrationSourceSha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
                  }
                }
              ]
            }
          }
        }
      ]
    },
    "accessibilityPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["standard", "version", "level", "exception"],
      "properties": {
        "standard": { "const": "WCAG" },
        "version": { "type": "string", "pattern": "^2\\.[0-2]$" },
        "level": { "enum": ["A", "AA", "AAA"] },
        "exception": {
          "oneOf": [
            { "type": "null" },
            {
              "type": "object",
              "additionalProperties": false,
              "required": ["requiredVersion", "requiredLevel", "reason", "requirementSource", "approvedBy"],
              "properties": {
                "requiredVersion": { "type": "string", "pattern": "^2\\.[0-2]$" },
                "requiredLevel": { "enum": ["A", "AA", "AAA"] },
                "reason": { "type": "string", "minLength": 1 },
                "requirementSource": { "type": "string", "minLength": 1 },
                "approvedBy": { "type": "string", "minLength": 1 }
              }
            }
          ]
        }
      }
    },
    "browserPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sessionMode", "sharedSessionAuthorization", "profileReuse", "profileStorage", "sensitiveArtifacts", "coverage"],
      "properties": {
        "sessionMode": { "enum": ["isolated-managed", "shared-authorized"] },
        "sharedSessionAuthorization": {
          "oneOf": [
            { "type": "null" },
            {
              "type": "object",
              "additionalProperties": false,
              "required": ["id", "lanes", "accountAlias", "approvedBy", "reason", "authorizationRuleId", "expiresAt"],
              "properties": {
                "id": { "$ref": "#/$defs/slug" },
                "lanes": { "type": "array", "minItems": 2, "uniqueItems": true, "items": { "$ref": "#/$defs/slug" } },
                "accountAlias": { "type": "string", "minLength": 1 },
                "approvedBy": { "type": "string", "minLength": 1 },
                "reason": { "type": "string", "minLength": 1 },
                "authorizationRuleId": { "type": "string", "minLength": 1 },
                "expiresAt": { "type": "string", "format": "date-time" }
              }
            }
          ]
        },
        "profileReuse": { "const": "same-lane-within-engagement" },
        "profileStorage": { "const": "engagement-worker-root" },
        "sensitiveArtifacts": {
          "type": "array",
          "uniqueItems": true,
          "items": { "enum": ["auth", "cookies", "downloads", "traces", "videos", "screenshots"] }
        },
        "coverage": {
          "type": "object",
          "additionalProperties": false,
          "required": ["derivation", "supportSource", "riskSignals", "rationale", "matrix"],
          "properties": {
            "derivation": { "const": "target-support-and-risk" },
            "supportSource": { "type": "string", "minLength": 1 },
            "riskSignals": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
            "rationale": { "type": "string", "minLength": 1 },
            "matrix": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": ["browser", "device", "viewport", "reasons"],
                "properties": {
                  "browser": { "enum": ["chromium", "firefox", "webkit"] },
                  "device": { "type": "string", "minLength": 1 },
                  "viewport": {
                    "type": "object",
                    "additionalProperties": false,
                    "required": ["width", "height"],
                    "properties": {
                      "width": { "type": "integer", "minimum": 240, "maximum": 10000 },
                      "height": { "type": "integer", "minimum": 240, "maximum": 10000 }
                    }
                  },
                  "reasons": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "minLength": 1 } }
                }
              }
            }
          }
        }
      }
    },
    "phasePlan": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "participants"],
        "properties": {
          "id": { "enum": ["preflight", "discovery", "hunting", "automation", "verification", "reporting", "complete"] },
          "participants": {
            "type": "array",
            "uniqueItems": true,
            "items": { "$ref": "#/$defs/slug" }
          }
        }
      }
    },
    "writePolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "auditPath", "fragmentRoot", "checkpointRoot", "workerRoot",
        "allowedArtifactRoots", "generatedTestRoots", "canonicalArtifacts", "bypass"
      ],
      "properties": {
        "auditPath": { "$ref": "#/$defs/relativePath" },
        "fragmentRoot": { "$ref": "#/$defs/relativePath" },
        "checkpointRoot": { "$ref": "#/$defs/relativePath" },
        "workerRoot": { "$ref": "#/$defs/relativePath" },
        "allowedArtifactRoots": { "$ref": "#/$defs/pathList" },
        "generatedTestRoots": { "$ref": "#/$defs/pathList" },
        "canonicalArtifacts": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["path", "owner", "format"],
            "properties": {
              "path": { "$ref": "#/$defs/relativePath" },
              "owner": { "$ref": "#/$defs/slug" },
              "format": { "enum": ["markdown", "text", "json", "json-document"] },
              "schema": { "type": ["string", "null"], "enum": [null, "bug-ledger", "lane-plan", "evidence-reference", "automation-status", "surface-inventory", "coverage-observations", "coverage-result", "final-summary"] }
            }
          }
        },
        "bypass": {
          "type": "object",
          "additionalProperties": false,
          "required": ["enabled", "approvedBy", "reason", "expiresAt", "allowedPaths", "tokenSha256"],
          "properties": {
            "enabled": { "type": "boolean" },
            "approvedBy": { "type": ["string", "null"] },
            "reason": { "type": ["string", "null"] },
            "expiresAt": { "type": ["string", "null"], "format": "date-time" },
            "allowedPaths": { "$ref": "#/$defs/pathList" },
            "tokenSha256": { "type": ["string", "null"], "pattern": "^[a-f0-9]{64}$" }
          }
        }
      }
    },
    "resourcePolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["portRange", "exclusiveOperations"],
      "properties": {
        "portRange": {
          "type": "object",
          "additionalProperties": false,
          "required": ["start", "end"],
          "properties": {
            "start": { "type": "integer", "minimum": 1024, "maximum": 65535 },
            "end": { "type": "integer", "minimum": 1024, "maximum": 65535 }
          }
        },
        "exclusiveOperations": {
          "type": "object",
          "additionalProperties": false,
          "required": ["reset", "fault"],
          "properties": {
            "reset": { "$ref": "#/$defs/slug" },
            "fault": { "$ref": "#/$defs/slug" }
          }
        }
      }
    },
    "idAllocators": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": ["owner", "prefix", "width"],
        "properties": {
          "owner": { "$ref": "#/$defs/slug" },
          "prefix": { "type": "string", "pattern": "^[A-Z][A-Z0-9-]*$" },
          "width": { "type": "integer", "minimum": 1, "maximum": 12 }
        }
      }
    },
    "cleanup": {
      "type": "object",
      "additionalProperties": false,
      "required": ["removeOnRelease"],
      "properties": {
        "removeOnRelease": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "enum": ["browser-profile", "browser-artifacts", "auth", "tmp", "locks"] }
        }
      }
    },
    "statePath": { "$ref": "#/$defs/relativePath" }
  },
  "$defs": {
    "slug": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
    "runtimeAttestationTrustKey": {
      "type": "object",
      "additionalProperties": false,
      "required": ["keyId", "purpose", "subjectId", "algorithm", "publicKeyPem", "keyFingerprintSha256"],
      "properties": {
        "keyId": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$" },
        "purpose": { "const": "runtime-attestation" },
        "subjectId": { "type": "string", "minLength": 1 },
        "algorithm": { "const": "Ed25519" },
        "publicKeyPem": { "type": "string", "pattern": "^-----BEGIN PUBLIC KEY-----" },
        "keyFingerprintSha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
      }
    },
    "operatorApprovalTrustKey": {
      "type": "object",
      "additionalProperties": false,
      "required": ["keyId", "purpose", "subjectId", "algorithm", "publicKeyPem", "keyFingerprintSha256"],
      "properties": {
        "keyId": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$" },
        "purpose": { "const": "operator-approval" },
        "subjectId": { "type": "string", "minLength": 1 },
        "algorithm": { "const": "Ed25519" },
        "publicKeyPem": { "type": "string", "pattern": "^-----BEGIN PUBLIC KEY-----" },
        "keyFingerprintSha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
      }
    },
    "relativePath": { "type": "string", "minLength": 1, "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$)).+" },
    "pathList": {
      "type": "array",
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/relativePath" }
    }
  }
}
