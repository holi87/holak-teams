{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://holak-teams.local/argus/runtime-adapters.schema.json",
  "title": "Argus Claude and Codex runtime adapters",
  "type": "object",
  "additionalProperties": false,
  "required": ["$schema", "schemaVersion", "support", "configurationParity", "claude", "codex", "explicitDifferences"],
  "properties": {
    "$schema": { "type": "string" },
    "schemaVersion": { "const": 2 },
    "support": {
      "type": "object",
      "additionalProperties": false,
      "required": ["claude", "codex"],
      "properties": {
        "claude": {
          "type": "object",
          "additionalProperties": false,
          "required": ["level", "parentRuntimeRequired"],
          "properties": {
            "level": { "const": "plugin-native" },
            "parentRuntimeRequired": { "const": false }
          }
        },
        "codex": {
          "type": "object",
          "additionalProperties": false,
          "required": ["level", "parentRuntimeRequired", "requiredParentCapabilities", "missingCapabilityOutcome"],
          "properties": {
            "level": { "const": "parent-runtime-dependent" },
            "parentRuntimeRequired": { "const": true },
            "requiredParentCapabilities": {
              "type": "array",
              "minItems": 1,
              "uniqueItems": true,
              "items": { "enum": ["orchestration", "packaged-assets", "tool-equivalence"] }
            },
            "missingCapabilityOutcome": { "const": "CAPABILITY_GAP" }
          }
        }
      }
    },
    "configurationParity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "scope", "doesNotClaim"],
      "properties": {
        "status": { "const": "validated" },
        "scope": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "enum": ["role-inventory", "generated-instructions", "model-and-effort", "sandbox-policy", "native-config-load"]
          }
        },
        "doesNotClaim": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "enum": ["behavioral-equivalence", "tool-availability", "packaged-asset-availability", "delegation-execution", "target-outcomes"]
          }
        }
      }
    },
    "claude": {
      "type": "object",
      "additionalProperties": false,
      "required": ["preloadedSkill", "toolSource", "modelSource"],
      "properties": {
        "preloadedSkill": { "const": "qa-doctrine" },
        "toolSource": { "const": "role-manifest" },
        "modelSource": { "const": "model-policy" }
      }
    },
    "codex": {
      "type": "object",
      "additionalProperties": false,
      "required": ["modelSource", "sandboxPolicy", "doctrinePolicy", "toolPolicy"],
      "properties": {
        "modelSource": { "const": "model-policy" },
        "sandboxPolicy": { "type": "string", "minLength": 1 },
        "doctrinePolicy": { "type": "string", "minLength": 1 },
        "toolPolicy": { "type": "string", "minLength": 1 }
      }
    },
    "explicitDifferences": {
      "type": "array",
      "minItems": 5,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["field", "claude", "codex", "reason"],
        "properties": {
          "field": { "type": "string", "minLength": 1 },
          "claude": { "type": "string", "minLength": 1 },
          "codex": { "type": "string", "minLength": 1 },
          "reason": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
