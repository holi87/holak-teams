{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/holi87/holak-teams/argus/schemas/bug-ledger.schema.json",
  "title": "Argus confirmed defect ledger",
  "type": "array",
  "items": {
    "type": "object",
    "additionalProperties": true,
    "required": ["id", "origin", "title", "severity", "priority", "lane", "oracle_id", "wired", "test_ref"],
    "properties": {
      "id": { "type": "string", "pattern": "^BUG-[0-9]{4}$" },
      "origin": {
        "type": "array",
        "minItems": 1,
        "uniqueItems": true,
        "items": { "type": "string", "pattern": "^[A-Z]{3}-[0-9]{3,4}$" }
      },
      "title": { "type": "string", "minLength": 1 },
      "severity": { "enum": ["Blocker", "Critical", "Major", "Minor", "Trivial"] },
      "priority": { "enum": ["P1", "P2", "P3", "P4"] },
      "lane": { "type": "string", "minLength": 1 },
      "oracle_id": { "type": "string", "pattern": "^ORC-[A-Z0-9]+-[0-9]{3,4}$" },
      "status": { "enum": ["CONFIRMED", "SUSPECTED", "NEEDS_ORACLE"] },
      "req_risk": { "type": ["string", "null"] },
      "detected_by": { "type": ["string", "null"] },
      "wired": { "type": "boolean" },
      "test_ref": { "type": ["string", "null"] }
    },
    "allOf": [
      {
        "if": { "properties": { "wired": { "const": true } }, "required": ["wired"] },
        "then": { "properties": { "test_ref": { "type": "string", "minLength": 1 } } }
      }
    ]
  }
}
