{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://holak-teams.local/argus/model-decision.schema.json",
  "title": "Immutable Argus model routing decision",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema", "decisionId", "integritySha256", "relativePath", "createdAt", "policyId", "policySha256",
    "engagementId", "engagementManifestSha256", "dispatchId", "attempt",
    "agent", "runtime", "signal", "status", "reasonCode", "baselineConfig",
    "selectedConfig", "requiredOverrides", "requiredEnforcements", "adapter", "missingCapabilities", "fallbackUsed",
    "operatorEscalation", "weakerFallbackAllowed", "reason"
  ],
  "properties": {
    "schema": { "const": "argus/model-decision@2" },
    "decisionId": { "type": "string", "pattern": "^MDR-[a-f0-9]{24}$" },
    "integritySha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "relativePath": { "type": "string", "pattern": "^ai_agents_internal/model-decisions/MDR-[a-f0-9]{24}\\.json$" },
    "createdAt": { "type": "string", "format": "date-time" },
    "policyId": { "const": "argus/model-policy@1" },
    "policySha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "engagementId": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$" },
    "engagementManifestSha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "dispatchId": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$" },
    "attempt": { "type": "integer", "minimum": 1 },
    "agent": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
    "runtime": { "enum": ["claude", "codex"] },
    "signal": { "type": "string", "minLength": 1 },
    "status": { "enum": ["selected", "blocked"] },
    "reasonCode": {
      "enum": [
        "BASELINE_SELECTED",
        "ESCALATION_SELECTED",
        "SIGNAL_NOT_ALLOWED",
        "MECHANICAL_FULL_ROLE_FORBIDDEN",
        "FRONTIER_UNAVAILABLE",
        "CAPABILITY_DRIFT"
      ]
    },
    "baselineConfig": { "$ref": "#/$defs/modelConfig" },
    "selectedConfig": { "$ref": "#/$defs/modelConfig" },
    "requiredOverrides": {
      "type": "array",
      "uniqueItems": true,
      "items": { "enum": ["model", "effort"] }
    },
    "requiredEnforcements": {
      "type": "array",
      "minItems": 3,
      "uniqueItems": true,
      "items": { "enum": ["model", "effort", "maxTurns"] }
    },
    "adapter": {
      "type": "object",
      "additionalProperties": false,
      "required": ["contractId", "adapterId", "snapshotSha256", "runtime", "mode", "capabilities"],
      "properties": {
        "contractId": { "const": "argus/runtime-adapters@3" },
        "adapterId": { "enum": ["claude-plugin-agent@1", "codex-custom-agent@1"] },
        "snapshotSha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "runtime": { "enum": ["claude", "codex"] },
        "mode": { "enum": ["baseline", "escalation"] },
        "capabilities": { "$ref": "#/$defs/enforcementCapabilities" }
      }
    },
    "missingCapabilities": {
      "type": "array",
      "uniqueItems": true,
      "items": { "enum": ["model", "effort", "maxTurns"] }
    },
    "fallbackUsed": { "type": "boolean" },
    "operatorEscalation": { "type": "boolean" },
    "weakerFallbackAllowed": { "const": false },
    "reason": { "type": "string", "minLength": 1 }
  },
  "$defs": {
    "modelConfig": {
      "type": "object",
      "additionalProperties": false,
      "required": ["tier", "model", "effort", "maxTurns"],
      "properties": {
        "tier": { "enum": ["frontier", "standard", "mechanical"] },
        "model": { "type": "string", "minLength": 1 },
        "effort": { "type": "string", "minLength": 1 },
        "maxTurns": { "type": "integer", "minimum": 1 }
      }
    },
    "enforcementCapabilities": {
      "type": "object",
      "additionalProperties": false,
      "required": ["model", "effort", "maxTurns"],
      "properties": {
        "model": { "type": "boolean" },
        "effort": { "type": "boolean" },
        "maxTurns": { "type": "boolean" }
      }
    }
  }
}
