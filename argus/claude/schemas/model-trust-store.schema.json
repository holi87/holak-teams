{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://holak-teams.local/argus/model-trust-store.schema.json",
  "title": "Host-provisioned Argus model trust store",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "schemaVersion", "keys"],
  "properties": {
    "schema": { "const": "argus/model-trust-store@1" },
    "schemaVersion": { "const": 1 },
    "keys": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["keyId", "purpose", "subjectId", "algorithm", "publicKeyPem", "status"],
        "properties": {
          "keyId": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$" },
          "purpose": { "enum": ["runtime-attestation", "operator-approval"] },
          "subjectId": { "type": "string", "minLength": 1 },
          "algorithm": { "const": "Ed25519" },
          "publicKeyPem": { "type": "string", "pattern": "^-----BEGIN PUBLIC KEY-----" },
          "status": { "enum": ["active", "revoked"] }
        }
      }
    }
  }
}
