{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/holi87/holak-teams/argus/schemas/final-summary.schema.json",
  "title": "Argus final engagement summary v1",
  "type": "object", "additionalProperties": false,
  "required": ["$schema", "schemaVersion", "engagementId", "owner", "status", "counts", "sourceSchemas", "summary", "generatedAt"],
  "properties": {
    "$schema": { "const": "argus/final-summary@1" }, "schemaVersion": { "const": 1 }, "engagementId": { "type": "string", "minLength": 1 }, "owner": { "const": "kleio" }, "status": { "enum": ["completed", "blocked", "degraded"] },
    "counts": { "type": "object", "additionalProperties": false, "required": ["bugs", "automated", "evidence"], "properties": { "bugs": { "type": "integer", "minimum": 0 }, "automated": { "type": "integer", "minimum": 0 }, "evidence": { "type": "integer", "minimum": 0 } } },
    "sourceSchemas": { "type": "array", "uniqueItems": true, "items": { "type": "string", "pattern": "^argus/[a-z-]+@1$" } }, "summary": { "type": "string", "minLength": 1 }, "generatedAt": { "type": "string", "format": "date-time" }
  }
}
